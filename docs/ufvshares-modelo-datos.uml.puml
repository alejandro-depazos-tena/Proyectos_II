QUEDADA "1" -- "0..*" ASISTENCIA : tiene
UBICACION "1" -- "0..*" QUEDADA : se_realiza_en

CATEGORIA "1" -- "0..*" PRODUCTO : clasifica
UBICACION "0..*" -- "0..1" PRODUCTO : entrega_en
PRODUCTO "1" -- "0..*" FOTO : contiene
PRODUCTO "1" -- "0..*" CONVERSACION : genera
PRODUCTO "1" -- "0..*" VALORACION : asociada

CONVERSACION "1" -- "0..*" MENSAJE : contiene
USUARIO "1" -- "0..*" CONVERSACION : participante1
USUARIO "1" -- "0..*" CONVERSACION : participante2

PRODUCTO_AMAZON "1" -- "0..*" HISTORICO_PRECIO : registra
PRODUCTO_AMAZON "1" -- "0..*" ALERTA_PRECIO : monitorea
USUARIO "1" -- "0..*" ALERTA_PRECIO : crea

