# Variables de entorno del frontend
# Copia este fichero como .env y rellena los valores

# URL del backend (Spring Boot)
PUBLIC_API_BASE=http://localhost:8080/api

# API Key de Google Books (necesaria para el buscador de libros en /profile)
# Obtener en: https://console.cloud.google.com/ → APIs → Books API → Credenciales
PUBLIC_GOOGLE_BOOKS_KEY=
