---
import "../styles/global.css";
import Navbar from "../components/navbar/NavBar.astro";
import AnnouncementBar from "../components/ui/AnnouncementBar.astro";
import Footer from "../components/footer/Footer.astro";
import ToasterComponent from "../components/ui/ToasterComponent";

const { title } = Astro.props;
const pageTitle = typeof title === "string" && title.trim().length > 0 ? title : "UFV Shares";
---

<!doctype html>
<html lang="es" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<style>body{visibility:hidden;}</style>
		<script is:inline>
			(function(){
				if(!localStorage.getItem('ufvshares_token')){
					location.replace('/auth?mode=login&next='+encodeURIComponent(location.pathname+location.search));
				} else {
					document.addEventListener('DOMContentLoaded',function(){document.body.style.visibility='visible';});
				}
			})();
		</script>
	</head>
	<body class="bg-base-200 min-h-screen">
		<AnnouncementBar />
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
		<ToasterComponent client:load />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
	}
</style>
