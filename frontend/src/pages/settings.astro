  };

  function openLegalModal(key) {
    const data = legalContent[key];
    if (!data || !legalModal || !legalModalTitle || !legalModalContent || !legalModalKicker) return;
    legalModalKicker.textContent = data.kicker;
    legalModalTitle.textContent = data.title;
    legalModalContent.innerHTML = data.body;
    legalModal.classList.remove("hidden");
    legalModal.classList.add("flex");
  }

  function closeLegalModal() {
    if (!legalModal) return;
    legalModal.classList.add("hidden");
    legalModal.classList.remove("flex");
  }

  document.querySelectorAll("[data-legal-open]").forEach((btn) => {
    btn.addEventListener("click", () => {
      openLegalModal(btn.getAttribute("data-legal-open"));
    });
  });

  legalModalClose?.addEventListener("click", closeLegalModal);
  legalModalAccept?.addEventListener("click", closeLegalModal);
  legalModal?.addEventListener("click", (event) => {
    if (event.target === legalModal) closeLegalModal();
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeLegalModal();
  });

  themeToggle?.addEventListener("click", () => {
    const currentTheme = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
    setTheme(currentTheme === "dark" ? "light" : "dark");
  });

  async function loadActivity() {
    try {
      if (userPill) userPill.textContent = "Sesión verificada";
      const res = await fetch(API_BASE + "/me/historial", { headers });
      if (!res.ok) {
        renderHistory([]);
        return;
      }
      const historial = await res.json();
      renderHistory(Array.isArray(historial) ? historial : []);
    } catch {
      renderHistory([]);
    }
  }

  loadActivity();
</script>
