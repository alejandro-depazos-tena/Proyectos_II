---
import Layout from "../layouts/Layout.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "/api";
---

<Layout title="Panel Admin | UFV Shares">
  <section class="admin-shell">
    <header class="admin-hero">
      <div>
        <p class="admin-kicker">Panel de administracion</p>
        <h1>Dashboard operativo</h1>
        <p>
          Vista rapida de salud de plataforma, conversion de solicitudes y actividad diaria.
        </p>
      </div>
      <ul id="admin-highlights" class="hero-highlights">
        <li>Cargando metricas...</li>
      </ul>
    </header>

    <div id="admin-error" class="admin-error hidden"></div>

    <section class="summary-grid">
      <article class="panel">
        <h2>Resumen general</h2>
        <div id="kpis-main" class="kpis-grid kpis-main"></div>
      </article>

      <article class="panel">
        <h2>Operacion</h2>
        <div id="kpis-secondary" class="kpis-grid"></div>
      </article>

      <article class="panel">
        <h2>Lectura rapida</h2>
        <ul id="insights-list" class="insights-list">
          <li>Esperando datos del backend...</li>
        </ul>
      </article>
    </section>

    <section class="charts-grid">
      <article class="chart-card chart-card-wide">
        <header class="chart-head">
          <h3>Publicaciones por dia</h3>
          <p>Tendencia de los ultimos 14 dias</p>
        </header>
        <div id="chart-productos-dia" class="chart-line"></div>
      </article>

      <article class="chart-card chart-card-wide">
        <header class="chart-head">
          <h3>Mensajes de chat por dia</h3>
          <p>Actividad de conversaciones reciente</p>
        </header>
        <div id="chart-mensajes-dia" class="chart-line"></div>
      </article>

      <article class="chart-card">
        <header class="chart-head">
          <h3>Solicitudes por estado</h3>
          <p>Volumen por estado actual</p>
        </header>
        <div id="chart-solicitudes-estado" class="chart-bars"></div>
      </article>

      <article class="chart-card">
        <header class="chart-head">
          <h3>Composicion de solicitudes</h3>
          <p>Distribucion porcentual</p>
        </header>
        <div id="chart-solicitudes-ratio" class="chart-stacked"></div>
      </article>

      <article class="chart-card">
        <header class="chart-head">
          <h3>Productos por categoria</h3>
          <p>Comparativa por segmento</p>
        </header>
        <div id="chart-productos-categoria" class="chart-bars"></div>
      </article>

      <article class="chart-card">
        <header class="chart-head">
          <h3>Distribucion por categoria</h3>
          <p>Peso relativo de cada categoria</p>
        </header>
        <div id="chart-categorias-donut" class="chart-donut"></div>
      </article>

      <article class="chart-card">
        <header class="chart-head">
          <h3>Tipos de transaccion</h3>
          <p>Que formato se publica mas</p>
        </header>
        <div id="chart-productos-tipo" class="chart-bars"></div>
      </article>

      <article class="chart-card">
        <header class="chart-head">
          <h3>Top productos mas solicitados</h3>
          <p>Ranking para detectar demanda</p>
        </header>
        <div id="chart-top-productos" class="chart-rank"></div>
      </article>
    </section>

    <section class="moderation-grid">
      <article class="panel moderation-panel">
        <header class="chart-head">
          <h3>Reportes de producto</h3>
          <p>Contenido del marketplace pendiente de revisión</p>
        </header>
        <div id="reportes-producto-list" class="moderation-list">
          <p class="chart-empty">Cargando reportes...</p>
        </div>
      </article>

      <article class="panel moderation-panel">
        <header class="chart-head">
          <h3>Reportes de usuario</h3>
          <p>Usuarios señalados por la comunidad</p>
        </header>
        <div id="reportes-usuario-list" class="moderation-list">
          <p class="chart-empty">Cargando reportes...</p>
        </div>
      </article>
    </section>
  </section>
</Layout>

<script define:vars={{ API_BASE }}>
  const token = localStorage.getItem("ufvshares_token");
  const errEl = document.getElementById("admin-error");

  function clearSession() {
    ["ufvshares_token", "ufvshares_email", "ufvshares_nombre", "ufvshares_id", "ufvshares_admin"].forEach((k) => {
      localStorage.removeItem(k);
    });
  }

  function showError(message) {
    if (!errEl) return;
    errEl.textContent = message;
    errEl.classList.remove("hidden");
  }

  function shortDateLabel(isoDate) {
    try {
      const d = new Date(isoDate + "T00:00:00");
      return d.toLocaleDateString("es-ES", { day: "2-digit", month: "2-digit" });
    } catch {
      return isoDate;
    }
  }

  function formatLabel(label) {
    return String(label || "").replaceAll("_", " ");
  }

  function n(value) {
    return Number(value || 0);
  }

  function sumCounts(rows) {
    return (Array.isArray(rows) ? rows : []).reduce((acc, row) => acc + n(row.count), 0);
  }

  function formatNumber(value) {
    return n(value).toLocaleString("es-ES");
  }

  function percent(part, total) {
    if (!total) return 0;
    return Math.round((n(part) / n(total)) * 100);
  }

  function splitRows(rows, max = 5) {
    return (Array.isArray(rows) ? rows : []).slice(0, max);
  }

  function renderKpis(overview) {
    const mainEl = document.getElementById("kpis-main");
    const secondaryEl = document.getElementById("kpis-secondary");
    if (!mainEl || !secondaryEl) return;

    const mainCards = [
      ["Usuarios", overview.totalUsuarios],
      ["Productos publicados", overview.totalProductos],
      ["Solicitudes pendientes", overview.solicitudesPendientes],
      ["Compras realizadas", overview.comprasRealizadas],
    ];

    const secondaryCards = [
      ["Solicitudes aceptadas", overview.solicitudesAceptadas],
      ["Solicitudes rechazadas", overview.solicitudesRechazadas],
      ["Alquileres activos", overview.alquileresActivos],
      ["Conversaciones", overview.conversacionesActivas],
      ["Mensajes totales", overview.mensajesTotales],
    ];

    mainEl.innerHTML = mainCards
      .map(([title, value]) => `
        <div class="kpi-card kpi-card-main">
          <span>${title}</span>
          <strong>${formatNumber(value)}</strong>
        </div>
      `)
      .join("");

    secondaryEl.innerHTML = secondaryCards
      .map(([title, value]) => `
        <div class="kpi-card">
          <span>${title}</span>
          <strong>${formatNumber(value)}</strong>
        </div>
      `)
      .join("");
  }

  function renderHighlights(overview, charts) {
    const highlightsEl = document.getElementById("admin-highlights");
    const insightsEl = document.getElementById("insights-list");
    if (!highlightsEl || !insightsEl) return;

    const solicitudesTotal =
      n(overview.solicitudesPendientes) + n(overview.solicitudesAceptadas) + n(overview.solicitudesRechazadas);
    const tasaAceptacion = percent(overview.solicitudesAceptadas, solicitudesTotal);
    const ratioMensajesPorChat = n(overview.conversacionesActivas)
      ? Math.round(n(overview.mensajesTotales) / n(overview.conversacionesActivas))
      : 0;

    const productosPorDia = Array.isArray(charts.productosPorDia) ? charts.productosPorDia : [];
    const ultimos7 = productosPorDia.slice(-7).reduce((acc, row) => acc + n(row.count), 0);
    const previos7 = productosPorDia.slice(-14, -7).reduce((acc, row) => acc + n(row.count), 0);
    const delta7 = ultimos7 - previos7;

    const categorias = splitRows(charts.productosPorCategoria, 3);
    const topCategoria = categorias[0];

    highlightsEl.innerHTML = `
      <li><strong>${formatNumber(overview.totalUsuarios)}</strong> usuarios registrados</li>
      <li><strong>${tasaAceptacion}%</strong> tasa de aceptacion de solicitudes</li>
      <li><strong>${formatNumber(delta7)}</strong> diferencia de publicaciones vs semana anterior</li>
    `;

    insightsEl.innerHTML = `
      <li>
        <span class="insight-title">Conversion de solicitudes</span>
        <p>${formatNumber(overview.solicitudesAceptadas)} aceptadas de ${formatNumber(solicitudesTotal)} totales.</p>
      </li>
      <li>
        <span class="insight-title">Ritmo de publicaciones</span>
        <p>${formatNumber(ultimos7)} en los ultimos 7 dias, ${delta7 >= 0 ? "sube" : "baja"} ${formatNumber(Math.abs(delta7))} frente a la semana previa.</p>
      </li>
      <li>
        <span class="insight-title">Actividad en chat</span>
        <p>Promedio de ${formatNumber(ratioMensajesPorChat)} mensajes por conversacion activa.</p>
      </li>
      <li>
        <span class="insight-title">Categoria dominante</span>
        <p>${topCategoria ? `${formatLabel(topCategoria.label)} con ${formatNumber(topCategoria.count)} publicaciones.` : "Sin datos de categoria."}</p>
      </li>
    `;
  }

  function renderBarChart(containerId, rows) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const data = Array.isArray(rows) ? rows : [];
    const max = Math.max(1, ...data.map((r) => n(r.count)));

    if (!data.length) {
      el.innerHTML = '<p class="chart-empty">Sin datos</p>';
      return;
    }

    el.innerHTML = data
      .map((row) => {
        const count = n(row.count);
        const pct = Math.max(3, Math.round((count / max) * 100));
        return `
          <div class="bar-row">
            <div class="bar-meta">
              <span>${formatLabel(row.label)}</span>
              <strong>${formatNumber(count)}</strong>
            </div>
            <div class="bar-track"><div class="bar-fill" style="width:${pct}%"></div></div>
          </div>
        `;
      })
      .join("");
  }

  function renderRankList(containerId, rows) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const data = splitRows(rows, 5);
    const max = Math.max(1, ...data.map((r) => n(r.count)));

    if (!data.length) {
      el.innerHTML = '<p class="chart-empty">Sin datos</p>';
      return;
    }

    el.innerHTML = data
      .map((row, idx) => {
        const count = n(row.count);
        const pct = Math.max(4, Math.round((count / max) * 100));
        return `
          <div class="rank-row">
            <span class="rank-num">#${idx + 1}</span>
            <div class="rank-content">
              <p class="rank-title">${formatLabel(row.label)}</p>
              <div class="rank-track"><div class="rank-fill" style="width:${pct}%"></div></div>
            </div>
            <strong>${formatNumber(count)}</strong>
          </div>
        `;
      })
      .join("");
  }

  function formatReportDate(isoDate) {
    if (!isoDate) return '—';
    try {
      return new Date(isoDate).toLocaleString('es-ES', {
        day: '2-digit',
        month: 'short',
        year: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
      });
    } catch {
      return isoDate;
    }
  }

  function reportStateClass(state) {
    if (state === 'CERRADO') return 'badge-success';
    if (state === 'EN_REVISION') return 'badge-warning';
    return 'badge-error';
  }

  function renderModerationReports(containerId, items, kind) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const data = Array.isArray(items) ? items : [];
    if (!data.length) {
      el.innerHTML = '<p class="chart-empty">No hay reportes</p>';
      return;
    }

    el.innerHTML = data.map((item) => {
      const reportante = item.reportante || {};
      const target = kind === 'product' ? (item.producto || {}) : (item.reportado || {});
      const targetName = kind === 'product'
        ? (target.titulo || `Producto #${item.producto?.idProducto ?? '—'}`)
        : [`${target.nombre || ''} ${target.apellidos || ''}`.trim(), target.correo].filter(Boolean).join(' · ') || `Usuario #${item.reportado?.idUsuario ?? '—'}`;
      const reportanteName = [`${reportante.nombre || ''} ${reportante.apellidos || ''}`.trim(), reportante.correo].filter(Boolean).join(' · ') || `Usuario #${reportante.idUsuario ?? '—'}`;
      const state = item.estadoReporte || 'ABIERTO';
      return `
        <article class="moderation-card" data-report-id="${item.idReporte}" data-report-kind="${kind}">
          <div class="moderation-card-head">
            <div>
              <p class="moderation-title">${formatLabel(item.motivo)}</p>
              <p class="moderation-subtitle">${targetName}</p>
            </div>
            <span class="badge ${reportStateClass(state)} border-none">${formatLabel(state)}</span>
          </div>
          <p class="moderation-meta">Reportado por: ${reportanteName}</p>
          <p class="moderation-meta">Fecha: ${formatReportDate(item.fechaReporte)}</p>
          ${item.comentario ? `<p class="moderation-comment">${item.comentario}</p>` : ''}
          <div class="moderation-actions">
            ${state !== 'CERRADO' ? `<button type="button" class="btn btn-sm btn-primary rounded-full" data-report-close>Marcar como cerrado</button>` : '<span class="moderation-closed">Cerrado</span>'}
          </div>
        </article>
      `;
    }).join('');
  }

  async function loadModerationReports() {
    const productRes = await fetch(API_BASE + '/admin/reportes-producto', { headers: { Authorization: 'Bearer ' + token } });
    const userRes = await fetch(API_BASE + '/admin/reportes-usuario', { headers: { Authorization: 'Bearer ' + token } });

    if (productRes.ok) {
      const productReports = await productRes.json().catch(() => []);
      renderModerationReports('reportes-producto-list', productReports, 'product');
    } else {
      const el = document.getElementById('reportes-producto-list');
      if (el) el.innerHTML = '<p class="chart-empty">No se pudieron cargar los reportes</p>';
    }

    if (userRes.ok) {
      const userReports = await userRes.json().catch(() => []);
      renderModerationReports('reportes-usuario-list', userReports, 'user');
    } else {
      const el = document.getElementById('reportes-usuario-list');
      if (el) el.innerHTML = '<p class="chart-empty">No se pudieron cargar los reportes</p>';
    }
  }

  async function closeReport(kind, id) {
    const endpoint = kind === 'product'
      ? `/admin/reportes-producto/${id}/cerrar`
      : `/admin/reportes-usuario/${id}/cerrar`;

    const res = await fetch(API_BASE + endpoint, {
      method: 'PUT',
      headers: { Authorization: 'Bearer ' + token },
    });

    if (!res.ok) {
      throw new Error('No se pudo cerrar el reporte');
    }

    return await res.json().catch(() => null);
  }

  function renderStackedShare(containerId, rows) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const data = splitRows(rows, 4);
    const total = sumCounts(data);

    if (!data.length || total === 0) {
      el.innerHTML = '<p class="chart-empty">Sin datos</p>';
      return;
    }

    const colors = ["#2f7fb8", "#31b67a", "#ec8f2d", "#d84f6f"];
    const segments = data
      .map((row, i) => {
        const p = percent(row.count, total);
        return `<span style="width:${p}%;background:${colors[i % colors.length]}"></span>`;
      })
      .join("");

    const legend = data
      .map((row, i) => `
        <li>
          <span class="dot" style="background:${colors[i % colors.length]}"></span>
          <span>${formatLabel(row.label)}</span>
          <strong>${percent(row.count, total)}%</strong>
        </li>
      `)
      .join("");

    el.innerHTML = `
      <div class="stacked-bar">${segments}</div>
      <ul class="stacked-legend">${legend}</ul>
    `;
  }

  function renderDonut(containerId, rows) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const data = splitRows(rows, 5);
    const total = sumCounts(data);

    if (!data.length || total === 0) {
      el.innerHTML = '<p class="chart-empty">Sin datos</p>';
      return;
    }

    const colors = ["#286ea7", "#2f9d95", "#e49f37", "#d66a4a", "#37b5db"];
    let cursor = 0;
    const slices = data
      .map((row, i) => {
        const angle = (n(row.count) / total) * 360;
        const from = cursor;
        cursor += angle;
        return `${colors[i % colors.length]} ${from}deg ${cursor}deg`;
      })
      .join(", ");

    const legend = data
      .map((row, i) => `
        <li>
          <span class="dot" style="background:${colors[i % colors.length]}"></span>
          <span>${formatLabel(row.label)}</span>
          <strong>${percent(row.count, total)}%</strong>
        </li>
      `)
      .join("");

    el.innerHTML = `
      <div class="donut-wrap">
        <div class="donut" style="background:conic-gradient(${slices})">
          <div class="donut-hole">
            <small>Total</small>
            <strong>${formatNumber(total)}</strong>
          </div>
        </div>
      </div>
      <ul class="donut-legend">${legend}</ul>
    `;
  }

  function renderLineChart(containerId, rows, seriesLabel) {
    const el = document.getElementById(containerId);
    if (!el) return;

    const data = Array.isArray(rows) ? rows : [];
    const values = data.map((r) => n(r.count));
    const max = Math.max(1, ...values);

    if (!data.length) {
      el.innerHTML = '<p class="chart-empty">Sin datos</p>';
      return;
    }

    const width = 720;
    const height = 220;
    const stepX = data.length > 1 ? width / (data.length - 1) : width;

    const points = data
      .map((row, i) => {
        const y = height - (n(row.count) / max) * (height - 28) - 14;
        const x = i * stepX;
        return `${x},${y}`;
      })
      .join(" ");

    const areaPoints = `0,${height} ${points} ${width},${height}`;
    const last = data[data.length - 1];
    const avg = Math.round(values.reduce((acc, value) => acc + value, 0) / values.length);
    const peak = Math.max(...values);

    el.innerHTML = `
      <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" class="spark" aria-hidden="true">
        <polyline points="${areaPoints}" fill="rgba(27,116,184,0.2)" stroke="none"></polyline>
        <polyline points="${points}" fill="none" stroke="#1b74b8" stroke-width="3"></polyline>
      </svg>
      <ul class="line-foot-list">
        <li><span>Ultimo dia:</span><strong>${formatNumber(last.count)}</strong></li>
        <li><span>Media diaria:</span><strong>${formatNumber(avg)}</strong></li>
        <li><span>Pico periodo:</span><strong>${formatNumber(peak)}</strong></li>
        <li><span>Fecha final:</span><strong>${shortDateLabel(last.date)}</strong></li>
        <li><span>Serie:</span><strong>${seriesLabel}</strong></li>
      </ul>
    `;
  }

  async function ensureAdmin() {
    if (!token) {
      window.location.href = "/auth?mode=login&next=" + encodeURIComponent("/admin");
      return false;
    }

    const meRes = await fetch(API_BASE + "/me", { headers: { Authorization: "Bearer " + token } });
    if (!meRes.ok) {
      clearSession();
      window.location.href = "/auth?mode=login&next=" + encodeURIComponent("/admin");
      return false;
    }

    const me = await meRes.json().catch(() => null);
    if (!me?.esAdmin) {
      window.location.href = "/app";
      return false;
    }

    localStorage.setItem("ufvshares_admin", "1");
    return true;
  }

  async function loadDashboard() {
    try {
      const allowed = await ensureAdmin();
      if (!allowed) return;

      const res = await fetch(API_BASE + "/admin/metrics", {
        headers: { Authorization: "Bearer " + token },
      });

      if (res.status === 403) {
        window.location.href = "/app";
        return;
      }

      if (!res.ok) {
        showError("No se pudieron cargar las metricas del panel.");
        return;
      }

      const payload = await res.json();
      const overview = payload.overview || {};
      const charts = payload.charts || {};

      renderKpis(overview);
      renderHighlights(overview, charts);

      renderLineChart("chart-productos-dia", charts.productosPorDia || [], "Publicaciones");
      renderLineChart("chart-mensajes-dia", charts.mensajesPorDia || [], "Mensajes");
      renderBarChart("chart-solicitudes-estado", charts.solicitudesPorEstado || []);
      renderStackedShare("chart-solicitudes-ratio", charts.solicitudesPorEstado || []);
      renderBarChart("chart-productos-categoria", charts.productosPorCategoria || []);
      renderDonut("chart-categorias-donut", charts.productosPorCategoria || []);
      renderBarChart("chart-productos-tipo", charts.productosPorTipoTransaccion || []);
      renderRankList("chart-top-productos", charts.topProductosSolicitados || []);
      await loadModerationReports();
    } catch {
      showError("Error de conexion al cargar el panel de admin.");
    }
  }

  document.addEventListener('click', async (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    const button = target.closest('[data-report-close]');
    if (!button) return;

    const card = button.closest('[data-report-id]');
    const reportId = card?.getAttribute('data-report-id');
    const reportKind = card?.getAttribute('data-report-kind');
    if (!reportId || !reportKind) return;

    button.disabled = true;
    const oldText = button.textContent;
    button.textContent = 'Cerrando...';

    try {
      await closeReport(reportKind, reportId);
      await loadModerationReports();
    } catch (error) {
      showError(error instanceof Error ? error.message : 'No se pudo cerrar el reporte.');
    } finally {
      button.disabled = false;
      button.textContent = oldText || 'Marcar como cerrado';
    }
  });

  loadDashboard();
</script>

<style is:global>
  .admin-shell {
    max-width: 1260px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .admin-hero {
    background: linear-gradient(125deg, #0d3558 0%, #0f5a86 60%, #2f8bb8 100%);
    color: #f5fbff;
    border-radius: 1.1rem;
    padding: 1.5rem;
    margin-bottom: 1.1rem;
    box-shadow: 0 22px 40px rgba(8, 35, 60, 0.22);
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 1rem;
    align-items: start;
  }

  .admin-kicker {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.8;
    margin: 0 0 0.4rem;
  }

  .admin-hero h1 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.45rem);
    line-height: 1.05;
  }

  .admin-hero p {
    margin: 0.55rem 0 0;
    max-width: 58ch;
    opacity: 0.92;
  }

  .hero-highlights {
    list-style: none;
    margin: 0;
    padding: 0.9rem;
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.24);
    display: grid;
    gap: 0.55rem;
    font-size: 0.92rem;
  }

  .hero-highlights li {
    line-height: 1.25;
  }

  .hero-highlights strong {
    color: #ffffff;
  }

  .admin-error {
    margin: 0 0 1rem;
    padding: 0.85rem 1rem;
    border-radius: 0.75rem;
    background: #ffe6e6;
    color: #8a1f1f;
    border: 1px solid #efb3b3;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.9rem;
    margin-bottom: 1rem;
