  let pendingLoc: {lat: number, lng: number, addr: string} | null = null;
  let searchTimer: ReturnType<typeof setTimeout> | null = null;

  function setLocMap(container: HTMLElement | null, lat: number, lng: number) {
    if (!container) return;
    container.innerHTML =
      '<iframe src="https://www.openstreetmap.org/export/embed.html?bbox='
      + (lng-0.005) + ',' + (lat-0.003) + ',' + (lng+0.005) + ',' + (lat+0.003)
      + '&layer=mapnik&marker=' + lat + ',' + lng
      + '" class="w-full border-0" style="height:180px" loading="lazy"></iframe>';
  }

  function selectLoc(lat: number, lng: number, addr: string) {
    pendingLoc = { lat, lng, addr };
    if (locSend) locSend.disabled = false;
  }

  // Pestaña: ubicacion actual
  function loadCurrentLocation() {
    pendingLoc = null;
    if (locSend)    locSend.disabled = true;
    if (locStatus)  locStatus.textContent = 'Obteniendo tu ubicación...';
    if (locPreview) locPreview.innerHTML  = '';
    if (locAddrEl)  locAddrEl.textContent = '';
    locRetry?.classList.add('hidden');
    if (!navigator.geolocation) {
      if (locStatus) locStatus.textContent = 'Geolocalización no disponible en este navegador.';
      return;
    }
    navigator.geolocation.getCurrentPosition(
      async (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;
        if (locStatus) locStatus.textContent = 'Buscando dirección...';
        let addr = lat.toFixed(5) + ', ' + lng.toFixed(5);
        try {
          const r = await fetch(
            'https://nominatim.openstreetmap.org/reverse?format=json&lat=' + lat + '&lon=' + lng,
            { headers: { 'Accept-Language': 'es', 'User-Agent': 'UFVShares/1.0' } }
          );
          if (r.ok) { const d = await r.json(); addr = d.display_name ?? addr; }
        } catch {}
        if (locStatus)  locStatus.textContent = '';
        if (locAddrEl)  locAddrEl.textContent  = '📍 ' + addr;
        setLocMap(locPreview, lat, lng);
        selectLoc(lat, lng, addr);
      },
      () => {
        if (locStatus) locStatus.textContent = 'No se pudo obtener la ubicación. Comprueba los permisos.';
        locRetry?.classList.remove('hidden');
      },
      { timeout: 12000 }
    );
  }

  // Tabs
  function showTab(tab: 'current' | 'search') {
    pendingLoc = null;
    if (locSend) locSend.disabled = true;
    if (tab === 'current') {
      locTabCurrent?.classList.add('border-[#128C7E]', 'text-[#128C7E]');
      locTabCurrent?.classList.remove('border-transparent', 'text-base-content/50');
      locTabSearch?.classList.remove('border-[#128C7E]', 'text-[#128C7E]');
      locTabSearch?.classList.add('border-transparent', 'text-base-content/50');
      locPanelCurrent?.classList.remove('hidden');
      locPanelCurrent?.classList.add('flex');
      locPanelSearch?.classList.add('hidden');
      locPanelSearch?.classList.remove('flex');
      loadCurrentLocation();
    } else {
      locTabSearch?.classList.add('border-[#128C7E]', 'text-[#128C7E]');
      locTabSearch?.classList.remove('border-transparent', 'text-base-content/50');
      locTabCurrent?.classList.remove('border-[#128C7E]', 'text-[#128C7E]');
      locTabCurrent?.classList.add('border-transparent', 'text-base-content/50');
      locPanelSearch?.classList.remove('hidden');
      locPanelSearch?.classList.add('flex');
      locPanelCurrent?.classList.add('hidden');
      locPanelCurrent?.classList.remove('flex');
      if (locSearchRes) locSearchRes.innerHTML = '';
      if (locSearchPrev) locSearchPrev.innerHTML = '';
      if (locSearchAddr) locSearchAddr.textContent = '';
      setTimeout(() => locSearchInput?.focus(), 60);
    }
  }

  // Busqueda por texto
  async function doSearch(q: string) {
    if (!q.trim()) { if (locSearchRes) locSearchRes.innerHTML = ''; return; }
    if (locSearchRes) locSearchRes.innerHTML = '<p class="text-xs text-base-content/50 text-center py-2">Buscando...</p>';
    try {
      const r = await fetch(
        'https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(q) + '&limit=6&addressdetails=1',
        { headers: { 'Accept-Language': 'es', 'User-Agent': 'UFVShares/1.0' } }
      );
      const results: any[] = r.ok ? await r.json() : [];
      if (!locSearchRes) return;
      if (results.length === 0) {
        locSearchRes.innerHTML = '<p class="text-xs text-base-content/50 text-center py-2">Sin resultados</p>';
        return;
      }
      locSearchRes.innerHTML = '';
      results.forEach((item: any) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'flex items-start gap-2 text-left px-3 py-2 rounded-xl hover:bg-base-200 transition-colors w-full';
        const name = item.display_name as string;
        btn.innerHTML = '<span class="text-base shrink-0 mt-0.5">📍</span>'
          + '<span class="text-sm text-base-content leading-snug line-clamp-2">' + name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') + '</span>';
        btn.addEventListener('click', () => {
          const lat = parseFloat(item.lat);
          const lng = parseFloat(item.lon);
          if (locSearchAddr) locSearchAddr.textContent = '📍 ' + name;
          setLocMap(locSearchPrev, lat, lng);
          selectLoc(lat, lng, name);
          // Highlight seleccionado
          locSearchRes?.querySelectorAll('button').forEach(b => b.classList.remove('bg-base-200'));
          btn.classList.add('bg-base-200');
        });
        locSearchRes.appendChild(btn);
      });
    } catch {
      if (locSearchRes) locSearchRes.innerHTML = '<p class="text-xs text-base-content/50 text-center py-2">Error al buscar</p>';
    }
  }

  locSearchInput?.addEventListener('input', () => {
    if (searchTimer) clearTimeout(searchTimer);
    searchTimer = setTimeout(() => doSearch(locSearchInput.value), 400);
  });
  locSearchInput?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter') { e.preventDefault(); if (searchTimer) clearTimeout(searchTimer); doSearch(locSearchInput.value); }
  });

  locTabCurrent?.addEventListener('click', () => showTab('current'));
  locTabSearch?.addEventListener('click',  () => showTab('search'));
  locRetry?.addEventListener('click', loadCurrentLocation);

  function openLocModal() {
    locModal?.classList.remove('hidden');
    locModal?.classList.add('flex');
    showTab('current');
  }

  locBtn?.addEventListener('click', openLocModal);
  locCancel?.addEventListener('click', () => {
    locModal?.classList.add('hidden');
    locModal?.classList.remove('flex');
  });
  locSend?.addEventListener('click', async () => {
    if (!pendingLoc || activeConvId === null) return;
    locModal?.classList.add('hidden');
    locModal?.classList.remove('flex');
    const content = LOC_PREFIX + JSON.stringify(pendingLoc);
    const sent = await sendMessage(activeConvId, content);
    if (sent) {
      appendMessage(sent);
      if (sent.idMensaje > lastMsgId) lastMsgId = sent.idMensaje;
      const conv = conversations.find(c => c.idConversacion === activeConvId);
      if (conv) { conv.ultimoMensaje = '📍 Ubicacion'; conv.fechaUltimoMsg = sent.fechaEnvio; syncUnreadSnapshot(conversations); renderConvList(); }
    }
  });

  // ── Profile modal ──
  const profileModal      = document.getElementById('profile-modal');
  const pmAvatar          = document.getElementById('pm-avatar');
  const pmName            = document.getElementById('pm-name');
  const pmApellidos       = document.getElementById('pm-apellidos');
  const pmAnuncios        = document.getElementById('pm-anuncios');
  const pmPhoneRow        = document.getElementById('pm-phone-row');
  const pmPhone           = document.getElementById('pm-phone');
  const pmPhoneLink       = document.getElementById('pm-phone-link') as HTMLAnchorElement | null;
  const pmProductRow      = document.getElementById('pm-product-row');
  const pmProductCount    = document.getElementById('pm-product-count');
  const profileModalClose = document.getElementById('profile-modal-close');

  async function openProfileModal(userId: number, fotoUrl: string | null, iniciales: string) {
    // Mostrar con datos básicos inmediatamente
    if (pmAvatar) {
      pmAvatar.innerHTML = fotoUrl
        ? '<img src="' + BACKEND_BASE + fotoUrl + '" alt="" class="w-full h-full object-cover"/>'
        : iniciales;
    }
    if (pmName)        pmName.textContent      = '';
    if (pmApellidos)   pmApellidos.textContent  = '';
    if (pmAnuncios)    pmAnuncios.textContent   = '...';
    pmPhoneRow?.classList.add('hidden');
    pmProductRow?.classList.add('hidden');
    profileModal?.classList.remove('hidden');
    profileModal?.classList.add('flex');

    try {
      const res = await fetch(API_BASE + '/usuarios/' + userId + '/public');
      if (!res.ok) return;
      const data = await res.json();
      if (pmName)        pmName.textContent      = data.nombre ?? '';
      if (pmApellidos)   pmApellidos.textContent  = data.apellidos ?? '';
      if (pmAnuncios)    pmAnuncios.textContent   = String(data.numAnuncios ?? 0);
      if (data.telefono) {
        if (pmPhone)     pmPhone.textContent = data.telefono;
        if (pmPhoneLink) pmPhoneLink.href    = 'tel:' + data.telefono;
        pmPhoneRow?.classList.remove('hidden');
        pmPhoneRow?.classList.add('flex');
      }
      if (data.numAnuncios > 0) {
        if (pmProductCount) pmProductCount.textContent = data.numAnuncios + ' anuncio' + (data.numAnuncios !== 1 ? 's' : '');
        pmProductRow?.classList.remove('hidden');
        pmProductRow?.classList.add('flex');
      }
    } catch {}
  }

  profileModalClose?.addEventListener('click', () => {
    profileModal?.classList.add('hidden');
    profileModal?.classList.remove('flex');
  });
  profileModal?.addEventListener('click', (e) => {
    if (e.target === profileModal) {
      profileModal.classList.add('hidden');
      profileModal.classList.remove('flex');
    }
  });

  // Single one-time listeners — read current user from dataset set by openConversation
  function openProfileFromHeader() {
    const userId = parseInt(chatHeaderAvatar.dataset.userId ?? '0', 10);
    const fotoUrl = chatHeaderAvatar.dataset.fotoUrl || null;
    const iniciales = chatHeaderAvatar.dataset.iniciales ?? '';
    if (userId) openProfileModal(userId, fotoUrl, iniciales);
  }
  [chatHeaderAvatar, chatHeaderName, chatHeaderProduct].forEach(el => {
    el?.addEventListener('click', openProfileFromHeader);
  });
</script>