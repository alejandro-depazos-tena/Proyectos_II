---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Chats | UFV Shares">
  <div class="px-2 sm:px-4 py-2" style="height: calc(100vh - 110px); min-height: 560px;">
    <div id="chat-shell" class="flex h-full overflow-hidden rounded-2xl border border-base-200 shadow-lg">

      <!-- ══ SIDEBAR ══ -->
      <div id="chat-sidebar" class="flex flex-col w-full sm:w-[340px] lg:w-[380px] shrink-0 bg-base-100 border-r border-base-200">
        <!-- Cabecera -->
        <div id="chat-sidebar-header" class="flex items-center gap-3 px-4 py-3.5 bg-[#f0f2f5] border-b border-base-200 shrink-0">
          <button id="sidebar-toggle-btn" type="button" class="w-9 h-9 rounded-full bg-primary flex items-center justify-center shrink-0" title="Comprimir/expandir panel de chats" aria-label="Comprimir/expandir panel de chats" aria-expanded="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </button>
          <h2 class="flex-1 font-bold text-[1.05rem] text-base-content">Chats</h2>
          <button id="refresh-btn" class="btn btn-ghost btn-circle btn-sm text-base-content/50" title="Actualizar">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          </button>
        </div>
        <div id="chat-sidebar-tabs" class="px-3 py-2 bg-base-100 border-b border-base-200 shrink-0 flex items-center gap-2 overflow-x-auto scrollbar-none">
          <button type="button" data-view="all" class="chat-filter-tab chat-filter-tab-active">Todos</button>
          <button type="button" data-view="unread" class="chat-filter-tab">No leidos <span id="unread-count" class="opacity-70">(0)</span></button>
          <button type="button" data-view="blocked" class="chat-filter-tab">Bloqueados <span id="blocked-count" class="opacity-70">(0)</span></button>
        </div>
        <div id="archived-shortcut-wrap" class="px-3 pt-2 pb-1 bg-base-100 border-b border-base-200 shrink-0">
          <button id="archived-shortcut" type="button" class="w-full flex items-center gap-3 px-3 py-2 rounded-xl border border-base-200 hover:bg-base-200/60 transition-colors">
            <span class="w-8 h-8 rounded-full bg-base-200 flex items-center justify-center text-base-content/70">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="5" rx="1"></rect><path d="M4 8h16v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path><path d="M12 11v6"></path><path d="m9.5 14.5 2.5 2.5 2.5-2.5"></path></svg>
            </span>
            <span class="flex-1 text-left text-sm font-semibold text-base-content">Archivados</span>
            <span id="archived-count" class="archived-shortcut-count hidden">0</span>
          </button>
        </div>
        <!-- Buscador -->
        <div id="chat-search-wrap" class="px-3 py-2 bg-base-100 border-b border-base-200 shrink-0">
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-base-content/40 pointer-events-none"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input id="chat-search" type="text" placeholder="Buscar o empezar un chat" class="input input-sm w-full pl-9 bg-[#f0f2f5] border-none rounded-full text-sm focus:outline-none" />
          </div>
        </div>
        <!-- Lista -->
        <div id="conv-list" class="flex-1 overflow-y-auto">
          <div id="conv-skeleton">
            <div class="flex items-center gap-3 px-4 py-4 border-b border-base-200/50 animate-pulse"><div class="w-12 h-12 rounded-full bg-base-300 shrink-0"></div><div class="flex-1 space-y-2"><div class="h-3.5 bg-base-300 rounded w-2/3"></div><div class="h-2.5 bg-base-300 rounded w-1/2"></div></div></div>
            <div class="flex items-center gap-3 px-4 py-4 border-b border-base-200/50 animate-pulse"><div class="w-12 h-12 rounded-full bg-base-300 shrink-0"></div><div class="flex-1 space-y-2"><div class="h-3.5 bg-base-300 rounded w-3/4"></div><div class="h-2.5 bg-base-300 rounded w-1/3"></div></div></div>
            <div class="flex items-center gap-3 px-4 py-4 border-b border-base-200/50 animate-pulse"><div class="w-12 h-12 rounded-full bg-base-300 shrink-0"></div><div class="flex-1 space-y-2"><div class="h-3.5 bg-base-300 rounded w-1/2"></div><div class="h-2.5 bg-base-300 rounded w-2/5"></div></div></div>
          </div>
        </div>
        <div id="collapsed-conv-rail" class="hidden flex-1 overflow-y-auto py-2 px-2">
          <div id="collapsed-conv-list" class="flex flex-col items-center gap-2"></div>
        </div>
      </div>

      <!-- ══ AREA PRINCIPAL ══ -->
      <div id="chat-main" class="hidden sm:flex flex-1 flex-col min-w-0">
        <!-- Cabecera del chat -->
        <div id="chat-header" class="flex items-center gap-3 px-3 py-2.5 bg-[#f0f2f5] border-b border-base-200 shrink-0 z-10">
          <button id="back-btn" class="btn btn-ghost btn-circle btn-sm sm:hidden text-base-content/70 mr-0.5" aria-label="Volver">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <div id="chat-header-avatar" class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-sm font-black text-primary shrink-0 cursor-pointer">?</div>
          <div class="flex-1 min-w-0 cursor-pointer">
            <p id="chat-header-name" class="font-semibold text-[15px] text-base-content leading-snug truncate">Selecciona una conversacion</p>
            <p id="chat-header-product" class="text-xs text-base-content/50 truncate leading-snug mt-px"></p>
          </div>
          <div class="flex items-center gap-0.5 shrink-0 relative">
            <button id="chat-in-search-btn" class="btn btn-ghost btn-circle btn-sm text-base-content/50" title="Buscar en el chat" aria-label="Buscar en el chat">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </button>
            <button id="chat-more-btn" class="btn btn-ghost btn-circle btn-sm text-base-content/50" title="Mas opciones" aria-label="Mas opciones" aria-expanded="false" aria-controls="chat-more-menu">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
            </button>
            <div id="chat-more-menu" class="hidden absolute right-0 top-11 w-56 rounded-xl border border-base-200 bg-base-100 shadow-xl p-1.5 z-20">
              <button id="chat-archive-btn" class="w-full text-left px-3 py-2 rounded-lg hover:bg-base-200 text-sm text-base-content transition-colors flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect x="3" y="3" width="18" height="5" rx="1"></rect><path d="M4 8h16v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path><path d="M12 11v6"></path><path d="m9.5 14.5 2.5 2.5 2.5-2.5"></path></svg>
                <span>Archivar chat</span>
              </button>
              <button id="chat-report-btn" class="w-full text-left px-3 py-2 rounded-lg hover:bg-base-200 text-sm text-base-content transition-colors flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                <span>Reportar usuario</span>
              </button>
              <button id="chat-block-btn" class="w-full text-left px-3 py-2 rounded-lg hover:bg-base-200 text-sm text-red-600 transition-colors flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                <span>Bloquear usuario</span>
              </button>
            </div>
          </div>
        </div>
        <div id="chat-inline-search" class="hidden px-3 py-2 bg-base-100 border-b border-base-200 items-center gap-2">
          <div class="relative flex-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/40 pointer-events-none"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            <input id="chat-inline-search-input" type="text" placeholder="Buscar palabras en esta conversacion" class="input input-sm w-full pl-9 rounded-full" />
          </div>
          <span id="chat-inline-search-count" class="text-xs text-base-content/60 min-w-[64px] text-center">0/0</span>
          <button id="chat-inline-search-prev" type="button" class="btn btn-ghost btn-circle btn-sm" aria-label="Resultado anterior" title="Resultado anterior">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button id="chat-inline-search-next" type="button" class="btn btn-ghost btn-circle btn-sm" aria-label="Siguiente resultado" title="Siguiente resultado">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
          <button id="chat-inline-search-close" type="button" class="btn btn-ghost btn-sm" aria-label="Cerrar busqueda">Cerrar</button>
        </div>
        <!-- Mensajes (fondo beige WhatsApp) -->
        <div id="chat-messages" class="flex-1 overflow-y-auto flex flex-col px-[4%] md:px-[8%] lg:px-[14%] py-4 gap-px chat-bg">
          <div id="chat-empty-state" class="flex flex-col items-center justify-center h-full gap-4 py-20 text-center flex-1">
            <div class="w-20 h-20 rounded-full bg-white/80 shadow-sm flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            </div>
            <div>
              <p class="font-bold text-[#3b4a54] text-lg">UFV Shares</p>
              <p class="text-sm text-[#4b5563] mt-1 max-w-xs">Selecciona una conversacion de la lista o contacta con el vendedor de un producto.</p>
            </div>
          </div>
        </div>
        <!-- Input -->
        <div id="chat-input-area" class="hidden shrink-0 bg-[#f0f2f5] border-t border-base-200 px-3 py-2.5 relative">
          <!-- Picker de emojis -->
          <div id="emoji-picker" class="hidden absolute bottom-16 left-3 z-50 bg-base-100 border border-base-200 rounded-2xl shadow-xl p-3 w-72">
            <div id="emoji-grid" class="grid grid-cols-8 gap-1 max-h-52 overflow-y-auto"></div>
          </div>
          <form id="chat-form" class="flex items-end gap-2">
            <button type="button" id="emoji-btn" class="btn btn-ghost btn-circle btn-sm text-base-content/50 shrink-0 mb-1" aria-label="Emojis">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
            </button>
            <button type="button" id="loc-btn" class="btn btn-ghost btn-circle btn-sm text-base-content/50 shrink-0 mb-1" aria-label="Enviar ubicación">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </button>
            <div class="flex-1 bg-white rounded-3xl px-4 py-2.5 shadow-sm flex items-end min-h-[44px]">
              <textarea id="msg-input" rows="1" placeholder="Escribe un mensaje" aria-label="Escribe un mensaje" class="w-full resize-none bg-transparent text-sm leading-relaxed max-h-32 focus:outline-none text-base-content placeholder:text-base-content/40"></textarea>
            </div>
            <button type="submit" id="send-btn" class="btn btn-primary btn-circle w-11 h-11 min-h-0 shrink-0 shadow-sm mb-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </div>
      </div>

      <!-- ══ SIN CONVERSACIONES ══ -->
      <div id="no-convs-state" class="hidden flex-1 flex-col items-center justify-center gap-5 text-center px-8 chat-bg">
        <div class="w-24 h-24 rounded-full bg-white shadow flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#25d366" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </div>
        <div>
          <p class="font-bold text-xl text-[#3b4a54]">Sin mensajes todavia</p>
          <p class="text-sm text-[#4b5563] mt-1.5 max-w-xs leading-relaxed">Cuando contactes con un vendedor desde la pagina de un producto, la conversacion aparecera aqui.</p>
        </div>
        <a href="/app" class="btn btn-primary btn-sm rounded-full gap-2 mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          Explorar productos
        </a>
      </div>

    </div>
  </div>

  <div id="chat-toast-root" class="chat-toast-root" aria-live="polite" aria-atomic="true"></div>

  <div id="report-modal" class="hidden fixed inset-0 z-[130] bg-black/45 items-center justify-center p-4">
    <div class="bg-base-100 rounded-2xl shadow-2xl w-full max-w-md border border-base-200">
      <div class="px-5 py-4 border-b border-base-200 flex items-center justify-between gap-3">
        <h3 class="font-semibold text-base">Reportar usuario</h3>
        <button id="report-close-btn" class="btn btn-ghost btn-circle btn-sm" aria-label="Cerrar">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
      <form id="report-form" class="px-5 py-4 flex flex-col gap-3">
        <p id="report-target-label" class="text-sm text-base-content/70"></p>
        <label class="text-xs font-semibold text-base-content/70" for="report-reason">Motivo</label>
        <select id="report-reason" class="select select-bordered w-full" required>
          <option value="Spam">Spam</option>
          <option value="Acoso">Acoso</option>
          <option value="Fraude">Fraude</option>
          <option value="Contenido inapropiado">Contenido inapropiado</option>
          <option value="Otro">Otro</option>
        </select>
        <label class="text-xs font-semibold text-base-content/70" for="report-comment">Comentario (opcional)</label>
        <textarea id="report-comment" rows="4" class="textarea textarea-bordered w-full" placeholder="Describe brevemente el problema"></textarea>
        <div class="flex justify-end gap-2 mt-1">
          <button id="report-cancel-btn" type="button" class="btn btn-ghost">Cancelar</button>
          <button id="report-submit-btn" type="submit" class="btn btn-error text-white">Enviar reporte</button>
        </div>
      </form>
    </div>
  </div>

  <div id="block-confirm-modal" class="hidden fixed inset-0 z-[131] bg-black/45 items-center justify-center p-4">
    <div class="bg-base-100 rounded-2xl shadow-2xl w-full max-w-sm border border-base-200">
      <div class="px-5 py-4 border-b border-base-200">
        <h3 class="font-semibold text-base">Confirmar accion</h3>
      </div>
      <div class="px-5 py-4">
        <p id="block-confirm-text" class="text-sm text-base-content/80 leading-relaxed"></p>
      </div>
      <div class="px-5 pb-4 flex justify-end gap-2">
        <button id="block-confirm-cancel" type="button" class="btn btn-ghost">Cancelar</button>
        <button id="block-confirm-accept" type="button" class="btn btn-error text-white">Bloquear</button>
      </div>
    </div>
  </div>

<!-- Modal perfil usuario -->
<div id="profile-modal" class="hidden fixed inset-0 z-[100] bg-black/50 items-center justify-center p-4">
  <div class="bg-base-100 rounded-2xl shadow-2xl w-full max-w-sm flex flex-col overflow-hidden">
    <!-- Banner + avatar -->
    <div class="relative">
      <div class="h-24 bg-gradient-to-r from-[#128C7E] to-[#25d366]"></div>
      <div id="pm-avatar" class="absolute left-1/2 -translate-x-1/2 -bottom-8 w-16 h-16 rounded-full border-4 border-base-100 bg-primary/20 flex items-center justify-center text-xl font-black text-primary shrink-0 overflow-hidden shadow"></div>
    </div>
    <!-- Contenido -->
    <div class="pt-12 pb-5 px-5 flex flex-col gap-4">
      <div class="text-center">
        <p id="pm-name" class="font-bold text-lg text-base-content"></p>
        <p id="pm-apellidos" class="text-sm text-base-content/60"></p>
      </div>
      <div class="flex justify-center gap-8 py-3 bg-base-200/50 rounded-xl">
        <div class="text-center">
          <p id="pm-anuncios" class="font-bold text-xl text-[#128C7E]">-</p>
          <p class="text-[11px] text-base-content/50 mt-0.5">Anuncios</p>
        </div>
      </div>
      <div class="flex flex-col gap-2.5">
        <div id="pm-phone-row" class="hidden flex items-center gap-3 bg-base-200/50 rounded-xl px-4 py-3">
          <div class="w-9 h-9 rounded-full bg-[#128C7E]/10 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#128C7E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-[11px] text-base-content/50 leading-none mb-1">Teléfono</p>
            <p id="pm-phone" class="text-sm font-semibold text-base-content"></p>
          </div>
          <a id="pm-phone-link" href="#" class="btn btn-ghost btn-circle btn-sm text-[#128C7E]" title="Llamar">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </a>
        </div>
        <div id="pm-product-row" class="hidden items-center gap-3 bg-base-200/50 rounded-xl px-4 py-3">
          <div class="w-9 h-9 rounded-full bg-[#128C7E]/10 flex items-center justify-center shrink-0">
