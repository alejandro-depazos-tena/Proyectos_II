---
import '../styles/site.css';

const featured = [
	{ title: 'Libro de Álgebra Lineal', price: '12,00', type: 'Venta', tag: 'Libros', img: '/foto.webp' },
	{ title: 'Calculadora científica', price: '5,00', type: 'Alquiler', tag: 'Material', img: '/campus.webp' },
	{ title: 'Apuntes de Microeconomía', price: '3,50', type: 'Venta', tag: 'Apuntes', img: '/foto.webp' },
	{ title: 'Trípode para móvil', price: '6,00', type: 'Alquiler', tag: 'Tech', img: '/campus.webp' },
	{ title: 'Diccionario Inglés (C1)', price: '8,00', type: 'Venta', tag: 'Idiomas', img: '/foto.webp' },
	{ title: 'Bata de laboratorio', price: '4,00', type: 'Alquiler', tag: 'Material', img: '/campus.webp' }
];

const categories = ['Libros', 'Apuntes', 'Material', 'Tech', 'Idiomas', 'Deporte'];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>UFV Shares</title>
	</head>
	<body>
		<div class="container">
			<header class="header">
				<div class="brand">
					<img class="logo" src="/Logo.png" onerror="this.onerror=null;this.src='/ufv-badge.svg'" alt="UFV" width="42" height="42" />
					<div>
						<h1>UFV Shares</h1>
						<p class="subtitle">Marketplace universitario entre estudiantes.</p>
					</div>
				</div>
				<nav class="row">
					<a class="button" href="/login">Iniciar sesión</a>
					<a class="button button--primary" href="/auth?mode=register">Registrarse</a>
				</nav>
			</header>

			<main class="stack">
				<section class="carousel full-bleed" aria-label="Carrusel">
					<div class="carousel-track" id="landing-carousel" tabindex="0">
						<article class="carousel-slide" aria-label="Campus UFV">
							<img class="carousel-img" src="/campus.webp" alt="Campus UFV" loading="lazy" />
							<div class="carousel-caption">
								<h2>Bienvenido a UFV Shares</h2>
								<p>Compra, vende y alquila entre estudiantes.</p>
							</div>
						</article>
						<article class="carousel-slide" aria-label="Marketplace">
							<img class="carousel-img" src="/foto.webp" alt="Marketplace UFV Shares" loading="lazy" />
							<div class="carousel-caption">
								<h2>Destacados y categorías</h2>
								<p>Explora rápido y entra a la app.</p>
							</div>
						</article>
						<article class="carousel-slide" aria-label="Publica">
							<img class="carousel-img" src="/campus.webp" alt="Publica en un minuto" loading="lazy" />
							<div class="carousel-caption">
								<h2>Publica en 1 minuto</h2>
								<p>Entra y crea tu anuncio (MVP).</p>
							</div>
						</article>
					</div>
					<div class="carousel-controls" aria-label="Controles del carrusel">
						<button class="button" type="button" id="carouselPrev" aria-controls="landing-carousel">Anterior</button>
						<button class="button button--primary" type="button" id="carouselNext" aria-controls="landing-carousel">Siguiente</button>
					</div>
				</section>

				<section class="hero">
					<div class="hero-grid hero-grid--market">
						<div>
							<h2>Compra, vende y alquila entre estudiantes</h2>
							<p>Busca rápido y entra a la app para ver anuncios y publicar.</p>

							<div class="searchbar" role="search" aria-label="Buscar">
								<input id="q" type="search" placeholder="Buscar (libros, apuntes, material…)" autocomplete="off" />
								<button class="button button--primary" id="searchGo" type="button" data-go="/app">Buscar</button>
							</div>

							<div class="categories" aria-label="Categorías">
								{categories.map((c) => (
									<button class="chip chip--click" type="button" data-go="/app">{c}</button>
								))}
							</div>

							<div class="row" style="margin-top: 12px;">
								<button class="button" data-go="/app">Explorar</button>
								<button class="button" data-go="/app#publicar">Publicar</button>
								<a class="button" href="/auth?mode=register&next=%2Fapp">Crear cuenta</a>
							</div>
						</div>

						<div class="photo photo--market" aria-label="Imagen de cabecera">
							<img class="photo-img" src="/campus.webp" alt="Campus UFV" loading="lazy" />
						</div>
					</div>
				</section>

				<section class="section">
					<div class="section-head">
						<div>
							<h3 class="section-title">Destacados</h3>
							<p class="section-desc">Ejemplos para que se vea como un marketplace.</p>
						</div>
						<button class="button" data-go="/app">Ver todos</button>
					</div>

					<div class="product-grid" style="margin-top: 12px;">
						{featured.map((p) => (
							<article class="tile" aria-label={p.title}>
								<div class="tile-media" aria-hidden="true" style={`background-image: url('${p.img}')`}></div>
								<div class="tile-body">
									<div class="tile-top">
										<h2 class="tile-title">{p.title}</h2>
										<div class="tile-price">€{p.price}</div>
									</div>
									<div class="row">
										<span class="chip">{p.type}</span>
										<span class="chip">{p.tag}</span>
									</div>
									<button class="button" data-go="/app">Ver</button>
								</div>
							</article>
						))}
					</div>
				</section>

				<section class="hero hero--dark">
					<h2>Entra y publica en 1 minuto</h2>
					<p>La app (MVP) es donde están los anuncios y el formulario de publicación.</p>
					<div class="row" style="margin-top: 12px;">
						<a class="button button--primary" href="/auth?mode=register&next=%2Fapp">Crear cuenta</a>
						<a class="button" href="/login?next=%2Fapp">Ya tengo cuenta</a>
						<button class="button" data-go="/app">Entrar</button>
					</div>
				</section>

				<footer class="footer" aria-label="Footer">
					<div class="footer-grid">
						<div>
							<div class="brand">
								<img class="logo" src="/Logo.png" onerror="this.onerror=null;this.src='/ufv-badge.svg'" alt="UFV" width="42" height="42" />
								<div>
									<h3>UFV Shares</h3>
									<div class="muted small">Marketplace universitario (demo)</div>
								</div>
							</div>
							<p class="muted small" style="margin-top: 10px;">
								Proyecto de ejemplo. Enlaces y contenidos son demostrativos.
							</p>
						</div>

						<div>
							<h3>Enlaces</h3>
							<ul>
								<li><a href="/app">Entrar a la app</a></li>
								<li><a href="/login">Iniciar sesión</a></li>
								<li><a href="/auth?mode=register">Crear cuenta</a></li>
								<li><a href="#">Soporte (demo)</a></li>
							</ul>
						</div>
					</div>

					<div class="footer-bottom">
						<span>© {new Date().getFullYear()} UFV Shares (demo)</span>
						<span class="row"><a href="#">Privacidad</a><a href="#">Términos</a><a href="#">Cookies</a></span>
					</div>
				</footer>
			</main>
		</div>

		<script type="module">
			const token = localStorage.getItem('ufvshares_token');
			const track = document.getElementById('landing-carousel');
			const prev = document.getElementById('carouselPrev');
			const next = document.getElementById('carouselNext');

			function scrollBySlide(dir) {
				if (!track) return;
				const slide = track.querySelector('.carousel-slide');
				if (!slide) return;
				const slideWidth = slide.getBoundingClientRect().width;
				track.scrollBy({ left: dir * slideWidth, behavior: 'smooth' });
			}

			prev?.addEventListener('click', () => scrollBySlide(-1));
			next?.addEventListener('click', () => scrollBySlide(1));
			track?.addEventListener('keydown', (e) => {
				if (e.key === 'ArrowLeft') { e.preventDefault(); scrollBySlide(-1); }
				if (e.key === 'ArrowRight') { e.preventDefault(); scrollBySlide(1); }
			});

			for (const btn of document.querySelectorAll('button[data-go]')) {
				btn.addEventListener('click', () => {
					const target = btn.getAttribute('data-go') || '/app';
					if (!token) {
						window.location.href = `/login?next=${encodeURIComponent(target)}`;
						return;
					}
					window.location.href = target;
				});
			}
		</script>
	</body>
</html>