---
import "../styles/global.css";
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>UFV Shares · Marketplace universitario</title>
    <meta name="description" content="Compra, vende y alquila entre estudiantes de la UFV. El marketplace universitario más cercano." />
    <style>
      @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
      @keyframes floatB { 0%,100%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-8px) rotate(3deg)} }
      @keyframes fadeUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
      @keyframes countUp { from{opacity:0;transform:scale(.7)} to{opacity:1;transform:scale(1)} }
      .anim-float  { animation: float  4s ease-in-out infinite; }
      .anim-floatB { animation: floatB 5s ease-in-out infinite; }
      .anim-fade   { animation: fadeUp .7s ease both; }
      .anim-fade-d1{ animation: fadeUp .7s .15s ease both; }
      .anim-fade-d2{ animation: fadeUp .7s .30s ease both; }
      .anim-fade-d3{ animation: fadeUp .7s .45s ease both; }
      .anim-count  { animation: countUp .6s .8s ease both; }
      .card-hover  { transition: transform .25s ease, box-shadow .25s ease; }
      .card-hover:hover { transform: translateY(-6px); box-shadow: 0 20px 40px -12px rgba(0,0,0,.18); }
      .bento       { display:grid; grid-template-columns:1fr 1fr; gap:1rem; }
      @media(min-width:768px){ .bento{ grid-template-columns:repeat(4,1fr); } }
      .bento-span2 { grid-column: span 2; }
    </style>
  </head>
  <body class="bg-base-100 min-h-screen font-sans overflow-x-hidden">

    <!-- ── NAVBAR ───────────────────────────────────────────────── -->
    <header class="navbar fixed top-0 z-50 bg-base-100/80 backdrop-blur-md shadow-sm px-4 sm:px-8">
      <div class="navbar-start">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center group-hover:rotate-12 transition-transform shadow">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-content" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
          <span class="text-xl font-extrabold tracking-tight text-primary">UFV<span class="text-base-content"> Shares</span></span>
        </a>
      </div>
      <div class="navbar-end gap-2">
        <a href="/auth?mode=login&next=%2Fapp&src=nav" class="btn btn-ghost btn-sm hidden sm:flex">Iniciar sesión</a>
        <a href="/auth?mode=register&next=%2Fapp&src=nav" class="btn btn-primary btn-sm rounded-full px-5 shadow">Registrarse</a>
      </div>
    </header>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- HERO — split layout                                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <section class="relative min-h-screen flex items-center pt-16 bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#312e81] overflow-hidden">

      <!-- decorative blobs -->
      <div class="absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full bg-primary/20 blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full bg-yellow-400/10 blur-3xl pointer-events-none"></div>
      <div class="absolute top-1/3 left-1/2 w-60 h-60 rounded-full bg-indigo-500/15 blur-2xl pointer-events-none"></div>

      <div class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-2 gap-16 items-center py-20">

        <!-- LEFT: text -->
        <div>
          <span class="inline-flex items-center gap-2 bg-yellow-400/20 text-yellow-300 text-xs font-bold uppercase tracking-widest px-4 py-2 rounded-full border border-yellow-400/30 mb-8 anim-fade">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2z"/></svg>
            Solo para estudiantes UFV
          </span>

          <h1 class="text-5xl sm:text-6xl xl:text-7xl font-black leading-[1.05] text-white mb-6 anim-fade-d1">
            Tu campus.<br/>
            Tu <span class="text-transparent bg-clip-text bg-gradient-to-r from-yellow-300 to-orange-400">mercado</span>.
          </h1>

          <p class="text-lg sm:text-xl text-white/60 mb-10 max-w-lg leading-relaxed anim-fade-d2">
            Compra, vende y alquila con tus compañeros sin salir del campus. Sin comisiones, sin intermediarios.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 anim-fade-d3">
            <a href="/auth?mode=register&next=%2Fapp&src=hero-primary"
              class="btn btn-warning btn-lg rounded-full px-10 font-bold shadow-2xl hover:scale-105 transition-transform text-lg gap-2">
              Empezar gratis
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
            <a href="/auth?mode=login&next=%2Fapp&src=hero-secondary"
              class="btn btn-ghost btn-lg rounded-full px-10 text-white border-white/25 hover:bg-white/10 hover:border-white text-lg">
              Ya tengo cuenta
            </a>
          </div>

          <!-- stats row -->
          <div class="flex gap-8 mt-14 anim-count">
            <div>
              <div class="text-3xl font-black text-yellow-300">+200</div>
              <div class="text-xs text-white/50 uppercase tracking-wider mt-0.5">Estudiantes</div>
            </div>
            <div class="w-px bg-white/15 self-stretch"></div>
            <div>
              <div class="text-3xl font-black text-yellow-300">+500</div>
              <div class="text-xs text-white/50 uppercase tracking-wider mt-0.5">Productos</div>
            </div>
            <div class="w-px bg-white/15 self-stretch"></div>
            <div>
              <div class="text-3xl font-black text-yellow-300">0€</div>
              <div class="text-xs text-white/50 uppercase tracking-wider mt-0.5">Comisión</div>
            </div>
          </div>
        </div>

        <!-- RIGHT: product card mockup -->
        <div class="relative flex justify-center items-center anim-float hidden lg:flex">
          <!-- main card -->
          <div class="relative w-72 bg-white/10 backdrop-blur-xl rounded-3xl border border-white/20 p-5 shadow-2xl">
            <!-- card header -->
            <div class="w-full h-44 rounded-2xl bg-gradient-to-br from-primary/60 to-indigo-600/60 flex items-center justify-center mb-4 overflow-hidden">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-20 h-20 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17a2 2 0 01-2-2V6a1 1 0 011-1h14a1 1 0 011 1v9a2 2 0 01-2 2H5z" />
              </svg>
            </div>
            <div class="space-y-2">
              <div class="flex justify-between items-start">
                <div>
                  <div class="text-white font-bold text-sm">MacBook Air M2</div>
                  <div class="text-white/50 text-xs mt-0.5">Electrónica · 2ª mano</div>
                </div>
                <div class="text-yellow-300 font-black text-lg">850€</div>
              </div>
              <div class="flex items-center gap-1 pt-1">
                <div class="w-6 h-6 rounded-full bg-gradient-to-br from-primary to-indigo-500 flex items-center justify-center text-white text-xs font-bold">A</div>
                <span class="text-white/50 text-xs">Ana García · UFV Madrid</span>
              </div>
              <button class="w-full mt-1 py-2 rounded-xl bg-yellow-400 text-yellow-900 text-xs font-bold hover:bg-yellow-300 transition-colors">Contactar</button>
            </div>
          </div>

          <!-- floating mini cards -->
          <div class="absolute -top-8 -right-10 w-44 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 p-3 shadow-xl anim-floatB">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-success/30 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v13M12 7c-1.8-1.2-4.2-1.7-7-1.7v11c2.8 0 5.2.5 7 1.7M12 7c1.8-1.2 4.2-1.7 7-1.7v11c-2.8 0-5.2.5-7 1.7"/></svg>
              </div>
              <div>
                <div class="text-white text-xs font-semibold">Libro de Cálculo</div>
                <div class="text-yellow-300 text-xs font-bold">12€</div>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-8 -left-12 w-48 bg-white/10 backdrop-blur-md rounded-2xl border border-white/20 p-3 shadow-xl" style="animation: floatB 6s 1s ease-in-out infinite;">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-warning/30 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
              </div>
              <div>
                <div class="text-white text-xs font-semibold">Calculadora Casio</div>
                <div class="text-white/50 text-xs">Alquiler · 3€/sem</div>
              </div>
            </div>
          </div>

          <!-- notification dot -->
          <div class="absolute top-12 right-6 flex items-center gap-2 bg-success/20 backdrop-blur-sm rounded-full px-3 py-1.5 border border-success/30">
            <div class="w-2 h-2 rounded-full bg-success animate-pulse"></div>
            <span class="text-success text-xs font-bold uppercase tracking-wide">3 nuevos hoy</span>
          </div>
        </div>

      </div>

      <!-- wave divider -->
      <div class="absolute bottom-0 left-0 right-0">
        <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <path d="M0 80L48 69.3C96 58.7 192 37.3 288 32C384 26.7 480 37.3 576 48C672 58.7 768 69.3 864 69.3C960 69.3 1056 58.7 1152 48C1248 37.3 1344 26.7 1392 21.3L1440 16V80H0Z" fill="oklch(var(--b1))"/>
        </svg>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- BENTO FEATURES                                             -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <section class="py-24 bg-base-100">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-14">
          <h2 class="text-4xl sm:text-5xl font-black">Todo lo que necesitas,<br/><span class="text-primary">en un solo lugar</span></h2>
          <p class="text-base-content/50 mt-4 text-lg">Sin apps de terceros. Solo tú y tus compañeros.</p>
        </div>

        <div class="bento">
          <!-- COMPRA — span2 -->
          <div class="bento-span2 rounded-3xl bg-gradient-to-br from-primary/10 to-primary/5 border border-primary/20 p-8 relative overflow-hidden card-hover">
            <div class="absolute -bottom-8 -right-8 w-40 h-40 rounded-full bg-primary/10 blur-2xl pointer-events-none"></div>
            <div class="w-14 h-14 rounded-2xl bg-primary/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            </div>
            <h3 class="text-2xl font-black mb-2 text-base-content">Compra</h3>
            <p class="text-base-content/60 leading-relaxed mb-6 max-w-sm">Apuntes, calculadoras, libros de texto… Encuentra lo que necesitas para el semestre publicado por estudiantes de tu misma facultad.</p>
            <a href="/auth?mode=register&next=%2Fapp&src=features-compra" class="btn btn-primary btn-sm rounded-full px-6 gap-2">
              Explorar
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>

          <!-- VENDE -->
          <div class="rounded-3xl bg-gradient-to-br from-[#0f172a] to-[#1e1b4b] border border-white/10 p-8 relative overflow-hidden card-hover">
            <div class="absolute -top-6 -right-6 w-28 h-28 rounded-full bg-yellow-400/10 blur-2xl pointer-events-none"></div>
            <div class="w-14 h-14 rounded-2xl bg-yellow-400/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 class="text-2xl font-black mb-2 text-white">Vende</h3>
            <p class="text-white/50 leading-relaxed text-sm">Publica en minutos y llega a cientos de compañeros. Sin comisiones.</p>
          </div>

          <!-- ALQUILA -->
          <div class="rounded-3xl bg-gradient-to-br from-success/10 to-success/5 border border-success/20 p-8 relative overflow-hidden card-hover">
            <div class="w-14 h-14 rounded-2xl bg-success/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
            </div>
            <h3 class="text-2xl font-black mb-2">Alquila</h3>
            <p class="text-base-content/60 leading-relaxed text-sm">¿Solo lo necesitas un semestre? Alquila sin compromiso.</p>
          </div>

          <!-- SEGURO — span2 bottom-left -->
          <div class="rounded-3xl bg-gradient-to-br from-warning/10 to-orange-400/5 border border-warning/20 p-8 card-hover">
            <div class="w-14 h-14 rounded-2xl bg-warning/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <h3 class="text-2xl font-black mb-2">Solo UFV</h3>
            <p class="text-base-content/60 leading-relaxed text-sm">Acceso exclusivo con correo universitario. Comunidad de confianza.</p>
          </div>

          <!-- INSTANTANEO — span2 bottom-right -->
          <div class="bento-span2 rounded-3xl bg-gradient-to-br from-error/10 to-pink-500/5 border border-error/20 p-8 relative overflow-hidden card-hover">
            <div class="absolute right-8 top-1/2 -translate-y-1/2 hidden md:block">
              <!-- mini timeline illustration -->
              <div class="flex flex-col gap-3 opacity-70">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white text-xs font-black">1</div>
                  <div class="h-2 w-24 rounded-full bg-base-300"></div>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-warning flex items-center justify-center text-xs font-black">2</div>
                  <div class="h-2 w-16 rounded-full bg-base-300"></div>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-success flex items-center justify-center text-white text-xs font-black">3</div>
                  <div class="h-2 w-20 rounded-full bg-base-300"></div>
                </div>
              </div>
            </div>
            <div class="w-14 h-14 rounded-2xl bg-error/20 flex items-center justify-center mb-5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-error" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="text-2xl font-black mb-2">Publicar en 1 minuto</h3>
            <p class="text-base-content/60 leading-relaxed max-w-xs">Sube foto, escribe descripción y pon precio. Tu anuncio llega al instante a toda la comunidad.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- CÓMO FUNCIONA — timeline horizontal                        -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <section class="py-24 bg-gradient-to-b from-base-200 to-base-100">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <span class="badge badge-primary badge-lg font-bold uppercase tracking-widest mb-4">Proceso</span>
          <h2 class="text-4xl sm:text-5xl font-black">En tres pasos, listo</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 relative">
          <!-- connector line (desktop) -->
          <div class="hidden md:block absolute top-11 left-[calc(16.6%+2rem)] right-[calc(16.6%+2rem)] h-0.5 bg-gradient-to-r from-primary via-warning to-success z-0"></div>

          <!-- Step 1 -->
          <div class="relative z-10 flex flex-col items-center text-center gap-4">
            <div class="w-24 h-24 rounded-full bg-primary text-primary-content flex items-center justify-center shadow-2xl ring-[6px] ring-primary/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            </div>
            <div class="bg-base-100 rounded-2xl border border-base-200 p-5 shadow-sm w-full">
              <div class="badge badge-primary badge-sm mb-2">Paso 1</div>
              <h3 class="text-xl font-black mb-2">Crea tu cuenta</h3>
              <p class="text-base-content/60 text-sm leading-relaxed">Regístrate con tu correo universitario. Sin formularios interminables, en segundos.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="relative z-10 flex flex-col items-center text-center gap-4">
            <div class="w-24 h-24 rounded-full bg-warning text-warning-content flex items-center justify-center shadow-2xl ring-[6px] ring-warning/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            </div>
            <div class="bg-base-100 rounded-2xl border border-base-200 p-5 shadow-sm w-full">
              <div class="badge badge-warning badge-sm mb-2">Paso 2</div>
              <h3 class="text-xl font-black mb-2">Explora o publica</h3>
              <p class="text-base-content/60 text-sm leading-relaxed">Navega el catálogo de tus compañeros o crea tu propio anuncio con foto y precio.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="relative z-10 flex flex-col items-center text-center gap-4">
            <div class="w-24 h-24 rounded-full bg-success text-success-content flex items-center justify-center shadow-2xl ring-[6px] ring-success/20">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>
            </div>
            <div class="bg-base-100 rounded-2xl border border-base-200 p-5 shadow-sm w-full">
              <div class="badge badge-success badge-sm mb-2">Paso 3</div>
              <h3 class="text-xl font-black mb-2">Contacta y cierra</h3>
              <p class="text-base-content/60 text-sm leading-relaxed">Queda en el campus y realiza la transacción directa, sin intermediarios ni comisiones.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- CATEGORÍAS — gradient pills scroll                         -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <section class="py-24 bg-base-100">
      <div class="max-w-6xl mx-auto px-6">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
          <div>
            <h2 class="text-4xl font-black">Explora por categoría</h2>
            <p class="text-base-content/50 mt-2">Todo lo que necesitas para el semestre.</p>
          </div>
          <a href="/auth?mode=register&next=%2Fapp%3Fview%3Dcategorias" class="btn btn-outline btn-primary rounded-full gap-2 self-start md:self-auto">
            Ver todo
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          <!-- Libros -->
