---
import "../styles/global.css";
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>UFV Shares · Marketplace universitario</title>
    <meta name="description" content="Compra, vende y alquila entre estudiantes de la UFV. El marketplace universitario más cercano." />
    <script>if(localStorage.getItem('ufvshares_token')){location.replace('/app');}</script>
  </head>
  <body class="bg-base-100 min-h-screen font-sans">

    <!-- ── NAVBAR ───────────────────────────────────────────────── -->
    <header class="navbar fixed top-0 z-50 bg-base-100/80 backdrop-blur-md shadow-sm max-w-full px-4 sm:px-8">
      <div class="navbar-start">
        <a href="/" class="flex items-center gap-2 group">
          <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center group-hover:rotate-12 transition-transform shadow">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-content" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
          <span class="text-xl font-extrabold tracking-tight text-primary">UFV<span class="text-base-content"> Shares</span></span>
        </a>
      </div>
      <div class="navbar-end gap-2">
        <a href="/auth?mode=login&next=%2Fapp" class="btn btn-ghost btn-sm hidden sm:flex">Iniciar sesión</a>
        <a href="/auth?mode=register&next=%2Fapp" class="btn btn-primary btn-sm rounded-full px-5 shadow">Registrarse</a>
      </div>
    </header>

    <!-- ── HERO ─────────────────────────────────────────────────── -->
    <section class="relative w-full min-h-screen flex items-center justify-center overflow-hidden pt-16">
      <!-- Background image -->
      <img
        src="/campus.webp"
        alt="Campus UFV"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-primary/50 to-black/70"></div>

      <!-- Content -->
      <div class="relative z-10 text-center text-white max-w-4xl mx-auto px-6 py-20">
        <div class="badge badge-warning badge-lg mb-6 font-semibold tracking-widest uppercase text-xs px-4 py-3 gap-2 shadow">
          Solo para estudiantes UFV
        </div>

        <h1 class="text-5xl sm:text-6xl md:text-7xl font-black leading-tight mb-6 drop-shadow-lg">
          El marketplace<br/>
          <span class="text-yellow-300">universitario</span><br/>
          que te faltaba
        </h1>

        <p class="text-xl sm:text-2xl text-white/85 mb-10 max-w-2xl mx-auto leading-relaxed">
          Compra, vende y alquila con tus compañeros de la UFV. Seguro, rápido y sin intermediarios.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a href="/auth?mode=register&next=%2Fapp" class="btn btn-warning btn-lg rounded-full px-10 font-bold shadow-2xl hover:scale-105 transition-transform text-lg">
            Empezar gratis
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/auth?mode=login&next=%2Fapp" class="btn btn-ghost btn-lg rounded-full px-10 text-white border-white/40 hover:bg-white/10 hover:border-white text-lg">
            Ya tengo cuenta
          </a>
        </div>

        <!-- Social proof mini -->
        <div class="flex items-center justify-center gap-6 mt-14">
          <div class="text-center">
            <div class="text-3xl font-black text-yellow-300">+200</div>
            <div class="text-xs text-white/70 uppercase tracking-wide">Estudiantes</div>
          </div>
          <div class="divider divider-horizontal opacity-30"></div>
          <div class="text-center">
            <div class="text-3xl font-black text-yellow-300">+500</div>
            <div class="text-xs text-white/70 uppercase tracking-wide">Productos</div>
          </div>
          <div class="divider divider-horizontal opacity-30"></div>
          <div class="text-center">
            <div class="text-3xl font-black text-yellow-300">100%</div>
            <div class="text-xs text-white/70 uppercase tracking-wide">Universitario</div>
          </div>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/50 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
      </div>
    </section>

    <!-- ── QUÉ PUEDES HACER ──────────────────────────────────────── -->
    <section class="py-24 bg-base-200">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">Todo lo que necesitas,<br/><span class="text-primary">entre universitarios</span></h2>
          <p class="text-lg text-base-content/60 max-w-xl mx-auto">Sin comisiones a terceros. Solo tú y tus compañeros de campus.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Card 1 -->
          <div class="card bg-base-100 shadow-xl border border-base-200 hover:-translate-y-2 transition-transform duration-300">
            <div class="card-body items-center text-center gap-4">
              <div class="w-16 h-16 rounded-2xl bg-success/15 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              </div>
              <h3 class="text-2xl font-bold">Compra</h3>
              <p class="text-base-content/60 leading-relaxed">Encuentra apuntes, calculadoras, libros de texto y mucho más publicados por estudiantes de tu propia facultad.</p>
              <a href="/auth?mode=register&next=%2Fapp" class="btn btn-success btn-outline btn-sm mt-2 rounded-full">Explorar productos</a>
            </div>
          </div>

          <!-- Card 2 -->
          <div class="card bg-primary text-primary-content shadow-xl hover:-translate-y-2 transition-transform duration-300 scale-105">
            <div class="card-body items-center text-center gap-4">
              <div class="w-16 h-16 rounded-2xl bg-primary-content/20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary-content" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <h3 class="text-2xl font-bold">Vende</h3>
              <p class="text-primary-content/80 leading-relaxed">Publica lo que ya no usas en minutos. Pon tu precio, elige el tipo de transacción y llega a cientos de estudiantes.</p>
              <a href="/auth?mode=register&next=%2Fapp" class="btn bg-primary-content text-primary btn-sm mt-2 rounded-full font-bold hover:scale-105">Publicar ahora</a>
            </div>
          </div>

          <!-- Card 3 -->
          <div class="card bg-base-100 shadow-xl border border-base-200 hover:-translate-y-2 transition-transform duration-300">
            <div class="card-body items-center text-center gap-4">
              <div class="w-16 h-16 rounded-2xl bg-warning/15 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-warning" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
              </div>
              <h3 class="text-2xl font-bold">Alquila</h3>
              <p class="text-base-content/60 leading-relaxed">Necesitas algo solo por un semestre? Alquila calculadoras, equipos de laboratorio y más sin tener que comprar.</p>
              <a href="/auth?mode=register&next=%2Fapp" class="btn btn-warning btn-outline btn-sm mt-2 rounded-full">Ver alquileres</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CÓMO FUNCIONA ─────────────────────────────────────────── -->
    <section class="py-24 bg-base-100">
      <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
          <h2 class="text-4xl sm:text-5xl font-black mb-4">¿Cómo funciona?</h2>
          <p class="text-lg text-base-content/60">En tres pasos, listo.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 relative">
          <!-- Step 1 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="relative">
              <div class="w-20 h-20 rounded-full bg-primary text-primary-content flex items-center justify-center text-3xl font-black shadow-lg ring-4 ring-primary/20">
                1
              </div>
            </div>
            <h3 class="text-xl font-bold">Crea tu cuenta</h3>
            <p class="text-base-content/60">Regístrate con tu correo universitario y accede en segundos. Sin formularios interminables.</p>
            <a href="/auth?mode=register&next=%2Fapp" class="link link-primary font-semibold text-sm">Registrarse →</a>
          </div>

          <!-- Step 2 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-20 h-20 rounded-full bg-base-200 text-base-content flex items-center justify-center text-3xl font-black shadow-lg ring-4 ring-base-300">
              2
            </div>
            <h3 class="text-xl font-bold">Explora o publica</h3>
            <p class="text-base-content/60">Navega por los productos de tus compañeros o crea tu anuncio con foto, descripción y precio.</p>
          </div>

          <!-- Step 3 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="w-20 h-20 rounded-full bg-base-200 text-base-content flex items-center justify-center text-3xl font-black shadow-lg ring-4 ring-base-300">
              3
            </div>
            <h3 class="text-xl font-bold">Contacta y cierra</h3>
            <p class="text-base-content/60">Contacta directamente con el vendedor, queda en el campus y realiza la transacción sin intermediarios.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── CATEGORÍAS ────────────────────────────────────────────── -->
    <section class="py-24 bg-base-200">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-14">
          <h2 class="text-4xl font-black mb-3">Explora por categoría</h2>
          <p class="text-base-content/60">Encuentra exactamente lo que buscas.</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
          <a href="/auth?mode=register&next=%2Fapp"
            class="card bg-base-100 shadow hover:shadow-xl hover:-translate-y-1 transition-all duration-200 cursor-pointer border border-base-200">
            <div class="card-body items-center text-center py-8 gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 5h14a1 1 0 011 1v7H4V6a1 1 0 011-1z"/>
              </svg>
              <span class="font-semibold text-sm">Electrónica</span>
            </div>
          </a>

          <a href="/auth?mode=register&next=%2Fapp"
            class="card bg-base-100 shadow hover:shadow-xl hover:-translate-y-1 transition-all duration-200 cursor-pointer border border-base-200">
            <div class="card-body items-center text-center py-8 gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v13"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 7c-1.8-1.2-4.2-1.7-7-1.7v11c2.8 0 5.2.5 7 1.7"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 7c1.8-1.2 4.2-1.7 7-1.7v11c-2.8 0-5.2.5-7 1.7"/>
              </svg>
              <span class="font-semibold text-sm">Libros</span>
            </div>
          </a>

          <a href="/auth?mode=register&next=%2Fapp"
            class="card bg-base-100 shadow hover:shadow-xl hover:-translate-y-1 transition-all duration-200 cursor-pointer border border-base-200">
            <div class="card-body items-center text-center py-8 gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10v4"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 8v8"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12h4"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8v8"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 10v4"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 12h4"/>
              </svg>
              <span class="font-semibold text-sm">Deporte</span>
            </div>
          </a>

          <a href="/auth?mode=register&next=%2Fapp"
            class="card bg-base-100 shadow hover:shadow-xl hover:-translate-y-1 transition-all duration-200 cursor-pointer border border-base-200">
            <div class="card-body items-center text-center py-8 gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 11l9-7 9 7"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 10v10h14V10"/>
              </svg>
              <span class="font-semibold text-sm">Hogar</span>
            </div>
          </a>

          <a href="/auth?mode=register&next=%2Fapp"
            class="card bg-base-100 shadow hover:shadow-xl hover:-translate-y-1 transition-all duration-200 cursor-pointer border border-base-200">
            <div class="card-body items-center text-center py-8 gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8 4-8-4 8-4 8 4z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10l8 4 8-4V7"/>
              </svg>
              <span class="font-semibold text-sm">Otros</span>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- ── FOTO PARALLAX CTA ─────────────────────────────────────── -->
    <section class="relative py-28 overflow-hidden">
      <img src="/foto.webp" alt="Estudiantes UFV" class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/50 to-transparent"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-6 text-white">
        <h2 class="text-4xl sm:text-5xl font-black mb-6 leading-tight">
          Publica tu primer<br/><span class="text-yellow-300">anuncio en 1 minuto</span>
        </h2>
        <p class="text-xl text-white/80 mb-10 max-w-lg">
          Sube una foto, añade descripción y precio. Tu anuncio llega a cientos de compañeros de campus al instante.
        </p>
        <a href="/auth?mode=register&next=%2Fapp%23publicar"
          class="btn btn-warning btn-lg rounded-full px-10 font-bold shadow-2xl hover:scale-105 transition-transform">
          Publicar ahora — es gratis
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </a>
      </div>
    </section>

    <!-- ── FINAL CTA ─────────────────────────────────────────────── -->
    <section class="py-28 bg-gradient-to-br from-primary to-primary/80 text-primary-content">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-4xl sm:text-5xl font-black mb-6 leading-tight">
          ¿Listo para unirte?
        </h2>
        <p class="text-xl text-primary-content/80 mb-10 max-w-xl mx-auto">
          Únete a la comunidad de estudiantes UFV. Crea tu cuenta en segundos y empieza a comprar, vender y alquilar.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/auth?mode=register&next=%2Fapp"
            class="btn bg-white text-primary btn-lg rounded-full px-12 font-bold shadow-2xl hover:scale-105 transition-transform text-lg">
            Crear cuenta gratis
          </a>
          <a href="/auth?mode=login&next=%2Fapp"
            class="btn btn-ghost btn-lg rounded-full px-12 text-white border-white/40 hover:bg-white/15 hover:border-white text-lg">
            Iniciar sesión
          </a>
        </div>
      </div>
    </section>

    <!-- ── FOOTER ────────────────────────────────────────────────── -->
    <footer class="bg-base-300 py-10">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-base-content/60 text-sm">
        <div class="flex items-center gap-2 font-bold text-base-content">
          <div class="w-7 h-7 bg-primary rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-content" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
          UFV Shares
        </div>
        <p>© {new Date().getFullYear()} UFV Shares · Marketplace universitario</p>
        <div class="flex gap-4">
          <a href="/auth?mode=login&next=%2Fapp" class="link link-hover">Acceder</a>
          <a href="/auth?mode=register&next=%2Fapp" class="link link-hover">Registrarse</a>
          <a href="/contact" class="link link-hover">Contacto</a>
        </div>
      </div>
    </footer>

  </body>
</html>
