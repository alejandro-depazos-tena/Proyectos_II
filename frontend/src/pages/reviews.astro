---
import Layout from "../layouts/Layout.astro";
import AboutAppReviews from "../components/about/AboutAppReviews.astro";
---

<Layout>
  <section class="max-w-7xl mx-auto px-4 py-10 lg:py-16">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-base-content">
        Reseñas de <span class="text-primary">UFV Shares</span>
      </h1>
      <p class="text-lg text-base-content/70 max-w-2xl mx-auto">
        Comparte tu experiencia y consulta lo que opinan otros estudiantes.
      </p>
    </div>
  </section>

  <AboutAppReviews />
</Layout>
