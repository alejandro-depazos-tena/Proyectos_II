---
import Layout from "../../layouts/Layout.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
---

<Layout title="Producto | UFV Shares">
    <!-- Breadcrumb skeleton / placeholder filled by JS -->
    <nav aria-label="Breadcrumb" class="bg-white border-b border-slate-100 py-3">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ol id="breadcrumb-list" class="flex items-center gap-2 text-sm text-slate-500">
                <li><a href="/" class="hover:text-primary font-medium">Inicio</a></li>
                <li class="text-slate-300">/</li>
                <li id="bc-category" class="text-slate-300">—</li>
                <li class="text-slate-300">/</li>
                <li id="bc-title" class="text-slate-400 truncate max-w-xs">Cargando…</li>
            </ol>
        </div>
    </nav>

    <div class="bg-white min-h-screen pb-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

            <!-- Loading -->
            <div id="product-loading" class="grid grid-cols-1 lg:grid-cols-2 gap-12 animate-pulse">
                <div class="rounded-2xl bg-slate-200" style="aspect-ratio:1/1;"></div>
                <div class="space-y-6 pt-4">
                    <div class="h-4 bg-slate-200 rounded w-1/4"></div>
                    <div class="h-8 bg-slate-200 rounded w-3/4"></div>
                    <div class="h-10 bg-slate-200 rounded w-1/3"></div>
                    <div class="h-4 bg-slate-200 rounded w-full"></div>
                    <div class="h-4 bg-slate-200 rounded w-5/6"></div>
                    <div class="h-4 bg-slate-200 rounded w-4/6"></div>
                </div>
            </div>

            <!-- Product detail (hidden until loaded) -->
            <div id="product-detail" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Image -->
                <div class="relative rounded-2xl overflow-hidden bg-slate-100 border border-slate-200" style="aspect-ratio:1/1;">
                    <img id="product-img" src="/foto.webp" alt="" class="w-full h-full object-cover" loading="eager" onerror="this.src='/foto.webp'" />
                    <span id="product-badge-tipo" class="absolute top-4 left-4 badge badge-primary font-bold text-sm"></span>
                </div>

                <!-- Info -->
                <div class="flex flex-col gap-6 pt-2">
                    <span id="product-category" class="text-xs font-semibold uppercase tracking-widest text-slate-400"></span>
                    <h1 id="product-title" class="text-3xl font-black text-slate-900 leading-tight"></h1>
                    <p id="product-price" class="text-4xl font-black text-primary"></p>

                    <!-- Meta chips -->
                    <div class="flex flex-wrap gap-3" id="product-meta">
                        <!-- filled by JS -->
                    </div>

                    <p id="product-desc" class="text-slate-600 leading-relaxed text-base"></p>

                    <!-- CTA buttons -->
                    <div class="flex flex-col sm:flex-row gap-3 mt-2">
                        <button id="add-cart-btn"
                            class="add-to-cart-btn btn btn-primary flex-1 gap-2 text-base font-bold"
                            data-product="">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                            </svg>
                            Añadir al carrito
                        </button>
                        <button id="add-fav-btn"
                            class="add-to-favorite-btn btn btn-outline flex-1 gap-2 text-base font-bold"
                            data-favorite="">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                            </svg>
                            Guardar
                        </button>
                    </div>
                </div>
            </div>

            <!-- Not found -->
            <div id="product-not-found" class="hidden text-center py-32 bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200 mt-4">
                <p class="text-slate-400 font-bold uppercase tracking-widest text-lg">Producto no encontrado</p>
                <a href="/" class="btn btn-primary mt-6">Volver al inicio</a>
            </div>

        </div>
    </div>
</Layout>

<script define:vars={{ API_BASE }}>
    const BACKEND_BASE = (() => { try { return new URL(API_BASE).origin; } catch { return 'http://localhost:8080'; } })();

    function getImageUrl(product) {
        if (product.fotoUrl) return BACKEND_BASE + product.fotoUrl;
        if (product.fotos && product.fotos.length > 0) return BACKEND_BASE + product.fotos[0].url;
        if (product.imagenUrl) return product.imagenUrl;
        return '/foto.webp';
    }

    function chip(label, value, colorClass) {
        return `<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold border ${colorClass}">${label}: <span class="font-bold">${value}</span></span>`;
    }

    async function loadProduct() {
        const id = new URLSearchParams(location.search).get('id');
        if (!id) { showNotFound(); return; }

        const token = localStorage.getItem('ufvshares_token');
        const headers = token ? { 'Authorization': 'Bearer ' + token } : {};

        try {
            const res = await fetch(`${API_BASE}/productos/${id}`, { headers });
            if (!res.ok) { showNotFound(); return; }
            const p = await res.json();
            renderProduct(p);
        } catch (e) {
            showNotFound();
            console.error(e);
        }
    }

    function showNotFound() {
        document.getElementById('product-loading')?.classList.add('hidden');
        document.getElementById('product-not-found')?.classList.remove('hidden');
    }

    function renderProduct(p) {
        const img = getImageUrl(p);
        const title = p.titulo || 'Sin título';
        const price = p.precio != null ? new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(Number(p.precio)) : 'Gratis';
        const category = (p.categoria || '').replace(/_/g, ' ');
        const tipo = p.tipoTransaccion === 'ALQUILER' ? 'Alquiler' : 'Venta';
        const id = p.idProducto;

        // Breadcrumb
        const bcCat = document.getElementById('bc-category');
        const bcTitle = document.getElementById('bc-title');
        if (bcCat) {
            bcCat.innerHTML = `<a href="/category/${(p.categoria || 'otros').toLowerCase()}" class="hover:text-primary">${category}</a>`;
            bcCat.classList.remove('text-slate-300');
        }
        if (bcTitle) bcTitle.textContent = title;
        document.title = `${title} | UFV Shares`;

        // Image
        document.getElementById('product-img').src = img;
        document.getElementById('product-img').alt = title;
        document.getElementById('product-badge-tipo').textContent = tipo;

        // Text
        document.getElementById('product-category').textContent = category;
        document.getElementById('product-title').textContent = title;
        document.getElementById('product-price').textContent = price;
        document.getElementById('product-desc').textContent = p.descripcion || '';

        // Meta chips
        const meta = document.getElementById('product-meta');
        if (meta) {
            const chips = [];
            if (p.condicion)      chips.push(chip('Condición',  p.condicion,      'bg-sky-50 border-sky-200 text-sky-700'));
            if (p.ubicacion)      chips.push(chip('Ubic.',      p.ubicacion,      'bg-amber-50 border-amber-200 text-amber-700'));
            if (p.estadoProducto) chips.push(chip('Estado',     p.estadoProducto, 'bg-emerald-50 border-emerald-200 text-emerald-700'));
            meta.innerHTML = chips.join('');
        }

        // Cart & favourite data
        const productData = JSON.stringify({ id: String(id), name: title, price: p.precio ?? 0, image: img, stock: 1 });
        const favData = JSON.stringify({ id: String(id), name: title, price: p.precio ?? 0, image: img, stock: 1, slug: String(id) });
        document.getElementById('add-cart-btn').dataset.product = productData;
        document.getElementById('add-fav-btn').dataset.favorite = favData;

        // Show detail
        document.getElementById('product-loading')?.classList.add('hidden');
        const detail = document.getElementById('product-detail');
        detail?.classList.remove('hidden');
        detail?.classList.add('grid');

        // Reinit cart/favorites listeners
        document.dispatchEvent(new CustomEvent('view:product-loaded'));
    }

    loadProduct();
</script>

<script>
    import { toggleFavorite, isFavorite, favoriteItems } from '../../store/favoriteStore';
    import { addToCart } from '../../store/cartStore';
    import { toast } from 'sonner';

    function setupViewListeners() {
        const cartBtn = document.getElementById('add-cart-btn');
        const favBtn = document.getElementById('add-fav-btn');

        if (!cartBtn || !favBtn) return;

        // Cart listener
        if (!cartBtn.getAttribute('data-listener')) {
            cartBtn.addEventListener('click', () => {
                const product = JSON.parse(cartBtn.getAttribute('data-product') || '{}');
                if (!product.id) return;
                const result = addToCart(product, 1);
                if (result.success) {
                    toast.success(result.message);
                } else {
                    toast.error(result.message);
                }
            });
            cartBtn.setAttribute('data-listener', 'true');
        }

        // Favorites listener
        if (!favBtn.getAttribute('data-listener')) {
            favBtn.addEventListener('click', () => {
                const fav = JSON.parse(favBtn.getAttribute('data-favorite') || '{}');
                if (!fav.id) return;
                const result = toggleFavorite(fav);
                if (result.success) {
                    toast.success(result.message);
                }
                updateFavBtn();
            });
            favBtn.setAttribute('data-listener', 'true');
        }

        // Subscribe to store to keep button in sync
        favoriteItems.subscribe(() => updateFavBtn());
    }

    function updateFavBtn() {
        const favBtn = document.getElementById('add-fav-btn');
        if (!favBtn) return;
        const fav = JSON.parse(favBtn.getAttribute('data-favorite') || '{}');
        if (!fav.id) return;
        const isFav = isFavorite(fav.id);
        const svg = favBtn.querySelector('svg');
        if (isFav) {
            svg?.classList.add('fill-current');
            favBtn.classList.add('btn-primary');
            favBtn.classList.remove('btn-outline');
        } else {
            svg?.classList.remove('fill-current');
            favBtn.classList.remove('btn-primary');
            favBtn.classList.add('btn-outline');
        }
    }

    // Init when product data is loaded into buttons
    document.addEventListener('view:product-loaded', () => {
        setupViewListeners();
        updateFavBtn();
    });
</script>
