---
import Layout from "../../layouts/Layout.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
---

<Layout title="Producto | UFV Shares">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="bg-white border-b border-slate-100 py-3">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <ol id="breadcrumb-list" class="flex items-center gap-2 text-sm text-slate-500">
                <li><a href="/app" class="hover:text-primary font-medium">Inicio</a></li>
                <li class="text-slate-300">/</li>
                <li id="bc-category" class="text-slate-300">—</li>
                <li class="text-slate-300">/</li>
                <li id="bc-title" class="text-slate-400 truncate max-w-xs">Cargando…</li>
            </ol>
        </div>
    </nav>

    <div class="bg-white min-h-screen pb-20">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

            <!-- Loading skeleton -->
            <div id="product-loading" class="grid grid-cols-1 lg:grid-cols-2 gap-12 animate-pulse">
                <div class="space-y-3">
                    <div class="rounded-2xl bg-slate-200" style="aspect-ratio:4/3;"></div>
                    <div class="flex gap-2">
                        <div class="h-16 w-16 rounded-xl bg-slate-200"></div>
                        <div class="h-16 w-16 rounded-xl bg-slate-200"></div>
                        <div class="h-16 w-16 rounded-xl bg-slate-200"></div>
                    </div>
                </div>
                <div class="space-y-6 pt-4">
                    <div class="h-4 bg-slate-200 rounded w-1/4"></div>
                    <div class="h-8 bg-slate-200 rounded w-3/4"></div>
                    <div class="h-10 bg-slate-200 rounded w-1/3"></div>
                    <div class="h-4 bg-slate-200 rounded w-full"></div>
                    <div class="h-4 bg-slate-200 rounded w-5/6"></div>
                </div>
            </div>

            <!-- Product detail -->
            <div id="product-detail" class="grid grid-cols-1 lg:grid-cols-2 gap-12" style="display:none;">

                <!-- LEFT: Gallery -->
                <div class="space-y-3">
                    <!-- Main image -->
                    <div class="relative rounded-2xl overflow-hidden bg-slate-100 border border-slate-200 cursor-zoom-in" id="main-img-wrap" style="aspect-ratio:4/3;">
                        <img id="product-img" src="/foto.webp" alt="" class="w-full h-full object-cover transition-transform duration-300 hover:scale-105" loading="eager" onerror="this.src='/foto.webp'" />
                        <span id="product-badge-tipo" class="absolute top-4 left-4 badge badge-primary font-bold text-sm"></span>
                        <!-- Zoom hint -->
                        <div class="absolute bottom-3 right-3 bg-black/40 text-white rounded-lg px-2 py-1 text-xs font-medium flex items-center gap-1 pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35M11 8v6M8 11h6"/></svg>
                            Ampliar
                        </div>
                    </div>
                    <!-- Thumbnails -->
                    <div id="thumbnail-strip" class="flex gap-2 overflow-x-auto pb-1"></div>
                </div>

                <!-- RIGHT: Info -->
                <div class="flex flex-col gap-5 pt-2">
                    <span id="product-category" class="text-xs font-semibold uppercase tracking-widest text-slate-400"></span>
                    <h1 id="product-title" class="text-3xl font-black text-slate-900 leading-tight"></h1>
                    <p id="product-price" class="text-4xl font-black text-primary"></p>

                    <!-- Meta chips -->
                    <div class="flex flex-wrap gap-2" id="product-meta"></div>

                    <!-- Unavailability banner -->
                    <div id="unavailability-banner" class="rounded-2xl p-4 border font-semibold text-sm flex items-start gap-3" style="display:none;"></div>

                    <!-- Rental dates block (shown when ALQUILADO) -->
                    <div id="rental-dates" class="hidden rounded-2xl border border-amber-200 bg-amber-50 p-4">
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-amber-600 mb-3">Fechas del alquiler activo</p>
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Inicio</p>
                                <p id="rental-start" class="text-sm font-bold text-slate-800">—</p>
                            </div>
                            <div>
                                <p class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">Devolución prevista</p>
                                <p id="rental-end" class="text-sm font-bold text-slate-800">—</p>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="border-t border-slate-100 pt-4">
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 mb-2">Descripción</p>
                        <p id="product-desc" class="text-slate-600 leading-relaxed text-base"></p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4" id="marketplace-compare-card">
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 mb-3">Comparar precio online</p>
                        <div class="space-y-2 mb-3">
                            <p class="text-sm text-slate-600">
                                Precio del anuncio:
                                <span class="font-black text-slate-900" id="seller-price-compare">—</span>
                            </p>
                            <p class="text-sm text-slate-600" id="online-price-reference-row">
                                Precio online de referencia:
                                <span class="font-black text-slate-900" id="online-price-reference">No disponible</span>
                            </p>
                        </div>
                        <p id="marketplace-status" class="hidden text-xs text-slate-500 mb-3"></p>
                        <div class="flex flex-wrap gap-2">
                            <a id="marketplace-amazon-link" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline rounded-full">Ver en Amazon</a>
                            <a id="marketplace-keepa-link" href="#" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline rounded-full">Ver en Keepa</a>
                        </div>
                    </div>

                    <!-- Stats row -->
                    <div id="product-stats" class="grid grid-cols-3 gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <div class="text-center">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Publicado</p>
                            <p class="text-sm font-bold text-slate-700" id="stat-fecha">—</p>
                        </div>
                        <div class="text-center border-x border-slate-200">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Vistas</p>
                            <p class="text-sm font-bold text-slate-700" id="stat-vistas">—</p>
                        </div>
                        <div class="text-center">
                            <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Fotos</p>
                            <p class="text-sm font-bold text-slate-700" id="stat-fotos">—</p>
                        </div>
                    </div>

                    <!-- Seller card -->
                    <div id="seller-card" class="hidden rounded-2xl border border-slate-100 bg-slate-50 p-5">
                        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400 mb-3" id="seller-role-label">Vendedor</p>
                        <div class="flex items-center gap-4">
                            <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center shrink-0 overflow-hidden border-2 border-white shadow">
                                <img id="seller-avatar" src="" alt="" class="hidden w-14 h-14 rounded-full object-cover" />
                                <svg id="seller-avatar-placeholder" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-black text-slate-900 text-base" id="seller-name">—</p>
                                <p class="text-xs text-slate-500 font-medium truncate" id="seller-email"></p>
                            </div>
                            <a id="seller-contact-quick" href="#" class="btn btn-sm btn-ghost border border-slate-200 gap-1 text-xs">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                                Escribir
                            </a>
                        </div>
                    </div>

                    <!-- CTA buttons -->
                    <div class="flex flex-col sm:flex-row gap-3 pt-2">
                        <a id="contact-btn" href="#" class="btn btn-primary flex-1 gap-2 text-base font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                            <span id="contact-btn-label">Contactar al vendedor</span>
                        </a>
                        <button id="reserve-btn" class="btn btn-outline btn-accent flex-1 gap-2 text-base font-bold">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Solicitar artículo
                        </button>
                        <button id="add-fav-btn" class="btn btn-outline flex-1 gap-2 text-base font-bold" data-favorite="">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                            </svg>
                            Guardar
                        </button>
                        <button id="report-product-btn" class="btn btn-outline btn-error flex-1 gap-2 text-base font-bold" type="button">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86l-8 14A2 2 0 004 21h16a2 2 0 001.71-3.14l-8-14a2 2 0 00-3.42 0z"/>
                            </svg>
                            Reportar
                        </button>
                    </div>

                    <div id="my-requests-panel" class="hidden rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-center justify-between gap-3 mb-3">
                            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500">Mis solicitudes para este producto</p>
                            <span id="my-requests-count" class="text-xs font-semibold text-slate-500">0</span>
                        </div>
                        <div id="my-requests-list" class="space-y-2"></div>
                        <p id="my-requests-empty" class="hidden text-sm text-slate-500">Aún no has enviado solicitudes para este producto.</p>
                    </div>

                    <div id="owner-requests-panel" class="hidden rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex items-center justify-between gap-3 mb-3">
                            <p class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500">Solicitudes en tu producto</p>
                            <span id="owner-requests-count" class="text-xs font-semibold text-slate-500">0</span>
                        </div>
                        <div id="owner-requests-list" class="space-y-2"></div>
                        <p id="owner-requests-empty" class="hidden text-sm text-slate-500">No hay solicitudes para este producto.</p>
                    </div>

                    <!-- Trust row -->
                    <div class="flex flex-wrap gap-4 text-xs text-slate-400 pt-2 border-t border-slate-100">
                        <span class="flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                            Transacción entre estudiantes UFV
                        </span>
                        <span class="flex items-center gap-1">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            Recogida en campus
                        </span>
                    </div>
                </div>
            </div>

            <!-- Not found -->
            <div id="product-not-found" class="hidden text-center py-32 bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200 mt-4">
                <p class="text-slate-400 font-bold uppercase tracking-widest text-lg">Producto no encontrado</p>
                <a href="/app" class="btn btn-primary mt-6">Volver al inicio</a>
            </div>

        </div>
    </div>

    <!-- Lightbox modal -->
    <div id="lightbox" class="fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4" style="display:none;" role="dialog" aria-modal="true" aria-label="Galería de fotos">
        <button id="lightbox-close" class="absolute top-4 right-4 text-white bg-white/10 hover:bg-white/20 rounded-full p-2 transition-colors" aria-label="Cerrar">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white bg-white/10 hover:bg-white/20 rounded-full p-3 transition-colors" aria-label="Anterior">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white bg-white/10 hover:bg-white/20 rounded-full p-3 transition-colors" aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
        <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-xl shadow-2xl" />
        <p id="lightbox-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm font-medium"></p>
    </div>

    <!-- Reserva: confirmación -->
    <div id="reserve-confirm-modal" class="fixed inset-0 z-60 items-center justify-center p-4 bg-black/55" style="display:none;">
        <div class="w-full max-w-md rounded-2xl bg-white border border-slate-200 shadow-2xl overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100">
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-emerald-500 mb-2">Confirmar solicitud</p>
                <h3 class="text-lg font-black text-slate-900">¿Quieres enviar solicitud al vendedor?</h3>
                <p class="text-sm text-slate-600 mt-2">Al confirmar, se enviará una solicitud y el vendedor podrá aceptarla o rechazarla.</p>
                <div id="reserve-rental-date-group" class="hidden mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3">
                    <label for="reserve-rental-end-date" class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Fecha de devolución</label>
                    <input
                        id="reserve-rental-end-date"
                        type="date"
                        class="input input-bordered w-full"
                    />
                    <p class="text-xs text-slate-500 mt-2">Selecciona hasta qué fecha quieres alquilar este producto.</p>
                </div>
                <p id="reserve-rental-date-error" class="hidden mt-3 text-xs font-semibold text-red-600"></p>
            </div>
            <div class="px-6 py-4 flex justify-end gap-3 bg-slate-50/70">
                <button id="reserve-confirm-cancel" type="button" class="btn btn-ghost btn-sm rounded-full">Cancelar</button>
                <button id="reserve-confirm-accept" type="button" class="btn btn-primary btn-sm rounded-full">Sí, enviar solicitud</button>
            </div>
        </div>
    </div>

    <!-- Reserva: resultado -->
    <div id="reserve-feedback-modal" class="fixed inset-0 z-61 items-center justify-center p-4 bg-black/55" style="display:none;">
        <div class="w-full max-w-md rounded-2xl bg-white border border-slate-200 shadow-2xl overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100">
                <p id="reserve-feedback-tag" class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-2">Información</p>
                <h3 id="reserve-feedback-title" class="text-lg font-black text-slate-900">Estado de la solicitud</h3>
                <p id="reserve-feedback-message" class="text-sm text-slate-600 mt-2"></p>
            </div>
            <div class="px-6 py-4 flex justify-end bg-slate-50/70">
                <button id="reserve-feedback-close" type="button" class="btn btn-primary btn-sm rounded-full">Aceptar</button>
            </div>
        </div>
    </div>

    <!-- Reporte de producto -->
    <div id="report-product-modal" class="fixed inset-0 z-62 items-center justify-center p-4 bg-black/55" style="display:none;">
        <div class="w-full max-w-md rounded-2xl bg-white border border-slate-200 shadow-2xl overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-100">
                <p class="text-[10px] font-black uppercase tracking-[0.3em] text-red-500 mb-2">Reportar producto</p>
                <h3 class="text-lg font-black text-slate-900">Ayúdanos a moderar contenido</h3>
                <p class="text-sm text-slate-600 mt-2">Tu reporte será revisado por el equipo de administración.</p>
            </div>
            <form id="report-product-form" class="px-6 py-5 grid gap-4">
                <div>
                    <label for="report-product-reason" class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Motivo</label>
                    <select id="report-product-reason" class="select select-bordered w-full" required>
                        <option value="">Selecciona un motivo</option>
                        <option value="Contenido inapropiado">Contenido inapropiado</option>
                        <option value="Producto fraudulento">Producto fraudulento</option>
                        <option value="Información incorrecta">Información incorrecta</option>
                        <option value="Spam">Spam</option>
                        <option value="Otro">Otro</option>
                    </select>
                </div>
                <div>
                    <label for="report-product-comment" class="block text-xs font-bold uppercase tracking-widest text-slate-500 mb-2">Comentario (opcional)</label>
                    <textarea id="report-product-comment" rows="4" class="textarea textarea-bordered w-full" placeholder="Describe brevemente el problema"></textarea>
                </div>
                <p id="report-product-error" class="text-xs font-semibold text-red-600 min-h-4"></p>
                <div class="flex justify-end gap-3 pt-1">
                    <button id="report-product-cancel" type="button" class="btn btn-ghost">Cancelar</button>
                    <button id="report-product-submit" type="submit" class="btn btn-error text-white">Enviar reporte</button>
                </div>
            </form>
        </div>
    </div>
</Layout>

<script define:vars={{ API_BASE }}>
    const BACKEND_BASE = (() => { try { return new URL(API_BASE).origin; } catch { return 'http://localhost:8080'; } })();

    // Gallery state
    let galleryPhotos = [];
    let lightboxIndex = 0;

    function getImageUrl(product) {
        if (product.fotoUrl) return BACKEND_BASE + product.fotoUrl;
        if (product.fotos && product.fotos.length > 0) return BACKEND_BASE + product.fotos[0].url;
        if (product.imagenUrl) return product.imagenUrl;
        return '/foto.webp';
    }

    function chip(label, value, colorClass) {
        return `<span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold border ${colorClass}">${label}: <span class="font-bold">${value}</span></span>`;
    }

    function buildMarketplaceQuery(product) {
        return [product?.titulo, product?.categoria, product?.marca]
            .filter(Boolean)
            .join(' ')
            .replace(/_/g, ' ')
            .trim();
    }

    function getAmazonSearchUrl(product) {
        return `https://www.amazon.es/s?k=${encodeURIComponent(buildMarketplaceQuery(product))}`;
    }

    function getKeepaSearchUrl(product) {
        return `https://keepa.com/#!search/${encodeURIComponent(buildMarketplaceQuery(product))}`;
    }

    function getOnlineReferencePrice(product) {
        const raw = product?.precioOnline ?? product?.precioReferenciaOnline ?? product?.precioMarketplace;
        const value = Number(raw);
        if (!Number.isFinite(value) || value <= 0) return null;
        return value;
    }

    function toEuro(value) {
        return new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(value);
    }

    async function loadMarketplaceData(productId, fallbackProduct) {
        const status = document.getElementById('marketplace-status');
        const onlineRefEl = document.getElementById('online-price-reference');
        const onlineRefRow = document.getElementById('online-price-reference-row');
        const amazonLink = document.getElementById('marketplace-amazon-link');
        const keepaLink = document.getElementById('marketplace-keepa-link');

        if (status) {
            status.classList.remove('hidden');
            status.textContent = 'Consultando precio online...';
        }

        try {
            const res = await fetch(`${API_BASE}/productos/${productId}/marketplace`);
            if (!res.ok) throw new Error('HTTP ' + res.status);
            const data = await res.json();

            if (amazonLink && data.amazonSearchUrl) amazonLink.setAttribute('href', data.amazonSearchUrl);
            if (keepaLink && (data.keepaSearchUrl || data.keepaProductUrl)) {
                keepaLink.setAttribute('href', data.keepaProductUrl || data.keepaSearchUrl);
            }

            if (onlineRefEl && data.currentOnlinePrice != null) {
                onlineRefEl.textContent = toEuro(Number(data.currentOnlinePrice));
                onlineRefRow?.classList.remove('hidden');
            } else if (onlineRefEl) {
                const fallback = getOnlineReferencePrice(fallbackProduct);
                if (fallback !== null) {
                    onlineRefEl.textContent = toEuro(fallback);
                    onlineRefRow?.classList.remove('hidden');
                } else {
                    onlineRefEl.textContent = 'No disponible';
                    onlineRefRow?.classList.add('hidden');
                }
            }

            if (status) {
                if (data.available === false && data.message) {
                    status.textContent = data.message;
                    status.classList.remove('hidden');
                } else {
                    status.classList.add('hidden');
                }
            }
        } catch {
            const fallback = getOnlineReferencePrice(fallbackProduct);
            if (onlineRefEl) {
                if (fallback !== null) {
                    onlineRefEl.textContent = toEuro(fallback);
                    onlineRefRow?.classList.remove('hidden');
                } else {
                    onlineRefEl.textContent = 'No disponible';
                    onlineRefRow?.classList.add('hidden');
                }
            }
            if (status) {
                status.textContent = 'No se pudo cargar la comparativa online ahora mismo.';
                status.classList.remove('hidden');
            }
        }
    }

    function toLocalDateInputValue(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        return `${year}-${month}-${day}`;
    }

    function openReserveConfirmModal(tipoTransaccion) {
        return new Promise((resolve) => {
            const modal = document.getElementById('reserve-confirm-modal');
            const btnCancel = document.getElementById('reserve-confirm-cancel');
            const btnAccept = document.getElementById('reserve-confirm-accept');
            const rentalDateGroup = document.getElementById('reserve-rental-date-group');
            const rentalDateInput = document.getElementById('reserve-rental-end-date');
            const rentalDateError = document.getElementById('reserve-rental-date-error');
            if (!modal || !btnCancel || !btnAccept) {
                resolve({ confirmed: false, fechaFin: null });
                return;
            }

            const isRental = tipoTransaccion === 'ALQUILER';
            if (rentalDateGroup) {
                rentalDateGroup.classList.toggle('hidden', !isRental);
            }
            if (rentalDateError) {
                rentalDateError.classList.add('hidden');
                rentalDateError.textContent = '';
            }
            if (isRental && rentalDateInput instanceof HTMLInputElement) {
                const tomorrow = new Date();
                tomorrow.setDate(tomorrow.getDate() + 1);
                const minDate = toLocalDateInputValue(tomorrow);
                rentalDateInput.min = minDate;
                if (!rentalDateInput.value || rentalDateInput.value < minDate) {
                    rentalDateInput.value = minDate;
                }
            }

            const close = (accepted) => {
                const selectedDate = rentalDateInput instanceof HTMLInputElement ? rentalDateInput.value || null : null;
                modal.style.display = 'none';
                btnCancel.onclick = null;
                btnAccept.onclick = null;
                modal.onclick = null;
                resolve({ confirmed: accepted, fechaFin: accepted ? selectedDate : null });
            };

            btnCancel.onclick = () => close(false);
            btnAccept.onclick = () => {
                if (isRental) {
                    const selectedDate = rentalDateInput instanceof HTMLInputElement ? rentalDateInput.value : '';
                    if (!selectedDate) {
                        if (rentalDateError) {
                            rentalDateError.textContent = 'Selecciona una fecha de devolución para el alquiler.';
                            rentalDateError.classList.remove('hidden');
                        }
                        return;
                    }
                }
                close(true);
            };
            modal.onclick = (e) => {
                if (e.target === modal) close(false);
            };

            modal.style.display = 'flex';
        });
    }

    function showReserveFeedbackModal(message, kind = 'info') {
        return new Promise((resolve) => {
            const modal = document.getElementById('reserve-feedback-modal');
            const tag = document.getElementById('reserve-feedback-tag');
            const title = document.getElementById('reserve-feedback-title');
            const text = document.getElementById('reserve-feedback-message');
            const btnClose = document.getElementById('reserve-feedback-close');
            if (!modal || !tag || !title || !text || !btnClose) {
                resolve();
                return;
            }

            if (kind === 'success') {
                tag.textContent = 'Solicitud enviada';
                tag.className = 'text-[10px] font-black uppercase tracking-[0.3em] text-emerald-500 mb-2';
                title.textContent = 'Solicitud enviada correctamente';
            } else if (kind === 'error') {
                tag.textContent = 'No se pudo enviar';
                tag.className = 'text-[10px] font-black uppercase tracking-[0.3em] text-red-500 mb-2';
                title.textContent = 'Ha ocurrido un problema';
            } else {
                tag.textContent = 'Información';
                tag.className = 'text-[10px] font-black uppercase tracking-[0.3em] text-slate-500 mb-2';
                title.textContent = 'Estado de la solicitud';
            }

            text.textContent = message;

            const close = () => {
                modal.style.display = 'none';
                btnClose.onclick = null;
                modal.onclick = null;
                resolve();
            };

            btnClose.onclick = close;
            modal.onclick = (e) => {
                if (e.target === modal) close();
            };
            modal.style.display = 'flex';
        });
    }

    function openReportProductModal() {
        const modal = document.getElementById('report-product-modal');
        const errorEl = document.getElementById('report-product-error');
        const reason = document.getElementById('report-product-reason');
        const comment = document.getElementById('report-product-comment');
        if (!modal) return;
        if (errorEl) errorEl.textContent = '';
        if (reason instanceof HTMLSelectElement) reason.value = 'Contenido inapropiado';
        if (comment instanceof HTMLTextAreaElement) comment.value = '';
        modal.style.display = 'flex';
    }

    function closeReportProductModal() {
        const modal = document.getElementById('report-product-modal');
        if (!modal) return;
        modal.style.display = 'none';
    }

    function formatEsDate(isoDate) {
        if (!isoDate) return '—';
        const d = new Date(isoDate);
        if (Number.isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#039;');
    }

    function badgeEstadoSolicitud(estado) {
        const styles = {
            PENDIENTE: 'bg-amber-100 text-amber-700 border border-amber-200',
            ACEPTADA: 'bg-emerald-100 text-emerald-700 border border-emerald-200',
            RECHAZADA: 'bg-red-100 text-red-700 border border-red-200',
            CANCELADA: 'bg-slate-200 text-slate-700 border border-slate-300',
        };
        const labels = {
            PENDIENTE: 'Pendiente',
            ACEPTADA: 'Aceptada',
            RECHAZADA: 'Rechazada',
            CANCELADA: 'Cancelada',
        };
        const css = styles[estado] || 'bg-slate-100 text-slate-700 border border-slate-200';
        const label = labels[estado] || estado || 'Desconocido';
        return `<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-bold ${css}">${escapeHtml(label)}</span>`;
    }

    async function loadMyRequestsForProduct(productId, token) {
        const panel = document.getElementById('my-requests-panel');
        const list = document.getElementById('my-requests-list');
        const empty = document.getElementById('my-requests-empty');
        const count = document.getElementById('my-requests-count');
        if (!panel || !list || !empty || !count || !token) return;

        try {
            const res = await fetch(API_BASE + '/me/solicitudes/enviadas', {
                headers: { 'Authorization': 'Bearer ' + token },
            });

            if (!res.ok) {
                panel.classList.add('hidden');
                return;
            }

            const all = await res.json();
            const productRequests = (Array.isArray(all) ? all : [])
                .filter((item) => Number(item?.producto?.idProducto) === Number(productId))
                .sort((a, b) => new Date(b?.fechaSolicitud || 0) - new Date(a?.fechaSolicitud || 0));

            list.innerHTML = '';
            count.textContent = String(productRequests.length);

            if (productRequests.length === 0) {
                empty.classList.remove('hidden');
                panel.classList.remove('hidden');
                return;
            }

            empty.classList.add('hidden');
            productRequests.forEach((item) => {
                const owner = item?.propietario || {};
                const nombre = [owner.nombre, owner.apellidos].filter(Boolean).join(' ').trim() || 'Vendedor';
                const fecha = formatEsDate(item?.fechaSolicitud);
                const fechaFin = formatEsDate(item?.fechaFin);
                list.insertAdjacentHTML('beforeend', `
                    <article class="rounded-xl border border-slate-200 bg-white px-3 py-2">
                        <div class="flex items-start justify-between gap-2">
                            <p class="font-semibold text-slate-800 text-sm">${escapeHtml(nombre)}</p>
                            ${badgeEstadoSolicitud(item?.estadoSolicitud)}
                        </div>
                        <p class="text-xs text-slate-500 mt-1">Enviada el ${escapeHtml(fecha)}</p>
                        ${item?.tipoTransaccion === 'ALQUILER' ? `<p class="text-xs text-slate-500 mt-1">Devolución solicitada: ${escapeHtml(fechaFin)}</p>` : ''}
                    </article>
                `);
            });

            panel.classList.remove('hidden');
        } catch {
            panel.classList.add('hidden');
        }
    }

    async function loadOwnerProductRequests(productId, token) {
        const panel = document.getElementById('owner-requests-panel');
        const list = document.getElementById('owner-requests-list');
        const empty = document.getElementById('owner-requests-empty');
        const count = document.getElementById('owner-requests-count');
        if (!panel || !list || !empty || !count || !token) return;

        try {
            const res = await fetch(API_BASE + '/me/solicitudes/recibidas', {
                headers: { 'Authorization': 'Bearer ' + token },
            });

            if (!res.ok) {
                panel.classList.add('hidden');
                return;
            }

            const all = await res.json();
            const productRequests = (Array.isArray(all) ? all : [])
                .filter((item) => Number(item?.producto?.idProducto) === Number(productId))
                .sort((a, b) => new Date(b?.fechaSolicitud || 0) - new Date(a?.fechaSolicitud || 0));

            list.innerHTML = '';
            count.textContent = String(productRequests.length);

            if (productRequests.length === 0) {
                empty.classList.remove('hidden');
                panel.classList.remove('hidden');
                return;
            }

            empty.classList.add('hidden');
            productRequests.forEach((item) => {
                const solicitante = item?.solicitante || {};
                const nombre = [solicitante.nombre, solicitante.apellidos].filter(Boolean).join(' ').trim() || 'Usuario';
                const fecha = formatEsDate(item?.fechaSolicitud);
                const fechaFin = formatEsDate(item?.fechaFin);
                const pending = item?.estadoSolicitud === 'PENDIENTE';
                list.insertAdjacentHTML('beforeend', `
                    <article class="rounded-xl border border-slate-200 bg-white px-3 py-2" data-owner-request-id="${escapeHtml(item?.idSolicitud)}">
                        <div class="flex items-start justify-between gap-2">
                            <p class="font-semibold text-slate-800 text-sm">${escapeHtml(nombre)}</p>
                            ${badgeEstadoSolicitud(item?.estadoSolicitud)}
                        </div>
                        <p class="text-xs text-slate-500 mt-1">Solicitado el ${escapeHtml(fecha)}</p>
                        ${item?.tipoTransaccion === 'ALQUILER' ? `<p class="text-xs text-slate-500 mt-1">Devolución solicitada: ${escapeHtml(fechaFin)}</p>` : ''}
                        ${pending ? `
                            <div class="mt-3 flex gap-2">
                                <button type="button" class="btn btn-xs btn-success rounded-full" data-owner-request-action="accept">Aceptar</button>
                                <button type="button" class="btn btn-xs btn-error rounded-full" data-owner-request-action="reject">Rechazar</button>
                            </div>
                        ` : ''}
                    </article>
                `);
            });

            panel.classList.remove('hidden');
        } catch {
            panel.classList.add('hidden');
        }
    }

    function setupOwnerRequestsActions(productId, token) {
        const list = document.getElementById('owner-requests-list');
        if (!list || !token) return;
        if (list.getAttribute('data-listener') === 'true') return;

        list.addEventListener('click', async (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;

            const button = target.closest('[data-owner-request-action]');
            if (!(button instanceof HTMLButtonElement)) return;

            const card = button.closest('[data-owner-request-id]');
            const requestId = card?.getAttribute('data-owner-request-id');
            const action = button.getAttribute('data-owner-request-action');
            if (!requestId || !action) return;

            const isAccept = action === 'accept';
            const oldLabel = button.textContent || '';
            button.disabled = true;
            button.textContent = isAccept ? 'Aceptando...' : 'Rechazando...';

            try {
                const res = await fetch(API_BASE + `/me/solicitudes/${requestId}/${isAccept ? 'aceptar' : 'rechazar'}`, {
                    method: 'PUT',
                    headers: { 'Authorization': 'Bearer ' + token },
                });

                if (!res.ok) {
                    const raw = await res.text().catch(() => '');
                    let message = 'No se pudo actualizar la solicitud.';
                    if (raw) {
                        try {
                            const parsed = JSON.parse(raw);
                            message = parsed?.message ?? parsed?.error ?? message;
                        } catch {
                            message = raw;
                        }
                    }
                    await showReserveFeedbackModal(message, 'error');
                    return;
                }

                await showReserveFeedbackModal(
                    isAccept ? 'Solicitud aceptada correctamente.' : 'Solicitud rechazada correctamente.',
                    'success'
                );
                await loadOwnerProductRequests(productId, token);
            } catch {
                await showReserveFeedbackModal('No se pudo conectar con el servidor.', 'error');
            } finally {
                button.disabled = false;
                button.textContent = oldLabel;
            }
        });

        list.setAttribute('data-listener', 'true');
    }

    // ── Gallery & lightbox ───────────────────────────────────────────────────

    function buildGallery(photos, fallbackUrl) {
        galleryPhotos = photos.length > 0 ? photos : [fallbackUrl];

        const mainImg = document.getElementById('product-img');
        const thumbStrip = document.getElementById('thumbnail-strip');
        const statFotos = document.getElementById('stat-fotos');

        if (mainImg) {
            mainImg.src = galleryPhotos[0];
            mainImg.onerror = () => { mainImg.src = '/foto.webp'; };
        }
        if (statFotos) statFotos.textContent = galleryPhotos.length;

        // Click main image → open lightbox
        const mainWrap = document.getElementById('main-img-wrap');
        if (mainWrap) {
            mainWrap.onclick = () => openLightbox(0);
        }

        // Build thumbnails
        if (thumbStrip) {
            thumbStrip.innerHTML = '';
            if (galleryPhotos.length > 1) {
                galleryPhotos.forEach((url, i) => {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = `flex-shrink-0 w-16 h-16 rounded-xl overflow-hidden border-2 transition-all ${i === 0 ? 'border-primary' : 'border-slate-200 hover:border-primary/60'}`;
                    btn.innerHTML = `<img src="${url}" alt="" class="w-full h-full object-cover" onerror="this.src='/foto.webp'" />`;
                    btn.onclick = () => {
                        switchMainImage(i);
                    };
                    thumbStrip.appendChild(btn);
                });
            }
        }

        // Init lightbox buttons
        document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
        document.getElementById('lightbox-prev')?.addEventListener('click', () => navigateLightbox(-1));
        document.getElementById('lightbox-next')?.addEventListener('click', () => navigateLightbox(1));
        document.getElementById('lightbox')?.addEventListener('click', (e) => {
            if (e.target === document.getElementById('lightbox')) closeLightbox();
        });
        document.addEventListener('keydown', handleLightboxKey);
    }

    function switchMainImage(index) {
        lightboxIndex = index;
        const mainImg = document.getElementById('product-img');
        if (mainImg) mainImg.src = galleryPhotos[index];
        // Update thumbnail active state
        const thumbStrip = document.getElementById('thumbnail-strip');
        if (thumbStrip) {
            thumbStrip.querySelectorAll('button').forEach((btn, i) => {
                btn.className = btn.className.replace('border-primary', i === index ? 'border-primary' : 'border-slate-200 hover:border-primary/60');
                if (i === index) btn.classList.add('border-primary');
                else btn.classList.remove('border-primary');
            });
        }
    }

    function openLightbox(index) {
        lightboxIndex = index;
        const lb = document.getElementById('lightbox');
        const lbImg = document.getElementById('lightbox-img');
        const lbCounter = document.getElementById('lightbox-counter');
        const lbPrev = document.getElementById('lightbox-prev');
        const lbNext = document.getElementById('lightbox-next');
        if (!lb || !lbImg) return;
        lbImg.src = galleryPhotos[index];
        if (lbCounter) lbCounter.textContent = galleryPhotos.length > 1 ? `${index + 1} / ${galleryPhotos.length}` : '';
        if (lbPrev) lbPrev.style.display = galleryPhotos.length > 1 ? '' : 'none';
        if (lbNext) lbNext.style.display = galleryPhotos.length > 1 ? '' : 'none';
        lb.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
        const lightbox = document.getElementById('lightbox');
        if (lightbox) lightbox.style.display = 'none';
        document.body.style.overflow = '';
    }

    function navigateLightbox(dir) {
        const newIndex = (lightboxIndex + dir + galleryPhotos.length) % galleryPhotos.length;
        openLightbox(newIndex);
    }

    function handleLightboxKey(e) {
        const lb = document.getElementById('lightbox');
        if (!lb || lb.classList.contains('hidden')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') navigateLightbox(-1);
        if (e.key === 'ArrowRight') navigateLightbox(1);
    }

    async function loadPhotos(productId, token, fallbackUrl) {
        const headers = token ? { 'Authorization': 'Bearer ' + token } : {};
        try {
            const res = await fetch(`${API_BASE}/fotos-producto/producto/${productId}`, { headers });
            if (res.ok) {
                const photos = await res.json();
                const urls = photos.map(f => BACKEND_BASE + f.urlFoto);
                buildGallery(urls, fallbackUrl);
            } else {
                buildGallery([], fallbackUrl);
            }
        } catch {
            buildGallery([], fallbackUrl);
        }
    }

    // ── Main ─────────────────────────────────────────────────────────────────

    async function loadProduct() {
        const id = new URLSearchParams(location.search).get('id');
        if (!id) { showNotFound(); return; }

        const token = localStorage.getItem('ufvshares_token');
        const headers = token ? { 'Authorization': 'Bearer ' + token } : {};

        try {
            const res = await fetch(`${API_BASE}/productos/${id}`, { headers });
            if (!res.ok) { showNotFound(); return; }
            const p = await res.json();
            await renderProduct(p, token);

            // Cargar detalles de transacción activa si el producto no está disponible
            if (p.estadoProducto === 'VENDIDO' || p.estadoProducto === 'ALQUILADO' || p.estadoProducto === 'NO_DISPONIBLE') {
                loadTransaccionActiva(id);
            }
        } catch (e) {
            showNotFound();
            console.error(e);
        }
    }

    async function loadTransaccionActiva(productId) {
        try {
            const res = await fetch(`${API_BASE}/transacciones/producto/${productId}`);
            if (!res.ok || res.status === 204) return;
            const t = await res.json();
            renderTransaccionBanner(t);
        } catch (e) {
            console.error('Error cargando transacción activa', e);
        }
    }

    function renderTransaccionBanner(t) {
        const tipo = t.tipoTransaccion;
        const banner = document.getElementById('unavailability-banner');
        const rentalDates = document.getElementById('rental-dates');

        if (!banner) return;

        if (tipo === 'VENTA') {
            banner.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                </svg>
                <span class="text-red-700">Este producto ya ha sido <strong>vendido</strong> y no está disponible.</span>`;
            banner.className = 'rounded-2xl p-4 border border-red-200 bg-red-50 font-semibold text-sm flex items-start gap-3';
            banner.style.display = 'flex';
        } else {
            // ALQUILER o PRESTAMO
            const fmtDate = (iso) => {
                if (!iso) return 'No especificada';
                return new Date(iso).toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' });
            };
            banner.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class="text-amber-700">Este producto está actualmente <strong>${tipo === 'PRESTAMO' ? 'en préstamo' : 'alquilado'}</strong> y no está disponible hasta que se devuelva.</span>`;
            banner.className = 'rounded-2xl p-4 border border-amber-200 bg-amber-50 font-semibold text-sm flex items-start gap-3';
            banner.style.display = 'flex';

            // Mostrar fechas
            if (rentalDates) {
                const startEl = document.getElementById('rental-start');
                const endEl = document.getElementById('rental-end');
                if (startEl) startEl.textContent = fmtDate(t.fechaInicio);
                if (endEl) endEl.textContent = fmtDate(t.fechaDevolucion);
                rentalDates.style.display = 'block';
            }
        }
    }

    function disableCtaButtons() {
        const contactBtn = document.getElementById('contact-btn');
        const reserveBtn = document.getElementById('reserve-btn');
        if (contactBtn) {
            contactBtn.removeAttribute('href');
            contactBtn.setAttribute('disabled', 'true');
            contactBtn.className = contactBtn.className.replace('btn-primary', 'btn-disabled');
            const label = document.getElementById('contact-btn-label');
            if (label) label.textContent = 'No disponible';
        }
        if (reserveBtn) {
            reserveBtn.setAttribute('disabled', 'true');
            reserveBtn.classList.add('btn-disabled');
        }
    }

    function showNotFound() {
        document.getElementById('product-loading')?.classList.add('hidden');
        document.getElementById('product-not-found')?.classList.remove('hidden');
    }

    async function renderProduct(p, token) {
        const fallbackImg = getImageUrl(p);
        const title = p.titulo || 'Sin título';
        const price = (p.precio == null || Number(p.precio) === 0) ? 'Gratis' : new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(Number(p.precio));
        const category = (p.categoria || '').replace(/_/g, ' ');
        const tipo = p.tipoTransaccion === 'ALQUILER' ? 'Alquiler' : 'Venta';
        const id = p.idProducto;
        let isOwner = false;

        // Breadcrumb
        const bcCat = document.getElementById('bc-category');
        const bcTitle = document.getElementById('bc-title');
        if (bcCat) {
            bcCat.innerHTML = `<a href="/category/${(p.categoria || 'otros').toLowerCase()}" class="hover:text-primary">${category}</a>`;
            bcCat.classList.remove('text-slate-300');
        }
        if (bcTitle) bcTitle.textContent = title;
        document.title = `${title} | UFV Shares`;

        // Badge
        document.getElementById('product-badge-tipo').textContent = tipo;

        // Text
        document.getElementById('product-category').textContent = category;
        document.getElementById('product-title').textContent = title;
        document.getElementById('product-price').textContent = price;
        document.getElementById('product-desc').textContent = p.descripcion || '';
        const sellerPriceCompare = document.getElementById('seller-price-compare');
        if (sellerPriceCompare) sellerPriceCompare.textContent = price;

        const amazonLink = document.getElementById('marketplace-amazon-link');
        const keepaLink = document.getElementById('marketplace-keepa-link');
        if (amazonLink) amazonLink.setAttribute('href', getAmazonSearchUrl(p));
        if (keepaLink) keepaLink.setAttribute('href', getKeepaSearchUrl(p));

        const onlineRef = getOnlineReferencePrice(p);
        const onlineRefEl = document.getElementById('online-price-reference');
        const onlineRefRow = document.getElementById('online-price-reference-row');
        if (onlineRefEl) {
            onlineRefEl.textContent = onlineRef === null
                ? 'No disponible'
                : new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(onlineRef);
        }
        if (onlineRefRow) {
            onlineRefRow.classList.toggle('hidden', onlineRef === null);
        }

        await loadMarketplaceData(id, p);

        // Stats row
        const statFecha = document.getElementById('stat-fecha');
        const statVistas = document.getElementById('stat-vistas');
        if (statFecha) {
            if (p.fechaPublicacion) {
                const d = new Date(p.fechaPublicacion);
                statFecha.textContent = d.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
            } else {
                statFecha.textContent = '—';
            }
        }
        if (statVistas) statVistas.textContent = p.vistas ?? p.numVisitas ?? '—';

        // Meta chips
        const meta = document.getElementById('product-meta');
        if (meta) {
            const chips = [];
            if (p.condicion)      chips.push(chip('Condición',  p.condicion,      'bg-sky-50 border-sky-200 text-sky-700'));
            if (p.ubicacion)      chips.push(chip('Ubicación',  p.ubicacion,      'bg-amber-50 border-amber-200 text-amber-700'));
            if (p.estadoProducto) {
                const estadoColors = {
                    DISPONIBLE:    'bg-emerald-50 border-emerald-200 text-emerald-700',
                    VENDIDO:       'bg-red-50 border-red-200 text-red-700',
                    ALQUILADO:     'bg-amber-50 border-amber-200 text-amber-700',
                    RESERVADO:     'bg-blue-50 border-blue-200 text-blue-700',
                    NO_DISPONIBLE: 'bg-slate-100 border-slate-300 text-slate-500',
                };
                const labels = {
                    DISPONIBLE:    'Disponible',
                    VENDIDO:       'Vendido',
                    ALQUILADO:     'Alquilado',
                    RESERVADO:     'Reservado',
                    NO_DISPONIBLE: 'No disponible',
                };
                const color = estadoColors[p.estadoProducto] ?? 'bg-emerald-50 border-emerald-200 text-emerald-700';
                const label = labels[p.estadoProducto] ?? p.estadoProducto;
                chips.push(chip('Estado', label, color));
            }
            meta.innerHTML = chips.join('');
        }

        // Deshabilitar CTAs si el producto no está disponible
        const noDisponible = ['VENDIDO', 'ALQUILADO', 'NO_DISPONIBLE'].includes(p.estadoProducto);
        if (noDisponible) {
            disableCtaButtons();
        }

        if (token && p.idPropietario) {
            try {
                const meRes = await fetch(API_BASE + '/me', {
                    headers: { 'Authorization': 'Bearer ' + token },
                });
                if (meRes.ok) {
                    const me = await meRes.json();
                    isOwner = Number(me?.idUsuario) === Number(p.idPropietario);
                }
            } catch {
                isOwner = false;
            }
        }

        // Favorites data
        const favData = JSON.stringify({ id: String(id), name: title, price: p.precio ?? 0, image: fallbackImg, stock: 1, slug: String(id) });
        document.getElementById('add-fav-btn').dataset.favorite = favData;

        // Seller info
        const roleLabel = p.tipoTransaccion === 'ALQUILER' ? 'Arrendador' : 'Vendedor';
        const sellerRoleEl = document.getElementById('seller-role-label');
        const sellerCard = document.getElementById('seller-card');
        if (sellerRoleEl) sellerRoleEl.textContent = roleLabel;

        const contactBtn = document.getElementById('contact-btn');
        const contactBtnLabel = document.getElementById('contact-btn-label');
        const sellerContactQuick = document.getElementById('seller-contact-quick');
        const reserveBtn = document.getElementById('reserve-btn');
        const addFavBtn = document.getElementById('add-fav-btn');
        const reportBtn = document.getElementById('report-product-btn');
        if (contactBtnLabel) contactBtnLabel.textContent = `Contactar al ${p.tipoTransaccion === 'ALQUILER' ? 'arrendador' : 'vendedor'}`;

        if (isOwner) {
            contactBtn?.classList.add('hidden');
            reserveBtn?.classList.add('hidden');
            sellerContactQuick?.classList.add('hidden');
            addFavBtn?.classList.add('hidden');
            reportBtn?.classList.add('hidden');
            document.getElementById('my-requests-panel')?.classList.add('hidden');
            await loadOwnerProductRequests(id, token);
            setupOwnerRequestsActions(id, token);
        } else if (token) {
            document.getElementById('owner-requests-panel')?.classList.add('hidden');
            await loadMyRequestsForProduct(id, token);
        } else {
            document.getElementById('owner-requests-panel')?.classList.add('hidden');
            document.getElementById('my-requests-panel')?.classList.add('hidden');
        }

        if (reportBtn) {
            reportBtn.classList.toggle('hidden', isOwner || !p.idPropietario);
            reportBtn.onclick = () => {
                if (!token) {
                    window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                    return;
                }
                openReportProductModal();
            };
        }

        if (reserveBtn) {
            reserveBtn.classList.toggle('hidden', noDisponible || isOwner);
            reserveBtn.onclick = async () => {
                if (!token) {
                    window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                    return;
                }
                const reserveChoice = await openReserveConfirmModal(p.tipoTransaccion);
                if (!reserveChoice?.confirmed) return;

                reserveBtn.setAttribute('disabled', 'true');
                const prevText = reserveBtn.textContent;
                reserveBtn.textContent = 'Enviando solicitud...';
                try {
                    const body = p.tipoTransaccion === 'ALQUILER'
                        ? { fechaFin: reserveChoice.fechaFin }
                        : {};
                    const res = await fetch(API_BASE + '/solicitudes/reservar/' + id, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                        body: JSON.stringify(body),
                    });
                    if (res.ok) {
                        await showReserveFeedbackModal('Tu solicitud se ha enviado al vendedor. Podrás ver su estado en tu perfil.', 'success');
                        reserveBtn.textContent = 'Solicitud enviada';
                        reserveBtn.setAttribute('disabled', 'true');
                        return;
                    }

                    const raw = await res.text().catch(() => '');
                    let msg = 'No se pudo completar la reserva.';
                    if (res.status === 401) {
                        msg = 'Tu sesión ha caducado. Vuelve a iniciar sesión.';
                    } else if (res.status === 409) {
                        msg = 'Ya tienes una solicitud activa para este artículo o ya no está disponible.';
                    } else if (res.status === 404) {
                        msg = 'No se encontró el endpoint de solicitudes en el backend. Reinicia el backend y vuelve a intentarlo.';
                    }

                    if (raw) {
                        try {
                            const parsed = JSON.parse(raw);
                            msg = parsed?.message ?? parsed?.error ?? msg;
                        } catch {
                            if (raw.includes('No static resource')) {
                                msg = 'El backend no tiene cargado el endpoint de solicitudes. Reinicia la API y vuelve a probar.';
                            }
                        }
                    }
                    await showReserveFeedbackModal(msg, 'error');
                } catch {
                    await showReserveFeedbackModal('No se pudo conectar con el servidor para enviar la solicitud.', 'error');
                } finally {
                    if (reserveBtn.textContent !== 'Solicitud enviada') {
                        reserveBtn.removeAttribute('disabled');
                        reserveBtn.textContent = prevText;
                    }
                }
            };
        }

        // Fetch owner info (fire-and-forget – button wiring happens below regardless)
        if (p.idPropietario) {
            const ownerHeaders = token ? { 'Authorization': 'Bearer ' + token } : {};
            fetch(`${API_BASE}/usuarios/${p.idPropietario}/public`, { headers: ownerHeaders })
                .then(r => r.ok ? r.json() : null)
                .then(owner => {
                    if (!owner) return;
                    const fullName = [owner.nombre, owner.apellidos].filter(Boolean).join(' ');
                    const sellerNameEl = document.getElementById('seller-name');
                    const sellerEmailEl = document.getElementById('seller-email');
                    const avatarImg = document.getElementById('seller-avatar');
                    const avatarPlaceholder = document.getElementById('seller-avatar-placeholder');
                    if (sellerNameEl) sellerNameEl.textContent = fullName || '—';
                    if (sellerEmailEl) sellerEmailEl.textContent = owner.correo || '';
                    if (owner.fotoPerfil && avatarImg) {
                        avatarImg.src = BACKEND_BASE + owner.fotoPerfil;
                        avatarImg.classList.remove('hidden');
                        avatarPlaceholder?.classList.add('hidden');
                    }
                    sellerCard?.classList.remove('hidden');
                })
                .catch(() => {});
        }

        // Wire up contact buttons – always, regardless of whether owner info loaded
        if (!isOwner && p.idPropietario && contactBtn && !contactBtn.hasAttribute('disabled')) {
            contactBtn.removeAttribute('href');
            contactBtn.addEventListener('click', async function handleContact(e) {
                e.preventDefault();
                if (!token) {
                    window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                    return;
                }
                const btn = e.currentTarget;
                btn.setAttribute('aria-disabled', 'true');
                const labelEl = document.getElementById('contact-btn-label');
                const prevLabel = labelEl ? labelEl.textContent : '';
                if (labelEl) labelEl.textContent = 'Abriendo…';
                try {
                    const res = await fetch(API_BASE + '/chats', {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                        body: JSON.stringify({ idProducto: id, idOtroUsuario: p.idPropietario })
                    });
                    if (res.ok) {
                        const conv = await res.json();
                        window.location.href = '/chats?conv=' + conv.idConversacion;
                    } else if (res.status === 401) {
                        window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                    } else if (res.status === 400) {
                        await showReserveFeedbackModal('No puedes contactar con tu propio anuncio.', 'error');
                        btn.removeAttribute('aria-disabled');
                        if (labelEl) labelEl.textContent = prevLabel;
                    } else {
                        const errText = await res.text().catch(() => res.status);
                        console.error('Chat API error', res.status, errText);
                        await showReserveFeedbackModal('Error al abrir el chat (' + res.status + '). Intentalo de nuevo en unos segundos.', 'error');
                        btn.removeAttribute('aria-disabled');
                        if (labelEl) labelEl.textContent = prevLabel;
                    }
                } catch (err) {
                    console.error('Chat fetch error', err);
                    const msg = err instanceof Error ? err.message : 'Error de red';
                    await showReserveFeedbackModal('No se pudo conectar con el servidor: ' + msg, 'error');
                    btn.removeAttribute('aria-disabled');
                    if (labelEl) labelEl.textContent = prevLabel;
                }
            });
        }
        if (!isOwner && p.idPropietario && sellerContactQuick && !sellerContactQuick.hasAttribute('disabled')) {
            sellerContactQuick.removeAttribute('href');
            sellerContactQuick.addEventListener('click', async function handleContactQuick(e) {
                e.preventDefault();
                if (!token) {
                    window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                    return;
                }
                try {
                    const res = await fetch(API_BASE + '/chats', {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                        body: JSON.stringify({ idProducto: id, idOtroUsuario: p.idPropietario })
                    });
                    if (res.ok) {
                        const conv = await res.json();
                        window.location.href = '/chats?conv=' + conv.idConversacion;
                    } else if (res.status === 401) {
                        window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                    } else if (res.status === 400) {
                        await showReserveFeedbackModal('No puedes contactar con tu propio anuncio.', 'error');
                    } else {
                        const errText = await res.text().catch(() => '');
                        console.error('Chat API error', res.status, errText);
                        await showReserveFeedbackModal('Error al abrir el chat (' + res.status + '). Intentalo de nuevo en unos segundos.', 'error');
                    }
                } catch (err) {
                    console.error('Chat fetch error', err);
                    await showReserveFeedbackModal('No se pudo conectar con el servidor.', 'error');
                }
            });
        }

        const reportModal = document.getElementById('report-product-modal');
        const reportForm = document.getElementById('report-product-form');
        const reportCancel = document.getElementById('report-product-cancel');
        const reportSubmit = document.getElementById('report-product-submit');
        const reportError = document.getElementById('report-product-error');

        reportCancel?.addEventListener('click', closeReportProductModal);
        reportModal?.addEventListener('click', (event) => {
            if (event.target === reportModal) closeReportProductModal();
        });
        reportForm?.addEventListener('submit', async (event) => {
            event.preventDefault();
            if (!token) {
                window.location.href = '/auth?mode=login&next=' + encodeURIComponent(window.location.pathname + window.location.search);
                return;
            }

            const reasonValue = (document.getElementById('report-product-reason') instanceof HTMLSelectElement)
                ? document.getElementById('report-product-reason').value.trim()
                : '';
            const commentValue = (document.getElementById('report-product-comment') instanceof HTMLTextAreaElement)
                ? document.getElementById('report-product-comment').value.trim()
                : '';

            if (!reasonValue) {
                if (reportError) reportError.textContent = 'Selecciona un motivo.';
                return;
            }

            if (reportError) reportError.textContent = '';
            if (reportSubmit instanceof HTMLButtonElement) {
                reportSubmit.disabled = true;
                reportSubmit.textContent = 'Enviando...';
            }

            try {
                const meRes = await fetch(API_BASE + '/me', { headers: { 'Authorization': 'Bearer ' + token } });
                if (!meRes.ok) {
                    await showReserveFeedbackModal('Tu sesión ha caducado. Vuelve a iniciar sesión.', 'error');
                    return;
                }
                const me = await meRes.json();
                const res = await fetch(API_BASE + '/reportes-producto', {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        idUsuarioReportante: me.idUsuario,
                        idProductoReportado: Number(id),
                        motivo: reasonValue,
                        comentario: commentValue || null,
                    }),
                });

                if (!res.ok) {
                    const raw = await res.text().catch(() => '');
                    let message = 'No se pudo enviar el reporte.';
                    if (raw) {
                        try {
                            const parsed = JSON.parse(raw);
                            message = parsed?.message ?? parsed?.error ?? message;
                        } catch {
                            message = raw;
                        }
                    }
                    await showReserveFeedbackModal(message, 'error');
                    return;
                }

                closeReportProductModal();
                await showReserveFeedbackModal('Reporte enviado correctamente. Gracias por avisarnos.', 'success');
            } catch {
                await showReserveFeedbackModal('No se pudo conectar con el servidor.', 'error');
            } finally {
                if (reportSubmit instanceof HTMLButtonElement) {
                    reportSubmit.disabled = false;
                    reportSubmit.textContent = 'Enviar reporte';
                }
            }
        });

        // Load photos before showing the detail (elements exist in DOM even when hidden)
        await loadPhotos(id, token, fallbackImg);

        // Show detail only once photos are ready — avoids the placeholder flash
        document.getElementById('product-loading')?.classList.add('hidden');
        const detail = document.getElementById('product-detail');
        if (detail) detail.style.display = 'grid';

        // Reinit favorites listeners
        document.dispatchEvent(new CustomEvent('view:product-loaded'));
    }

    loadProduct();
</script>

<script>
    import { toggleFavorite, isFavorite, favoriteItems } from '../../store/favoriteStore';
    import { toast } from 'sonner';

    let storeUnsubscribe: (() => void) | null = null;

    function updateFavBtn() {
        const favBtn = document.getElementById('add-fav-btn') as HTMLButtonElement | null;
        if (!favBtn) return;
        const fav = JSON.parse(favBtn.getAttribute('data-favorite') || '{}');
        if (!fav.id) return;
        const isFav = isFavorite(fav.id);
        const svg = favBtn.querySelector('svg');
        if (isFav) {
            svg?.classList.add('fill-current');
            favBtn.classList.add('btn-primary');
            favBtn.classList.remove('btn-outline');
        } else {
            svg?.classList.remove('fill-current');
            favBtn.classList.remove('btn-primary');
            favBtn.classList.add('btn-outline');
        }
    }

    function setupViewListeners() {
        const favBtn = document.getElementById('add-fav-btn') as HTMLButtonElement | null;
        if (!favBtn) return;

        // Remove old listener flag so it re-binds on each page load
        favBtn.removeAttribute('data-listener');

        if (!favBtn.getAttribute('data-listener')) {
            favBtn.addEventListener('click', async () => {
                const fav = JSON.parse(favBtn.getAttribute('data-favorite') || '{}');
                if (!fav.id) {
                    toast.error('Producto no cargado aún');
                    return;
                }
                const result = await toggleFavorite(fav);
                if (result.success) toast.success(result.message);
                else toast.error(result.message);
                updateFavBtn();
            });
            favBtn.setAttribute('data-listener', 'true');
        }

        // Unsubscribe previous subscription to avoid duplicates
        if (storeUnsubscribe) storeUnsubscribe();
        storeUnsubscribe = favoriteItems.subscribe(() => updateFavBtn());
    }

    // Run immediately (handles case where event fired before module loaded)
    setupViewListeners();

    // Run when product data is ready
    document.addEventListener('view:product-loaded', () => {
        setupViewListeners();
        updateFavBtn();
    });

    // Run on Astro page transitions
    document.addEventListener('astro:page-load', () => {
        setupViewListeners();
        updateFavBtn();
    });
</script>
