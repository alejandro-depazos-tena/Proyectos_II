---
import Layout from "../layouts/Layout.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
const GOOGLE_BOOKS_KEY = import.meta.env.PUBLIC_GOOGLE_BOOKS_KEY ?? "";
---

<Layout title="Mi perfil · UFV Shares">
  <div class="max-w-6xl mx-auto px-4 py-8 lg:py-10 space-y-8">

    <!-- ── Perfil ────────────────────────────────────────────── -->
    <div id="profile-card" class="hidden">
      <div class="grid grid-cols-1 xl:grid-cols-[1.5fr_1fr] gap-5">
        <div class="bg-base-100 border border-base-200 rounded-2xl shadow-sm p-6 flex flex-col sm:flex-row gap-6 items-center sm:items-start">

        <!-- Avatar con botón de edición flotante -->
        <div class="relative shrink-0 group">
          <div id="avatar-circle"
            class="w-20 h-20 rounded-2xl bg-primary text-primary-content
                   flex items-center justify-center text-3xl font-black overflow-hidden shadow-md ring-4 ring-base-100">
          </div>
          <label for="avatar-input"
            class="absolute -bottom-1.5 -right-1.5 w-7 h-7 rounded-full bg-base-content text-base-100
                   flex items-center justify-center cursor-pointer shadow-md
                   hover:scale-110 transition-transform"
            title="Cambiar foto">
            <span class="sr-only">Cambiar foto de perfil</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86
                a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5
                a2 2 0 01-2-2V9z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </label>
          <input id="avatar-input" type="file" accept="image/*" class="hidden" />
          <div id="avatar-uploading"
            class="absolute inset-0 rounded-2xl bg-base-content/60 hidden items-center justify-center">
            <span class="loading loading-spinner loading-xs text-base-100"></span>
          </div>
        </div>

          <!-- Datos -->
          <div class="flex-1 min-w-0 text-center sm:text-left">
            <p class="text-xs uppercase tracking-[0.16em] text-base-content/45 mb-1">Mi perfil</p>
            <h1 id="profile-name" class="text-2xl font-bold leading-snug"></h1>
            <p id="profile-email" class="text-base-content/55 text-sm mt-1"></p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-5 text-sm">
              <div class="rounded-xl bg-base-200/70 border border-base-200 p-3 text-left">
                <p class="text-[11px] uppercase tracking-wide text-base-content/50 mb-1">Teléfono</p>
                <div class="flex items-center gap-1.5 text-base-content/80">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary shrink-0" fill="none"
                    viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21
                      l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502
                      l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <span id="profile-telefono"></span>
                </div>
              </div>

              <div class="rounded-xl bg-base-200/70 border border-base-200 p-3 text-left">
                <p class="text-[11px] uppercase tracking-wide text-base-content/50 mb-1">DNI</p>
                <div class="flex items-center gap-1.5 text-base-content/80">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary shrink-0" fill="none"
                    viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5
                      m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4z" />
                  </svg>
                  <span id="profile-dni"></span>
                </div>
              </div>
            </div>

            <!-- Acción editar -->
            <div class="mt-5 sm:mt-4">
              <button id="btn-edit-profile"
                class="btn btn-outline btn-sm rounded-full gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
                  viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5
                    m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
                Editar datos
              </button>
            </div>
          </div>
        </div>

        <aside class="bg-base-100 border border-base-200 rounded-2xl shadow-sm p-5 sm:p-6 flex flex-col gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.16em] text-base-content/45">Resumen</p>
            <p class="text-sm text-base-content/65 mt-1">Vista rápida del estado de tu cuenta y seguridad.</p>
          </div>

          <div class="rounded-xl bg-primary/10 border border-primary/20 p-4">
            <p class="text-[11px] uppercase tracking-wide text-base-content/55">Productos publicados</p>
            <div class="flex items-baseline gap-2 mt-1">
              <span id="profile-prods-count" class="text-3xl font-black text-primary leading-none">0</span>
              <span class="text-sm text-base-content/70">activos</span>
            </div>
          </div>

          <div class="rounded-xl bg-base-200/60 border border-base-200 p-4 text-sm text-left">
            <p class="text-xs uppercase tracking-wide text-base-content/50 mb-1">Pregunta de seguridad</p>
            <p id="profile-security-question" class="font-semibold text-base-content/80">No configurada</p>
            <p class="text-xs text-base-content/55 mt-2">Actualízala desde “Editar datos” para facilitar la recuperación de contraseña.</p>
          </div>

          <div class="pt-1">
            <button type="button" id="btn-edit-profile-secondary" class="btn btn-ghost btn-sm rounded-full w-full">Gestionar datos de cuenta</button>
          </div>
        </aside>
      </div>
    </div>

    <!-- ── Drawer edición de perfil ──────────────────────────── -->
    <div id="edit-profile-overlay"
      class="fixed inset-0 z-[1200] bg-black/50 hidden items-end sm:items-center justify-center p-4
             transition-opacity">
      <div id="edit-profile-panel"
        class="relative z-[1210] bg-base-100 rounded-2xl shadow-2xl w-full max-w-md flex flex-col gap-0
               overflow-hidden transform translate-y-4 transition-transform">

        <!-- Header -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-base-200">
          <h2 class="font-bold text-lg">Editar datos del perfil</h2>
          <button id="btn-close-edit" class="btn btn-ghost btn-sm btn-circle text-lg">&times;</button>
        </div>

        <!-- Step 1: formulario -->
        <div id="edit-step-form" class="relative z-[1220] px-6 py-5 flex flex-col gap-4">
          <p class="text-sm text-base-content/60">
            Selecciona el dato que quieres cambiar y guarda. El cambio se aplica al momento.
          </p>

          <div>
            <label for="edit-campo" class="label pb-1"><span class="label-text font-semibold">Campo a cambiar</span></label>
            <select id="edit-campo" class="select select-bordered w-full">
              <option value="nombre">Nombre</option>
              <option value="apellidos">Apellidos</option>
              <option value="telefono">Tel&eacute;fono</option>
            </select>
          </div>

          <div>
            <label for="edit-valor" class="label pb-1">
              <span class="label-text font-semibold">Nuevo valor</span>
            </label>
            <input id="edit-valor" type="text" class="input input-bordered w-full"
              placeholder="Introduce el nuevo valor..." maxlength="150" />
          </div>

          <p id="edit-error" class="text-error text-sm hidden"></p>

          <div class="flex gap-3 justify-end pt-1">
            <button type="button" id="btn-edit-cancel" class="btn btn-ghost btn-sm">Cancelar</button>
            <button type="button" id="btn-edit-submit" class="btn btn-primary btn-sm rounded-full gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
                viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7
                  a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Guardar cambio
            </button>
          </div>

          <div class="divider my-1">Seguridad</div>

          <p class="text-sm text-base-content/60">
            Puedes cambiar aquí tu pregunta y respuesta de seguridad para recuperar contraseña.
          </p>

          <p id="edit-security-current" class="text-sm text-base-content/70">
            Pregunta actual: No configurada
          </p>

          <div>
            <label for="edit-security-question" class="label pb-1"><span class="label-text font-semibold">Nueva pregunta de seguridad</span></label>
            <select id="edit-security-question" class="select select-bordered w-full">
              <option value="">Selecciona una pregunta</option>
              <option value="¿Cuál es el nombre de tu primera mascota?">¿Cuál es el nombre de tu primera mascota?</option>
              <option value="¿Cuál es tu ciudad de nacimiento?">¿Cuál es tu ciudad de nacimiento?</option>
              <option value="¿Cuál es tu comida favorita?">¿Cuál es tu comida favorita?</option>
              <option value="¿Cuál fue tu primer colegio?">¿Cuál fue tu primer colegio?</option>
            </select>
          </div>

          <div>
            <label for="edit-security-answer" class="label pb-1"><span class="label-text font-semibold">Nueva respuesta de seguridad</span></label>
            <input id="edit-security-answer" type="text" class="input input-bordered w-full" placeholder="Tu respuesta" maxlength="255" />
          </div>

          <p id="edit-security-error" class="text-error text-sm hidden"></p>

          <div class="flex gap-3 justify-end pt-1">
            <button type="button" id="btn-security-submit" class="btn btn-secondary btn-sm rounded-full">Guardar seguridad</button>
          </div>
        </div>

        <!-- Step 2: éxito -->
        <div id="edit-step-ok" class="hidden px-6 py-8 flex flex-col items-center gap-4 text-center">
          <div class="w-14 h-14 rounded-full bg-success/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-success" fill="none"
              viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-bold text-lg">Correo enviado</p>
            <p id="edit-ok-msg" class="text-sm text-base-content/60 mt-1"></p>
          </div>
          <button id="btn-edit-ok-close" class="btn btn-primary btn-sm rounded-full mt-2">Entendido</button>
        </div>

      </div>
    </div>

    <!-- ── Toast de notificación ────────────────────────────── -->
    <div id="profile-toast"
      class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[950] transition-all duration-300
             opacity-0 pointer-events-none translate-y-4">
      <div id="profile-toast-inner"
        class="flex items-center gap-3 px-5 py-3 rounded-full shadow-xl text-sm font-semibold
               bg-success text-success-content">
        <svg id="profile-toast-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none"
          viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        <span id="profile-toast-msg"></span>
      </div>
    </div>

    <!-- Navegación rápida de secciones -->
    <div class="bg-base-100 border border-base-200 rounded-2xl p-4 shadow-sm">
      <p class="text-xs uppercase tracking-[0.16em] text-base-content/45 mb-1">Áreas del perfil</p>
      <p class="text-sm text-base-content/60 mb-3">Selecciona qué quieres gestionar ahora.</p>
      <div class="flex gap-2 overflow-x-auto pb-1">
        <button type="button" data-section-btn="productos" class="btn btn-sm rounded-full shrink-0" title="Gestionar anuncios publicados">Mis anuncios</button>
        <button type="button" data-section-btn="reservas" class="btn btn-sm rounded-full btn-ghost shrink-0" title="Ver tus reservas y compras">Reservas y compras</button>
        <button type="button" data-section-btn="solicitudes" class="btn btn-sm rounded-full btn-ghost shrink-0" title="Solicitudes enviadas y recibidas">Solicitudes de intercambio</button>
        <button type="button" data-section-btn="historial" class="btn btn-sm rounded-full btn-ghost shrink-0" title="Historial de ventas y alquileres">Historial de actividad</button>
        <button type="button" data-section-btn="contratos" class="btn btn-sm rounded-full btn-ghost shrink-0" title="Contratos generados y firmados">Contratos y firma</button>
      </div>
    </div>

    <!-- Sección: Mis productos -->
    <section id="section-productos" class="profile-section">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-black uppercase tracking-tighter">Mis anuncios publicados</h2>
        <button id="btn-toggle-form" class="btn btn-primary btn-sm rounded-full hidden">
          + Publicar producto
        </button>
      </div>

      <!-- Formulario publicar -->
      <div id="publish-form-wrap" class="card bg-base-100 shadow-md border border-base-200 mb-8 hidden">
        <div class="card-body">
          <h3 class="font-bold text-lg mb-4">Nuevo anuncio</h3>
          <form id="publish-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="sm:col-span-2">
            <label for="pub-titulo" class="label"><span class="label-text font-semibold">T&iacute;tulo</span></label>
            <input id="pub-titulo" name="titulo" type="text" required maxlength="150"
              class="input input-bordered w-full" placeholder="Ej: Libro de &Aacute;lgebra 3ª ed." />
          </div>
          <div class="sm:col-span-2">
            <label for="pub-descripcion" class="label"><span class="label-text font-semibold">Descripci&oacute;n</span></label>
            <textarea id="pub-descripcion" name="descripcion" required rows="3"
              class="textarea textarea-bordered w-full" placeholder="Estado, detalles, forma de entrega..."></textarea>
          </div>
          <div>
            <label for="pub-categoria" class="label"><span class="label-text font-semibold">Categor&iacute;a</span></label>
            <select id="pub-categoria" name="categoria" required class="select select-bordered w-full">
              <option value="">Elige una...</option>
              <option value="LIBROS">Libros</option>
              <option value="ELECTRONICA">Electr&oacute;nica</option>
              <option value="DEPORTE">Deporte</option>
              <option value="HOGAR">Hogar</option>
              <option value="OTROS">Otros</option>
            </select>
          </div>
          <div>
            <label for="pub-tipo-transaccion" class="label"><span class="label-text font-semibold">Tipo</span></label>
            <select id="pub-tipo-transaccion" name="tipoTransaccion" required class="select select-bordered w-full">
              <option value="">Elige uno...</option>
              <option value="VENTA">Venta</option>
              <option value="ALQUILER">Alquiler</option>
              <option value="PRESTAMO">Pr&eacute;stamo</option>
            </select>
          </div>
          <!-- ── Google Books lookup (visible sólo cuando categoría = LIBROS) ── -->
          <div id="books-lookup" class="sm:col-span-2 hidden">
            <div class="rounded-xl border border-blue-200 bg-blue-50/60 p-4 flex flex-col gap-3">
              <div class="flex flex-wrap items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 shrink-0"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                <span class="font-bold text-sm text-blue-700">Autocompletar con Google Books</span>
                <span class="text-xs text-blue-500 ml-auto hidden sm:inline">Rellena el t&iacute;tulo y descripci&oacute;n autom&aacute;ticamente</span>
              </div>
              <div class="flex gap-2">
                <label for="books-query" class="sr-only">Buscar libro por ISBN o t&iacute;tulo</label>
                <input id="books-query" type="text"
                  placeholder="ISBN (ej. 9788420412337) o t&iacute;tulo del libro…"
                  class="input input-sm input-bordered flex-1 bg-white text-sm" />
                <button type="button" id="btn-books-search"
                  class="btn btn-sm btn-primary gap-1.5 shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                  Buscar
                </button>
              </div>
              <!-- Resultados de búsqueda -->
              <div id="books-results" class="hidden flex-col gap-1 max-h-56 overflow-y-auto rounded-lg border border-blue-100 bg-white divide-y divide-blue-50"></div>
              <!-- Libro seleccionado -->
              <div id="books-selected" class="hidden items-center gap-2 text-sm bg-blue-100 text-blue-800 rounded-lg px-3 py-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-500"><path d="M20 6 9 17l-5-5"/></svg>
                <span id="books-selected-title" class="flex-1 font-medium truncate"></span>
                <button type="button" id="btn-books-clear"
                  class="shrink-0 w-5 h-5 rounded-full hover:bg-blue-200 flex items-center justify-center text-blue-500 hover:text-blue-800 transition-colors">&times;</button>
              </div>
            </div>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1">
              <label for="precio-input" class="label py-0"><span class="label-text font-semibold">Precio (&euro;)</span></label>
              <label class="flex items-center gap-2 cursor-pointer select-none">
                <input type="checkbox" id="precio-gratis-cb" class="checkbox checkbox-primary checkbox-sm" />
                <span class="text-sm font-semibold text-primary">Gratis</span>
              </label>
            </div>
            <input id="precio-input" name="precio" type="number" min="0" step="0.01"
              class="input input-bordered w-full" placeholder="0.00" />
          </div>
          <div>
            <label for="pub-condicion" class="label"><span class="label-text font-semibold">Condici&oacute;n del art&iacute;culo</span></label>
            <select id="pub-condicion" name="condicion" required class="select select-bordered w-full">
              <option value="">Elige una...</option>
              <option value="NUEVO">Nuevo</option>
              <option value="COMO_NUEVO">Como nuevo</option>
              <option value="BUENO">Buen estado</option>
              <option value="ACEPTABLE">Aceptable</option>
              <option value="DETERIORADO">Deteriorado</option>
            </select>
          </div>
          <!-- Fotos -->
          <div class="sm:col-span-2">
            <label for="foto-input" class="label">
              <span class="label-text font-semibold">Fotos del producto <span class="text-error">*</span></span>
              <span class="label-text-alt text-base-content/50">M&iacute;nimo 1 &middot; JPG / PNG / WebP &middot; m&aacute;x. 10 MB por foto</span>
            </label>
            <!-- Drop zone (gallery / files) -->
            <div id="foto-label" role="button" tabindex="0" aria-controls="foto-input" aria-label="Seleccionar fotos del producto"
              class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-base-300 rounded-xl cursor-pointer hover:border-primary hover:bg-base-200/50 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-base-content/40 mb-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5V19a2 2 0 002 2h14a2 2 0 002-2v-2.5M16 10l-4-4m0 0L8 10m4-4v12" />
              </svg>
              <span id="foto-label-text" class="text-sm text-base-content/50">Haz clic o arrastra im&aacute;genes aqu&iacute;</span>
            </div>
            <input id="foto-input" type="file" multiple accept="image/*" class="hidden" />
            <!-- Camera button -->
            <button type="button" id="btn-camera"
              class="btn btn-outline btn-sm rounded-full mt-3 gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Tomar foto
            </button>
            <!-- Preview thumbnails -->
            <div id="foto-preview" class="flex flex-wrap gap-2 mt-3"></div>
          </div>
          <div class="sm:col-span-2 flex gap-3 justify-end pt-2">
            <button type="button" id="btn-cancel-form" class="btn btn-ghost btn-sm">Cancelar</button>
            <button type="submit" id="btn-submit" class="btn btn-primary btn-sm rounded-full">Publicar</button>
          </div>
          <p id="form-error" class="sm:col-span-2 text-error text-sm hidden"></p>
          </form>
        </div>
      </div>

      <!-- Grid de productos -->
      <div id="products-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>

      <!-- Estado vacío -->
      <div id="no-products" class="hidden text-center py-16">
        <p class="text-base-content/50 mb-4">Todav&iacute;a no tienes productos publicados.</p>
        <button id="btn-empty-publish" class="btn btn-primary rounded-full">Publicar mi primer producto</button>
      </div>
    </section>

    <!-- Sección: Solicitudes -->
    <section id="section-solicitudes" class="profile-section hidden">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-black uppercase tracking-tighter">Solicitudes recibidas y enviadas</h2>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
        <div class="bg-base-100 border border-base-200 rounded-2xl p-4">
          <h3 class="font-bold text-base mb-3">Recibidas (como vendedor)</h3>
          <div id="requests-received-grid" class="space-y-3"></div>
          <p id="no-requests-received" class="hidden text-sm text-base-content/60 py-6 text-center">No tienes solicitudes recibidas.</p>
        </div>

        <div class="bg-base-100 border border-base-200 rounded-2xl p-4">
          <h3 class="font-bold text-base mb-3">Enviadas (como comprador)</h3>
          <div id="requests-sent-grid" class="space-y-3"></div>
          <p id="no-requests-sent" class="hidden text-sm text-base-content/60 py-6 text-center">No has enviado solicitudes.</p>
        </div>
      </div>
    </section>

    <!-- Sección: Artículos reservados -->
    <section id="section-reservas" class="profile-section hidden">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-black uppercase tracking-tighter">Reservas y compras</h2>
      </div>

      <div id="reserved-filter-bar" class="hidden mb-5 p-3 rounded-2xl border border-base-200 bg-base-100 flex flex-wrap gap-2">
        <button type="button" data-reserved-filter="ALL" class="btn btn-xs rounded-full btn-primary">Todo (<span id="reserved-count-all">0</span>)</button>
        <button type="button" data-reserved-filter="RESERVA" class="btn btn-xs rounded-full btn-ghost">Reservas (<span id="reserved-count-reservas">0</span>)</button>
        <button type="button" data-reserved-filter="COMPRA" class="btn btn-xs rounded-full btn-ghost">Compras (<span id="reserved-count-compras">0</span>)</button>
      </div>

      <div id="reserved-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>

      <div id="no-reserved" class="hidden text-center py-12 bg-base-100 border border-base-200 rounded-2xl">
        <p id="no-reserved-text" class="text-base-content/60">Aún no tienes artículos reservados ni compras.</p>
      </div>
    </section>

    <!-- Sección: Historial de ventas/alquileres -->
    <section id="section-historial" class="profile-section hidden">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-black uppercase tracking-tighter">Historial de ventas, alquileres y préstamos</h2>
      </div>

      <div id="history-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>

      <div id="no-history" class="hidden text-center py-12 bg-base-100 border border-base-200 rounded-2xl">
        <p class="text-base-content/60">Aún no tienes ventas ni alquileres.</p>
      </div>
    </section>

    <section id="section-contratos" class="profile-section hidden">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-black uppercase tracking-tighter">Contratos y estado de firma</h2>
      </div>

      <div id="contracts-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4"></div>

      <div id="no-contracts" class="hidden text-center py-12 bg-base-100 border border-base-200 rounded-2xl">
        <p class="text-base-content/60">Aún no tienes contratos activos o finalizados.</p>
      </div>
    </section>

    <div id="contract-detail-modal" class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/60 p-4">
      <div class="w-full max-w-3xl rounded-2xl border border-base-300 bg-base-100 shadow-2xl max-h-[90vh] overflow-hidden">
        <div class="flex items-center justify-between border-b border-base-200 px-5 py-4">
          <h3 id="contract-detail-title" class="text-lg font-black tracking-tight">Detalle del contrato</h3>
          <button id="contract-detail-close" type="button" class="btn btn-ghost btn-sm btn-circle" aria-label="Cerrar detalle de contrato">&times;</button>
        </div>
        <div class="overflow-y-auto max-h-[calc(90vh-76px)] px-5 py-4 space-y-3">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
            <p><span class="font-semibold">Estado:</span> <span id="contract-detail-estado">-</span></p>
            <p><span class="font-semibold">Rol:</span> <span id="contract-detail-rol">-</span></p>
            <p><span class="font-semibold">Creado:</span> <span id="contract-detail-creado">-</span></p>
            <p><span class="font-semibold">Firmado:</span> <span id="contract-detail-firmado">-</span></p>
            <p><span class="font-semibold">Periodo:</span> <span id="contract-detail-periodo">-</span></p>
            <p><span class="font-semibold">Contraparte:</span> <span id="contract-detail-contraparte">-</span></p>
          </div>
          <div class="rounded-xl border border-base-200 bg-base-50 p-4">
            <p class="text-xs uppercase tracking-wide text-base-content/60 mb-2">Texto completo</p>
            <p id="contract-detail-texto" class="text-sm leading-relaxed whitespace-pre-wrap"></p>
          </div>
        </div>
      </div>
    </div>

    <div id="delete-product-modal" class="fixed inset-0 z-[1300] hidden items-center justify-center bg-black/55 p-4">
      <div class="w-full max-w-sm rounded-2xl border border-base-200 bg-base-100 shadow-2xl">
        <div class="p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-base-content/45">Eliminar anuncio</p>
          <h3 class="mt-2 text-lg font-bold leading-tight text-base-content">¿Quieres eliminar este anuncio?</h3>
          <p class="mt-2 text-sm text-base-content/65">Esta acción no se puede deshacer y el anuncio dejará de estar disponible.</p>
          <div class="mt-6 flex items-center justify-end gap-2">
            <button id="delete-product-cancel" type="button" class="btn btn-ghost btn-sm rounded-full">Cancelar</button>
            <button id="delete-product-confirm" type="button" class="btn btn-error btn-sm rounded-full">Sí, eliminar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Loading -->
    <div id="loading" class="flex justify-center py-20">
      <span class="loading loading-spinner loading-lg text-primary"></span>
    </div>

    <!-- Modal cámara -->
    <div id="camera-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 hidden">
      <div class="bg-base-100 rounded-2xl shadow-2xl p-4 flex flex-col items-center gap-4 w-full max-w-lg mx-4">
        <div class="flex items-center justify-between w-full">
          <span class="font-bold text-lg">Tomar foto</span>
          <button id="btn-camera-close" type="button" class="btn btn-ghost btn-sm btn-circle">&times;</button>
        </div>
        <video id="camera-stream" autoplay playsinline muted aria-label="Vista previa de la c&aacute;mara para capturar foto" class="w-full rounded-xl bg-black max-h-72 object-cover"></video>
        <p id="camera-error" class="text-error text-sm hidden">No se pudo acceder a la c&aacute;mara. Comprueba los permisos del navegador.</p>
        <div class="flex gap-3">
          <button id="btn-camera-switch" type="button" class="btn btn-outline btn-sm rounded-full gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            Cambiar c&aacute;mara
          </button>
          <button id="btn-camera-capture" type="button" class="btn btn-primary btn-sm rounded-full gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="4"/><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /></svg>
            Capturar
          </button>
        </div>
        <canvas id="camera-canvas" class="hidden"></canvas>
      </div>
    </div>

  </div>
</Layout>

<script define:vars={{ API_BASE, GOOGLE_BOOKS_KEY }}>
  const BACKEND_BASE = (() => {
    try { return new URL(API_BASE).origin; } catch { return "http://localhost:8080"; }
  })();

  function clearSession() {
    localStorage.removeItem("ufvshares_token");
    localStorage.removeItem("ufvshares_email");
    localStorage.removeItem("ufvshares_nombre");
    localStorage.removeItem("ufvshares_id");
    localStorage.removeItem("ufvshares_admin");
  }

  const token = localStorage.getItem("ufvshares_token");
  if (!token) {
    clearSession();
    window.location.href = "/auth?mode=login&next=" + encodeURIComponent("/profile");
  }

  const headers = { "Authorization": "Bearer " + token, "Content-Type": "application/json" };
  let currentProfile = null;
  const contractsById = new Map();

  const $ = id => document.getElementById(id);

  // ── Navegación de secciones ────────────────────────────────
  const sectionButtons = Array.from(document.querySelectorAll('[data-section-btn]'));
  const sections = Array.from(document.querySelectorAll('.profile-section'));

  function setActiveSection(key) {
    sections.forEach((s) => s.classList.add('hidden'));
    const active = document.getElementById('section-' + key);
    if (active) active.classList.remove('hidden');

    sectionButtons.forEach((btn) => {
      const isActive = btn.dataset.sectionBtn === key;
      btn.classList.toggle('btn-primary', isActive);
      btn.classList.toggle('btn-ghost', !isActive);
    });
  }

  sectionButtons.forEach((btn) => {
    btn.addEventListener('click', () => setActiveSection(btn.dataset.sectionBtn));
  });

  async function loadProfile() {
    try {
      const [meRes, prodRes, reservasRes, historyRes, sentReqRes, receivedReqRes, contractsRes] = await Promise.all([
        fetch(API_BASE + "/me", { headers }),
        fetch(API_BASE + "/me/productos", { headers }),
        fetch(API_BASE + "/me/reservas", { headers }),
        fetch(API_BASE + "/me/historial", { headers }),
        fetch(API_BASE + "/me/solicitudes/enviadas", { headers }),
        fetch(API_BASE + "/me/solicitudes/recibidas", { headers }),
        fetch(API_BASE + "/me/contratos", { headers }),
      ]);

      if (!meRes.ok) { clearSession(); window.location.href = "/auth?mode=login&next=" + encodeURIComponent("/profile"); return; }

      const me = await meRes.json();
      const prods = await prodRes.json();
      const reservas = reservasRes.ok ? await reservasRes.json() : [];
      const historial = historyRes.ok ? await historyRes.json() : [];
      const sentRequests = sentReqRes.ok ? await sentReqRes.json() : [];
      const receivedRequests = receivedReqRes.ok ? await receivedReqRes.json() : [];
      const contracts = contractsRes.ok ? await contractsRes.json() : [];

      // Guardar id para el caché de avatar
      if (me.idUsuario) localStorage.setItem('ufvshares_id', me.idUsuario);

      currentProfile = me;

      // Render profile
      fillProfileCard(me);
      $('profile-prods-count').textContent = prods.length;
      $('profile-card').classList.remove('hidden');

      // Render products
      $('loading').classList.add('hidden');
      renderProducts(prods);
      renderReserved(reservas);
      renderRequests({ sent: sentRequests, received: receivedRequests });
      renderHistory(historial);
      renderContracts(contracts);
    } catch (e) {
      $("loading").classList.add("hidden");
      console.error(e);
    }
  }

  // Activar sección inicial
  const initialSection = (location.hash || '').replace('#', '') || 'productos';
  if (['productos', 'reservas', 'solicitudes', 'historial', 'contratos'].includes(initialSection)) {
    setActiveSection(initialSection);
  } else {
    setActiveSection('productos');
  }

  function setAvatarImg(src) {
    $('avatar-circle').innerHTML = `<img src="${src}" class="w-full h-full object-cover" alt="Foto de perfil" />`;
  }

  function fillProfileCard(me) {
    $('profile-name').textContent = me.nombre + ' ' + me.apellidos;
    $('profile-email').textContent = me.correo;
    $('profile-telefono').textContent = me.telefono ?? '—';
    $('profile-dni').textContent = me.dni ?? '—';
    syncSecurityQuestionUi(me.preguntaSeguridad ?? 'No configurada');
      function syncSecurityQuestionUi(question) {
        const q = (question && question.trim()) ? question.trim() : 'No configurada';
        if ($('profile-security-question')) $('profile-security-question').textContent = q;
        if ($('edit-security-current')) $('edit-security-current').textContent = 'Pregunta actual: ' + q;

        const select = $('edit-security-question');
        if (!select) return;

        const hasOption = Array.from(select.options).some((opt) => opt.value === q);
        if (hasOption) {
          select.value = q;
          return;
        }

        if (q !== 'No configurada') {
          const customValue = '__current_custom__';
          let customOption = Array.from(select.options).find((opt) => opt.value === customValue);
          if (!customOption) {
            customOption = document.createElement('option');
            customOption.value = customValue;
            select.insertBefore(customOption, select.options[1] ?? null);
          }
          customOption.textContent = q + ' (actual)';
          select.value = customValue;
        } else {
          select.value = '';
        }
      }

    const CACHE_KEY = 'ufvshares_avatar_' + me.idUsuario;
    if (me.fotoPerfil) {
      const src = BACKEND_BASE + me.fotoPerfil;
      localStorage.setItem(CACHE_KEY, src);
      setAvatarImg(src);
    } else {
      // Usar caché local si el servidor aún no tiene la foto guardada
      const cached = localStorage.getItem(CACHE_KEY);
      if (cached) {
        setAvatarImg(cached);
      } else {
        const initials = ((me.nombre?.[0] ?? '') + (me.apellidos?.[0] ?? '')).toUpperCase();
        $('avatar-circle').textContent = initials;
      }
    }
  }

  $('avatar-input')?.addEventListener('change', async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;
    e.target.value = '';

    const uploadingEl = $('avatar-uploading');
    uploadingEl?.classList.remove('hidden');
    uploadingEl?.classList.add('flex');

    const formData = new FormData();
    formData.append('foto', file);
    try {
      const res = await fetch(API_BASE + '/me/foto-perfil', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: formData,
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      const src = BACKEND_BASE + data.fotoPerfil;
      setAvatarImg(src);
      showToast('Foto de perfil actualizada');
    } catch {
      showToast('No se pudo subir la foto', 'error');
    } finally {
      uploadingEl?.classList.add('hidden');
      uploadingEl?.classList.remove('flex');
    }
  });

  // ── Toast ────────────────────────────────────────────────────
  function showToast(msg, type = 'success') {
    const toast = $('profile-toast');
    const inner = $('profile-toast-inner');
    const msgEl = $('profile-toast-msg');
    const icon  = $('profile-toast-icon');
    msgEl.textContent = msg;
    inner.className = inner.className.replace(/bg-\S+\s?|text-\S+-content\s?/g, '');
    if (type === 'success') {
      inner.classList.add('bg-success', 'text-success-content');
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />';
    } else {
      inner.classList.add('bg-error', 'text-error-content');
      icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />';
    }
    toast.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
    toast.classList.add('opacity-100', 'translate-y-0');
    setTimeout(() => {
      toast.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      toast.classList.remove('opacity-100', 'translate-y-0');
    }, 4000);
  }

  // ── Drawer edición de perfil ─────────────────────────────────
  async function openEditDrawer() {
    const overlay = $('edit-profile-overlay');
    const panel   = $('edit-profile-panel');
    // Reset al paso 1
    $('edit-step-form').classList.remove('hidden');
    $('edit-step-ok').classList.add('hidden');
    $('edit-valor').value = '';
    $('edit-security-answer').value = '';

    try {
      const meRes = await fetch(API_BASE + '/me', { headers });
      if (meRes.ok) {
        currentProfile = await meRes.json();
        syncSecurityQuestionUi(currentProfile?.preguntaSeguridad ?? 'No configurada');
      }
    } catch {
      // Ignorar para no bloquear la apertura del modal.
    }

    $('edit-error').classList.add('hidden');
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    requestAnimationFrame(() => {
      panel.classList.remove('translate-y-4');
      panel.classList.add('translate-y-0');
    });
  }

  function closeEditDrawer() {
    const overlay = $('edit-profile-overlay');
    const panel   = $('edit-profile-panel');
    panel.classList.add('translate-y-4');
    panel.classList.remove('translate-y-0');
    setTimeout(() => {
      overlay.classList.add('hidden');
      overlay.classList.remove('flex');
    }, 200);
  }

  $('btn-edit-profile')?.addEventListener('click', openEditDrawer);
  $('btn-edit-profile-secondary')?.addEventListener('click', openEditDrawer);
  $('btn-close-edit')?.addEventListener('click', closeEditDrawer);
  $('btn-edit-cancel')?.addEventListener('click', closeEditDrawer);
  $('btn-edit-ok-close')?.addEventListener('click', closeEditDrawer);

  // Cerrar al clicar el fondo
  $('edit-profile-overlay')?.addEventListener('click', (e) => {
    if (e.target === $('edit-profile-overlay')) closeEditDrawer();
  });

  $('btn-edit-submit')?.addEventListener('click', async () => {
    const valor = $('edit-valor').value.trim();
    const campo = $('edit-campo').value;
    const errorEl = $('edit-error');
    const btn = $('btn-edit-submit');
    errorEl.classList.add('hidden');

    if (!valor) {
      errorEl.textContent = 'Introduce el nuevo valor.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    const origHtml = btn.innerHTML;
    btn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Guardando…';
    try {
      const res = await fetch(API_BASE + '/me/solicitar-cambio', {
        method: 'POST',
        headers,
        body: JSON.stringify({ campo, valor }),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        if (err?.message === 'Campo no permitido') {
          errorEl.textContent = 'El campo seleccionado no se puede actualizar.';
        } else if (err?.message === 'El valor no puede estar vacío') {
          errorEl.textContent = 'Introduce un valor válido.';
        } else {
          errorEl.textContent = 'No se pudo guardar el cambio en este momento.';
        }
        errorEl.classList.remove('hidden');
        return;
      }

      if (campo === 'nombre') {
        const apellidos = currentProfile?.apellidos ?? '';
        $('profile-name').textContent = (valor + ' ' + apellidos).trim();
        currentProfile = { ...(currentProfile || {}), nombre: valor };
      } else if (campo === 'apellidos') {
        const nombre = currentProfile?.nombre ?? '';
        $('profile-name').textContent = (nombre + ' ' + valor).trim();
        currentProfile = { ...(currentProfile || {}), apellidos: valor };
      } else if (campo === 'telefono') {
        $('profile-telefono').textContent = valor;
        currentProfile = { ...(currentProfile || {}), telefono: valor };
      }

      showToast('Datos actualizados correctamente', 'success');
      closeEditDrawer();
    } catch {
      errorEl.textContent = 'No se pudo conectar con el servidor';
      errorEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.innerHTML = origHtml;
    }
  });

  $('btn-security-submit')?.addEventListener('click', async () => {
    let question = $('edit-security-question')?.value?.trim() || '';
    if (question === '__current_custom__') {
      question = currentProfile?.preguntaSeguridad?.trim() || '';
    }
    const answer = $('edit-security-answer')?.value?.trim() || '';
    const errorEl = $('edit-security-error');
    const btn = $('btn-security-submit');

    errorEl.classList.add('hidden');
    if (!question) {
      errorEl.textContent = 'Selecciona una pregunta de seguridad.';
      errorEl.classList.remove('hidden');
      return;
    }
    if (answer.length < 2) {
      errorEl.textContent = 'La respuesta debe tener al menos 2 caracteres.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    const originalText = btn.textContent;
    btn.textContent = 'Guardando...';
    try {
      const res = await fetch(API_BASE + '/me/seguridad', {
        method: 'POST',
        headers,
        body: JSON.stringify({
          preguntaSeguridad: question,
          respuestaSeguridad: answer,
        }),
      });

      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        errorEl.textContent = err.message ?? 'No se pudo guardar la seguridad';
        errorEl.classList.remove('hidden');
        return;
      }

      $('profile-security-question').textContent = question;
      syncSecurityQuestionUi(question);
      $('edit-security-answer').value = '';
      currentProfile = { ...(currentProfile || {}), preguntaSeguridad: question };
      showToast('Pregunta de seguridad actualizada', 'success');
    } catch {
      errorEl.textContent = 'No se pudo conectar con el servidor';
      errorEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });

  const tipoLabel = { VENTA: "Venta", ALQUILER: "Alquiler", PRESTAMO: "Préstamo" };
  const categoriaLabel = { LIBROS: "Libros", ELECTRONICA: "Electrónica", DEPORTE: "Deporte", HOGAR: "Hogar", OTROS: "Otros" };
  const condicionLabel = { NUEVO: "Nuevo", COMO_NUEVO: "Como nuevo", BUENO: "Buen estado", ACEPTABLE: "Aceptable", DETERIORADO: "Deteriorado" };
  const estadoClass = { DISPONIBLE: "badge-success", RESERVADO: "badge-warning", NO_DISPONIBLE: "badge-error" };
  const estadoTxt = { DISPONIBLE: "Disponible", RESERVADO: "Reservado", NO_DISPONIBLE: "No disponible" };

  function renderProducts(prods) {
    const grid = $("products-grid");
    grid.innerHTML = "";
    if (!prods.length) {
      $("no-products").classList.remove("hidden");
      $("btn-toggle-form").classList.add("hidden");
      return;
    }
    $("no-products").classList.add("hidden");
    $("btn-toggle-form").classList.remove("hidden");
    prods.forEach(p => {
      const badge = tipoLabel[p.tipoTransaccion] ?? p.tipoTransaccion;
      const cat = categoriaLabel[p.categoria] ?? p.categoria;
      const precio = (p.precio == null || Number(p.precio) === 0) ? "Gratis" : parseFloat(p.precio).toFixed(2) + " €";
      const condicion = condicionLabel[p.condicion] ?? "";
      const estClss = estadoClass[p.estadoProducto] ?? "badge-ghost";
      const estTxt = estadoTxt[p.estadoProducto] ?? p.estadoProducto;
      const imgSrc = p.fotoUrl ? BACKEND_BASE + p.fotoUrl : (p.imagenUrl ?? null);
      const fotoCount = Array.isArray(p.fotos) ? p.fotos.length : (p.fotoUrl ? 1 : 0);
      const imgHtml = imgSrc
        ? `<div class="relative"><img src="${imgSrc}" alt="${p.titulo}" class="w-full h-40 object-cover rounded-t-2xl" />${fotoCount > 1 ? `<span class="absolute bottom-1 right-1 badge badge-sm bg-black/50 text-white border-none gap-1"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>${fotoCount}</span>` : ""}</div>`
        : `<div class="w-full h-40 bg-base-200 rounded-t-2xl flex items-center justify-center text-base-content/30 text-sm">Sin foto</div>`;
