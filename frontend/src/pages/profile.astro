        : 'Usuario';
      const personaEmail = persona.correo ? `<p class="text-xs text-base-content/50">${persona.correo}</p>` : '';

      const alquilerHtml = (item.tipoTransaccion === 'ALQUILER' && (inicio || fin || dias != null))
        ? `<div class="text-xs text-base-content/60 mt-2">
             ${inicio && fin ? `Alquiler: ${inicio} → ${fin}` : inicio ? `Inicio: ${inicio}` : fin ? `Fin: ${fin}` : ''}
             ${dias != null ? `<span class="ml-2 badge badge-sm">${dias} día${dias !== 1 ? 's' : ''}</span>` : ''}
           </div>`
        : '';

      grid.insertAdjacentHTML("beforeend", `
        <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow">
          ${imgHtml}
          <div class="card-body p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-bold leading-tight">${prod.titulo ?? 'Producto'}</h3>
              <span class="badge badge-primary shrink-0">${tipo}</span>
            </div>
            <p class="text-xs text-base-content/50 mt-1">Fecha: ${fecha}</p>
            <div class="mt-2">
              <p class="text-sm font-semibold">${personaNombre}</p>
              ${personaEmail}
            </div>
            ${alquilerHtml}
            <div class="flex items-center justify-end mt-3">
              <span class="font-bold text-primary ml-auto">${precio}</span>
            </div>
          </div>
        </div>
      `);
    });
  }

  function renderContracts(items) {
    const grid = $("contracts-grid");
    const empty = $("no-contracts");
    if (!grid || !empty) return;

    const estadoContratoLabel = {
      PENDIENTE_FIRMA: 'Pendiente de firma',
      ACTIVO: 'Activo',
      FINALIZADO: 'Finalizado',
      CANCELADO: 'Cancelado',
    };
    const estadoContratoClass = {
      PENDIENTE_FIRMA: 'badge-warning',
      ACTIVO: 'badge-success',
      FINALIZADO: 'badge-info',
      CANCELADO: 'badge-error',
    };

    const rolLabel = {
      ARRENDADOR: 'Eres arrendador',
      ARRENDATARIO: 'Eres arrendatario',
    };

    contractsById.clear();
    grid.innerHTML = "";
    if (!Array.isArray(items) || items.length === 0) {
      empty.classList.remove("hidden");
      return;
    }

    empty.classList.add("hidden");

    items.forEach((item) => {
      contractsById.set(String(item.idContrato), item);
      const prod = item.producto ?? {};
      const cp = item.contraparte ?? {};
      const estado = item.estadoContrato ?? 'ACTIVO';
      const estadoTxt = estadoContratoLabel[estado] ?? estado;
      const estadoCls = estadoContratoClass[estado] ?? 'badge-ghost';
      const rolTxt = rolLabel[item.rol] ?? 'Contrato';

      const imgSrc = prod.fotoUrl ? BACKEND_BASE + prod.fotoUrl : (prod.imagenUrl ?? null);
      const imgHtml = imgSrc
        ? `<img src="${imgSrc}" alt="${prod.titulo ?? 'Producto'}" class="w-full h-40 object-cover rounded-t-2xl" />`
        : `<div class="w-full h-40 bg-base-200 rounded-t-2xl flex items-center justify-center text-base-content/30 text-sm">Sin foto</div>`;

      const fechaInicio = formatEsDate(item.fechaInicio);
      const fechaFin = formatEsDate(item.fechaFin);
      const fechaCreacion = formatEsDate(item.fechaCreacion);
      const fechaFirma = formatEsDate(item.fechaFirmaArrendatario);
      const canSign = item.rol === 'ARRENDATARIO' && estado === 'PENDIENTE_FIRMA';
      const SiPuedeliberarObjeto = item.rol === 'ARRENDADOR' && item.puedeLiberarObjeto === true;

      const cpNombre = (cp.nombre || cp.apellidos)
        ? `${cp.nombre ?? ''} ${cp.apellidos ?? ''}`.trim()
        : 'Usuario';

      grid.insertAdjacentHTML("beforeend", `
        <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow cursor-pointer" data-contract-id="${item.idContrato}">
          ${imgHtml}
          <div class="card-body p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-bold leading-tight">${prod.titulo ?? 'Producto'}</h3>
              <span class="badge badge-sm ${estadoCls} border-none">${estadoTxt}</span>
            </div>
            <p class="text-xs text-base-content/60 mt-1">${rolTxt}</p>
            <p class="text-xs text-base-content/60">Creado: ${fechaCreacion}</p>
            <p class="text-xs text-base-content/60">Periodo: ${fechaInicio} → ${fechaFin}</p>
            <p class="text-xs text-base-content/60">Firma arrendatario: ${item.fechaFirmaArrendatario ? fechaFirma : 'Pendiente'}</p>
            <div class="mt-2">
              <p class="text-sm font-semibold">Contraparte: ${cpNombre}</p>
              ${cp.correo ? `<p class="text-xs text-base-content/50">${cp.correo}</p>` : ''}
            </div>
            ${item.textoCondiciones ? `<p class="text-xs text-base-content/70 mt-3 line-clamp-3">${item.textoCondiciones}</p>` : ''}
            ${canSign ? `<div class="mt-3"><button type="button" class="btn btn-sm btn-primary rounded-full" data-sign-contract-id="${item.idContrato}">Firmar contrato</button></div>` : ''}
            ${SiPuedeliberarObjeto ? `<div class="mt-3"><button type="button" class="btn btn-sm btn-secondary rounded-full" data-release-object-transaction-id="${item.idTransaccion}">Liberar objeto</button></div>` : ''}
          </div>
        </div>
      `);
    });
