      const vistasHtml = p.vistas > 0
        ? `<span class="text-xs text-base-content/40">${p.vistas} vista${p.vistas !== 1 ? "s" : ""}</span>` : "";
      grid.insertAdjacentHTML("beforeend", `
        <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow cursor-pointer"
             data-product='${JSON.stringify(p).replace(/'/g, "&#39;")}'>
          ${imgHtml}
          <div class="card-body p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-bold leading-tight">${p.titulo}</h3>
              <span class="badge badge-primary shrink-0">${badge}</span>
            </div>
            <p class="text-sm text-base-content/60 line-clamp-2 mt-1">${p.descripcion}</p>
            ${ubicacionHtml}
            <div class="flex flex-wrap items-center gap-2 mt-3">
              <span class="text-xs bg-base-200 px-2 py-1 rounded-full">${cat}</span>
              ${condicion ? `<span class="text-xs bg-base-200 px-2 py-1 rounded-full">${condicion}</span>` : ""}
              <span class="badge badge-sm ${estClss} border-none">${estTxt}</span>
            </div>
            <div class="flex items-center justify-between mt-2">
              ${vistasHtml}
              <span class="font-bold text-primary ml-auto">${precio}</span>
            </div>
            <div class="flex gap-2 pt-3 mt-2 border-t border-base-200">
              <button type="button" data-action="delete" data-id="${p.idProducto}"
                class="btn btn-outline btn-error btn-xs flex-1">Eliminar</button>
              <a href="/product/edit?id=${p.idProducto}" onclick="event.stopPropagation()"
                class="btn btn-outline btn-xs flex-1 text-center">Editar</a>
            </div>
          </div>
        </div>
      `);
    });
  }

  function renderReserved(items) {
    reservedItemsCache = Array.isArray(items) ? items : [];
    renderReservedCurrentFilter();
  }

  function parseDate(raw) {
    if (!raw) return null;
    const d = new Date(raw);
    return Number.isNaN(d.getTime()) ? null : d;
  }

  function formatEsDate(raw) {
    const d = parseDate(raw);
    if (!d) return "-";
    return d.toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  let reservedItemsCache = [];
  let reservedFilter = 'ALL';

  function updateReservedFiltersUi(total, reservas, compras) {
    const bar = $('reserved-filter-bar');
    const allCount = $('reserved-count-all');
    const reservasCount = $('reserved-count-reservas');
    const comprasCount = $('reserved-count-compras');

    if (allCount) allCount.textContent = String(total);
    if (reservasCount) reservasCount.textContent = String(reservas);
    if (comprasCount) comprasCount.textContent = String(compras);

    if (bar) {
      if (total > 0) bar.classList.remove('hidden');
      else bar.classList.add('hidden');
    }

    document.querySelectorAll('[data-reserved-filter]').forEach((btn) => {
      const active = btn.getAttribute('data-reserved-filter') === reservedFilter;
      btn.classList.toggle('btn-primary', active);
      btn.classList.toggle('btn-ghost', !active);
    });
  }

  function renderReservedCurrentFilter() {
    const grid = $("reserved-grid");
    const empty = $("no-reserved");
    const emptyText = $('no-reserved-text');
    if (!grid || !empty) return;

    const compras = reservedItemsCache.filter((item) => item?.tipoTransaccion === 'VENTA');
    const reservas = reservedItemsCache.filter((item) => item?.tipoTransaccion !== 'VENTA');
    updateReservedFiltersUi(reservedItemsCache.length, reservas.length, compras.length);

    let visibleItems = reservedItemsCache;
    if (reservedFilter === 'COMPRA') visibleItems = compras;
    if (reservedFilter === 'RESERVA') visibleItems = reservas;

    grid.innerHTML = "";
    if (!Array.isArray(visibleItems) || visibleItems.length === 0) {
      if (emptyText) {
        if (reservedFilter === 'COMPRA') emptyText.textContent = 'Aún no tienes compras.';
        else if (reservedFilter === 'RESERVA') emptyText.textContent = 'Aún no tienes artículos reservados.';
        else emptyText.textContent = 'Aún no tienes artículos reservados ni compras.';
      }
      empty.classList.remove("hidden");
      return;
    }

    empty.classList.add("hidden");
    visibleItems.forEach((p) => {
      const isCompra = p.tipoTransaccion === 'VENTA';
      const badge = tipoLabel[p.tipoTransaccion] ?? p.tipoTransaccion;
      const cat = categoriaLabel[p.categoria] ?? p.categoria;
      const precio = (p.precio == null || Number(p.precio) === 0) ? "Gratis" : parseFloat(p.precio).toFixed(2) + " €";
      const estClss = estadoClass[p.estadoProducto] ?? "badge-ghost";
      const estTxt = estadoTxt[p.estadoProducto] ?? p.estadoProducto;
      const imgSrc = p.fotoUrl ? BACKEND_BASE + p.fotoUrl : (p.imagenUrl ?? null);
      const fechaReserva = formatEsDate(p.fechaSolicitud);
      const imgHtml = imgSrc
        ? `<img src="${imgSrc}" alt="${p.titulo}" class="w-full h-40 object-cover rounded-t-2xl" />`
        : `<div class="w-full h-40 bg-base-200 rounded-t-2xl flex items-center justify-center text-base-content/30 text-sm">Sin foto</div>`;

      grid.insertAdjacentHTML("beforeend", `
        <div class="card bg-base-100 border border-base-200 shadow-sm hover:shadow-md transition-shadow cursor-pointer"
             data-reserved-product-id="${p.idProducto}">
          ${imgHtml}
          <div class="card-body p-5">
            <div class="flex items-start justify-between gap-2">
              <h3 class="font-bold leading-tight">${p.titulo}</h3>
              <span class="badge badge-primary shrink-0">${badge}</span>
            </div>
            <p class="text-xs text-base-content/50 mt-1">${isCompra ? `Comprado el ${fechaReserva}` : `Reservado el ${fechaReserva}`}</p>
            <div class="flex flex-wrap items-center gap-2 mt-3">
              <span class="text-xs bg-base-200 px-2 py-1 rounded-full">${cat}</span>
              <span class="badge badge-sm ${isCompra ? 'badge-success' : 'badge-info'} border-none">${isCompra ? 'Compra' : 'Reserva'}</span>
              <span class="badge badge-sm ${estClss} border-none">${estTxt}</span>
            </div>
            <div class="flex items-center justify-end mt-2">
              <span class="font-bold text-primary ml-auto">${precio}</span>
            </div>
          </div>
        </div>
      `);
    });
  }

  document.querySelectorAll('[data-reserved-filter]').forEach((btn) => {
    btn.addEventListener('click', () => {
      reservedFilter = btn.getAttribute('data-reserved-filter') || 'ALL';
      renderReservedCurrentFilter();
    });
  });

  function estadoSolicitudBadge(estado) {
    const cls = {
      PENDIENTE: 'badge-warning',
      ACEPTADA: 'badge-success',
      RECHAZADA: 'badge-error',
      CANCELADA: 'badge-neutral',
    }[estado] ?? 'badge-ghost';
    const txt = {
      PENDIENTE: 'Pendiente',
      ACEPTADA: 'Aceptada',
      RECHAZADA: 'Rechazada',
      CANCELADA: 'Cancelada',
    }[estado] ?? (estado || '—');
    return `<span class="badge badge-sm ${cls} border-none">${txt}</span>`;
  }

  function renderRequests({ sent, received }) {
    const sentGrid = $('requests-sent-grid');
    const receivedGrid = $('requests-received-grid');
    const noSent = $('no-requests-sent');
    const noReceived = $('no-requests-received');
    if (!sentGrid || !receivedGrid || !noSent || !noReceived) return;

    const sentItems = Array.isArray(sent) ? sent : [];
    const receivedItems = Array.isArray(received) ? received : [];

    sentGrid.innerHTML = '';
    receivedGrid.innerHTML = '';

    if (sentItems.length === 0) noSent.classList.remove('hidden');
    else noSent.classList.add('hidden');

    if (receivedItems.length === 0) noReceived.classList.remove('hidden');
    else noReceived.classList.add('hidden');

    sentItems.forEach((item) => {
      const prod = item.producto || {};
      const owner = item.propietario || {};
      const fecha = formatEsDate(item.fechaSolicitud);
      sentGrid.insertAdjacentHTML('beforeend', `
        <article class="rounded-xl border border-base-200 p-3 bg-base-50">
          <div class="flex items-start justify-between gap-2">
            <h4 class="font-semibold leading-tight">${prod.titulo ?? 'Producto'}</h4>
            ${estadoSolicitudBadge(item.estadoSolicitud)}
          </div>
          <p class="text-xs text-base-content/60 mt-1">Solicitud enviada el ${fecha}</p>
          <p class="text-xs text-base-content/60 mt-1">Vendedor: ${(owner.nombre || owner.apellidos) ? `${owner.nombre ?? ''} ${owner.apellidos ?? ''}`.trim() : '—'}</p>
        </article>
      `);
    });

    receivedItems.forEach((item) => {
      const prod = item.producto || {};
      const buyer = item.solicitante || {};
      const fecha = formatEsDate(item.fechaSolicitud);
      const pending = item.estadoSolicitud === 'PENDIENTE';
      receivedGrid.insertAdjacentHTML('beforeend', `
        <article class="rounded-xl border border-base-200 p-3 bg-base-50" data-request-id="${item.idSolicitud}">
          <div class="flex items-start justify-between gap-2">
            <h4 class="font-semibold leading-tight">${prod.titulo ?? 'Producto'}</h4>
            ${estadoSolicitudBadge(item.estadoSolicitud)}
          </div>
          <p class="text-xs text-base-content/60 mt-1">Comprador: ${(buyer.nombre || buyer.apellidos) ? `${buyer.nombre ?? ''} ${buyer.apellidos ?? ''}`.trim() : '—'}</p>
          <p class="text-xs text-base-content/60 mt-1">Recibida el ${fecha}</p>
          ${pending ? `
            <div class="flex gap-2 mt-3">
              <button type="button" class="btn btn-xs btn-success rounded-full" data-request-action="accept">Aceptar</button>
              <button type="button" class="btn btn-xs btn-error rounded-full" data-request-action="reject">Rechazar</button>
            </div>
          ` : ''}
        </article>
      `);
    });
  }

  $('requests-received-grid')?.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-request-action]');
    if (!btn) return;

    const card = e.target.closest('[data-request-id]');
    const id = card?.getAttribute('data-request-id');
    const action = btn.getAttribute('data-request-action');
    if (!id || !action) return;

    const isAccept = action === 'accept';
    btn.disabled = true;
    const old = btn.textContent;
    btn.textContent = isAccept ? 'Aceptando...' : 'Rechazando...';

    try {
      const res = await fetch(API_BASE + `/me/solicitudes/${id}/${isAccept ? 'aceptar' : 'rechazar'}`, {
        method: 'PUT',
        headers,
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        showToast(err.message ?? 'No se pudo actualizar la solicitud', 'error');
        return;
      }

      showToast(isAccept ? 'Solicitud aceptada' : 'Solicitud rechazada');
      await loadProfile();
      setActiveSection('solicitudes');
    } catch {
      showToast('No se pudo conectar con el servidor', 'error');
    } finally {
      btn.disabled = false;
      btn.textContent = old;
    }
  });

  function renderHistory(items) {
    const grid = $("history-grid");
    const empty = $("no-history");
    if (!grid || !empty) return;

    grid.innerHTML = "";
    if (!Array.isArray(items) || items.length === 0) {
      empty.classList.remove("hidden");
      return;
    }

    empty.classList.add("hidden");

    items.forEach((item) => {
      const tipo = tipoLabel[item.tipoTransaccion] ?? item.tipoTransaccion ?? "—";
      const prod = item.producto ?? {};
      const persona = item.persona ?? {};
      const precio = (prod.precio == null || Number(prod.precio) === 0) ? "Gratis" : parseFloat(prod.precio).toFixed(2) + " €";
      const imgSrc = prod.fotoUrl ? BACKEND_BASE + prod.fotoUrl : (prod.imagenUrl ?? null);
      const fecha = item.fechaTransaccion
        ? new Date(item.fechaTransaccion).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })
        : '—';
      const inicio = item.fechaInicio
        ? new Date(item.fechaInicio).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })
        : null;
      const fin = item.fechaFin
        ? new Date(item.fechaFin).toLocaleDateString('es-ES', { day: '2-digit', month: 'short', year: 'numeric' })
        : null;
      const dias = item.diasAlquiler != null ? Number(item.diasAlquiler) : null;

      const imgHtml = imgSrc
        ? `<img src="${imgSrc}" alt="${prod.titulo ?? 'Producto'}" class="w-full h-40 object-cover rounded-t-2xl" />`
        : `<div class="w-full h-40 bg-base-200 rounded-t-2xl flex items-center justify-center text-base-content/30 text-sm">Sin foto</div>`;

      const personaNombre = (persona.nombre || persona.apellidos)
