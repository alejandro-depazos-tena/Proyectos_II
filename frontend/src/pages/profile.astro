  function openContractDetail(item) {
    if (!item) return;
    const estadoContratoLabel = {
      PENDIENTE_FIRMA: 'Pendiente de firma',
      ACTIVO: 'Activo',
      FINALIZADO: 'Finalizado',
      CANCELADO: 'Cancelado',
    };
    const rolLabel = {
      ARRENDADOR: 'Eres arrendador',
      ARRENDATARIO: 'Eres arrendatario',
    };
    const cp = item.contraparte ?? {};
    const cpNombre = (cp.nombre || cp.apellidos)
      ? `${cp.nombre ?? ''} ${cp.apellidos ?? ''}`.trim()
      : 'Usuario';

    $('contract-detail-title').textContent = item.producto?.titulo
      ? `Contrato · ${item.producto.titulo}`
      : 'Detalle del contrato';
    $('contract-detail-estado').textContent = estadoContratoLabel[item.estadoContrato] ?? (item.estadoContrato ?? '—');
    $('contract-detail-rol').textContent = rolLabel[item.rol] ?? 'Contrato';
    $('contract-detail-creado').textContent = formatEsDate(item.fechaCreacion);
    $('contract-detail-firmado').textContent = item.fechaFirmaArrendatario ? formatEsDate(item.fechaFirmaArrendatario) : 'Pendiente';
    $('contract-detail-periodo').textContent = `${formatEsDate(item.fechaInicio)} → ${formatEsDate(item.fechaFin)}`;
    $('contract-detail-contraparte').textContent = cp.correo ? `${cpNombre} (${cp.correo})` : cpNombre;
    $('contract-detail-texto').textContent = item.textoCondiciones || 'Este contrato no tiene texto disponible.';

    $('contract-detail-modal')?.classList.remove('hidden');
    $('contract-detail-modal')?.classList.add('flex');
  }

  function closeContractDetail() {
    $('contract-detail-modal')?.classList.add('hidden');
    $('contract-detail-modal')?.classList.remove('flex');
  }

  function openDeleteProductModal() {
    $('delete-product-modal')?.classList.remove('hidden');
    $('delete-product-modal')?.classList.add('flex');
  }

  function closeDeleteProductModal() {
    $('delete-product-modal')?.classList.add('hidden');
    $('delete-product-modal')?.classList.remove('flex');
  }

  function confirmDeleteProduct() {
    return new Promise((resolve) => {
      const modal = $('delete-product-modal');
      const confirmBtn = $('delete-product-confirm');
      const cancelBtn = $('delete-product-cancel');
      if (!modal || !confirmBtn || !cancelBtn) {
        resolve(false);
        return;
      }

      const cleanup = () => {
        confirmBtn.removeEventListener('click', onConfirm);
        cancelBtn.removeEventListener('click', onCancel);
        modal.removeEventListener('click', onBackdrop);
        document.removeEventListener('keydown', onEscape);
      };

      const onConfirm = () => {
        cleanup();
        closeDeleteProductModal();
        resolve(true);
      };

      const onCancel = () => {
        cleanup();
        closeDeleteProductModal();
        resolve(false);
      };

      const onBackdrop = (e) => {
        if (e.target === modal) onCancel();
      };

      const onEscape = (e) => {
        if (e.key === 'Escape') onCancel();
      };

      confirmBtn.addEventListener('click', onConfirm);
      cancelBtn.addEventListener('click', onCancel);
      modal.addEventListener('click', onBackdrop);
      document.addEventListener('keydown', onEscape);
      openDeleteProductModal();
    });
  }

  $('contract-detail-close')?.addEventListener('click', closeContractDetail);
  $('contract-detail-modal')?.addEventListener('click', (e) => {
    if (e.target === $('contract-detail-modal')) closeContractDetail();
