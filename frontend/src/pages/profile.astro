  $('contracts-grid')?.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-sign-contract-id]');
    if (btn) {
      const idContrato = btn.getAttribute('data-sign-contract-id');
      if (!idContrato) return;

      if (!confirm('Vas a firmar este contrato y aceptar sus términos. ¿Deseas continuar?')) return;

      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = 'Firmando...';
      try {
        const res = await fetch(API_BASE + `/me/contratos/${idContrato}/firmar`, {
          method: 'PUT',
          headers,
          body: JSON.stringify({
            aceptaTerminos: true,
          }),
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          showToast(err.message ?? 'No se pudo firmar el contrato', 'error');
          return;
        }
        showToast('Contrato firmado correctamente');
        await loadProfile();
        setActiveSection('contratos');
      } catch {
        showToast('No se pudo conectar con el servidor', 'error');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
      return;
    }

    const mostrarBotonLiberarObjeto = e.target.closest('[data-release-object-transaction-id]');
    if (mostrarBotonLiberarObjeto) {
      const idTransaccion = mostrarBotonLiberarObjeto.getAttribute('data-release-object-transaction-id');
      if (!idTransaccion) return;

      if (!confirm('Esta acción finaliza el contrato y libera el objeto para volver a alquilarse. ¿Deseas continuar?')) return;

      mostrarBotonLiberarObjeto.disabled = true;
      const originalText = mostrarBotonLiberarObjeto.textContent;
      mostrarBotonLiberarObjeto.textContent = 'Liberando...';
      try {
        const res = await fetch(API_BASE + `/me/transacciones/${idTransaccion}/liberar-objeto`, {
          method: 'PUT',
          headers,
        });
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          showToast(err.message ?? 'No se pudo liberar el objeto', 'error');
          return;
        }
        showToast('Objeto liberado y contrato finalizado');
        await loadProfile();
        setActiveSection('contratos');
      } catch {
        showToast('No se pudo conectar con el servidor', 'error');
      } finally {
        mostrarBotonLiberarObjeto.disabled = false;
        mostrarBotonLiberarObjeto.textContent = originalText;
      }
      return;
    }

    const card = e.target.closest('[data-contract-id]');
    if (!card) return;
    const idContrato = card.getAttribute('data-contract-id');
    if (!idContrato) return;
    openContractDetail(contractsById.get(idContrato));
  });

  // ── Eliminar producto ────────────────────────────────────────
  async function deleteProduct(id, btn) {
    if (!await confirmDeleteProduct()) return;
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const res = await fetch(API_BASE + '/me/productos/' + id, {
        method: 'DELETE',
        headers: { 'Authorization': 'Bearer ' + token },
      });
      if (!res.ok && res.status !== 204) throw new Error('HTTP ' + res.status);
      showToast('Anuncio eliminado');
      const prodRes = await fetch(API_BASE + '/me/productos', { headers });
      const prods = await prodRes.json();
      renderProducts(prods);
      $('profile-prods-count').textContent = prods.length;
    } catch {
      showToast('No se pudo eliminar el anuncio', 'error');
      btn.disabled = false;
      btn.textContent = 'Eliminar';
    }
  }

  // ── Navegar al ver/editar producto al clicar una tarjeta ──────
  $('products-grid')?.addEventListener('click', async (e) => {
    const delBtn = e.target.closest('[data-action="delete"]');
    if (delBtn) {
      e.stopPropagation();
      await deleteProduct(delBtn.dataset.id, delBtn);
      return;
    }
    const card = e.target.closest('[data-product]');
    if (!card) return;
    // Don't navigate if clicking the edit link
    if (e.target.closest('a[href]')) return;
    try {
      const p = JSON.parse(card.dataset.product);
      const id = p.idProducto ?? p.id_producto;
      if (id) window.location.href = '/product/view?id=' + id;
    } catch {}
  });

  $('reserved-grid')?.addEventListener('click', (e) => {
    const card = e.target.closest('[data-reserved-product-id]');
    if (!card) return;
    const id = card.getAttribute('data-reserved-product-id');
    if (id) window.location.href = '/product/view?id=' + id;
  });

  function showForm() {
    $("publish-form-wrap").classList.remove("hidden");
    $("publish-form-wrap").scrollIntoView({ behavior: "smooth", block: "start" });
  }
  // ── Shared photo state ──────────────────────────────────────────
  let selectedFiles = [];

  function updateLabel() {
    const n = selectedFiles.length;
    const el = $("foto-label-text");
    if (el) el.textContent = n > 0
      ? `${n} foto${n > 1 ? "s" : ""} seleccionada${n > 1 ? "s" : ""}`
      : "Haz clic o arrastra imágenes aquí";
  }

  function renderPreview() {
    const preview = $("foto-preview");
    if (!preview) return;
    preview.innerHTML = "";
    selectedFiles.forEach((file, idx) => {
      const url = URL.createObjectURL(file);
      const wrap = document.createElement("div");
      wrap.className = "relative w-20 h-20 rounded-lg overflow-hidden border border-base-300 group";
      wrap.innerHTML = `
        <img src="${url}" class="w-full h-full object-cover" />
        <button type="button" data-idx="${idx}"
          class="absolute inset-0 flex items-start justify-end p-0.5 opacity-0 group-hover:opacity-100 transition-opacity"
          aria-label="Quitar foto">
          <span class="w-5 h-5 rounded-full bg-error text-white text-xs flex items-center justify-center">&times;</span>
        </button>`;
      wrap.querySelector("button").addEventListener("click", (e) => {
        selectedFiles.splice(Number(e.currentTarget.dataset.idx), 1);
        renderPreview();
      });
      preview.appendChild(wrap);
    });
    updateLabel();
  }

  function addFiles(fileList) {
    for (const file of fileList) selectedFiles.push(file);
    renderPreview();
  }

  function hideForm() {
    $("publish-form-wrap").classList.add("hidden");
    $("publish-form").reset();
    $("form-error").classList.add("hidden");
    // Resetear checkbox gratis
    const gratisCb = document.getElementById("precio-gratis-cb");
    const precioInput = document.getElementById("precio-input");
    if (gratisCb) gratisCb.checked = false;
    if (precioInput) { precioInput.disabled = false; precioInput.value = ""; }
    selectedFiles = [];
    renderPreview();
  }

  // Checkbox "Gratis"
  document.getElementById("precio-gratis-cb")?.addEventListener("change", function () {
    const precioInput = document.getElementById("precio-input");
    if (!precioInput) return;
    if (this.checked) {
      precioInput.value = "";
      precioInput.disabled = true;
      precioInput.placeholder = "Gratis";
    } else {
      precioInput.disabled = false;
      precioInput.placeholder = "0.00";
    }
  });

  // Gallery / drop-zone input
  $("foto-label")?.addEventListener("click", () => {
    $("foto-input")?.click();
  });
  $("foto-label")?.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " ") {
      e.preventDefault();
      $("foto-input")?.click();
    }
  });
  $("foto-input")?.addEventListener("change", function () {
    addFiles(this.files);
    this.value = "";
  });

  // ── Lógica de cámara con getUserMedia ─────────────────────────
  let cameraStream = null;
  let facingMode = "environment"; // trasera por defecto

  async function startCamera() {
    const video = $("camera-stream");
    const errEl = $("camera-error");
    errEl.classList.add("hidden");
    if (cameraStream) {
      cameraStream.getTracks().forEach(t => t.stop());
      cameraStream = null;
    }
    try {
      cameraStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode, width: { ideal: 1280 }, height: { ideal: 720 } },
        audio: false,
      });
      video.srcObject = cameraStream;
    } catch {
      errEl.classList.remove("hidden");
    }
  }

  function stopCamera() {
    if (cameraStream) {
      cameraStream.getTracks().forEach(t => t.stop());
      cameraStream = null;
    }
    const video = $("camera-stream");
    if (video) video.srcObject = null;
  }

  $("btn-camera")?.addEventListener("click", async () => {
    $("camera-modal").classList.remove("hidden");
    await startCamera();
  });

  $("btn-camera-close")?.addEventListener("click", () => {
    stopCamera();
    $("camera-modal").classList.add("hidden");
  });

  $("btn-camera-switch")?.addEventListener("click", async () => {
    facingMode = facingMode === "environment" ? "user" : "environment";
    await startCamera();
  });

  $("btn-camera-capture")?.addEventListener("click", () => {
    const video = $("camera-stream");
    const canvas = $("camera-canvas");
    if (!video || !canvas) return;
    canvas.width = video.videoWidth;
    canvas.height = video.videoHeight;
    canvas.getContext("2d").drawImage(video, 0, 0);
    canvas.toBlob(blob => {
      if (!blob) return;
      const fileName = "foto_" + Date.now() + ".jpg";
      const file = new File([blob], fileName, { type: "image/jpeg" });
      addFiles([file]);
      stopCamera();
      $("camera-modal").classList.add("hidden");
    }, "image/jpeg", 0.9);
  });

  $("btn-toggle-form")?.addEventListener("click", showForm);
  $("btn-empty-publish")?.addEventListener("click", showForm);
  $("btn-cancel-form")?.addEventListener("click", hideForm);

  $("publish-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = $("btn-submit");
    const errEl = $("form-error");
    btn.disabled = true;
    btn.textContent = "Publicando...";
    errEl.classList.add("hidden");

    // Validate at least 1 photo
    if (selectedFiles.length === 0) {
      errEl.textContent = "Debes subir al menos una foto del producto";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      btn.textContent = "Publicar";
      return;
    }

    const fd = new FormData(e.target);
    const body = {
      titulo: fd.get("titulo"),
      descripcion: fd.get("descripcion"),
      categoria: fd.get("categoria"),
      tipoTransaccion: fd.get("tipoTransaccion"),
      estadoProducto: "DISPONIBLE",
      condicion: fd.get("condicion") || null,
    };
    const esGratis = document.getElementById('precio-gratis-cb')?.checked;
    if (esGratis) {
      body.precio = 0;
    } else {
      const precio = fd.get("precio");
      if (precio) body.precio = parseFloat(precio);
    }

    try {
      // Step 1: create product
      const res = await fetch(API_BASE + "/me/productos", {
        method: "POST",
        headers,
        body: JSON.stringify(body),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        errEl.textContent = err.message ?? "Error al publicar";
        errEl.classList.remove("hidden");
        return;
      }
      const producto = await res.json();

      // Step 2: upload photos
      btn.textContent = "Subiendo fotos...";
      const fotoData = new FormData();
      for (const file of selectedFiles) fotoData.append("fotos", file);
      const idProducto = producto.idProducto ?? producto.id_producto;
      if (!idProducto) {
        errEl.textContent = "Error interno: no se pudo obtener el ID del producto creado";
        errEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Publicar";
        return;
      }
      const fotoRes = await fetch(API_BASE + "/me/productos/" + idProducto + "/fotos", {
        method: "POST",
        headers: { Authorization: headers.Authorization },
        body: fotoData,
      });
      if (!fotoRes.ok) {
        const err = await fotoRes.json().catch(() => ({}));
        errEl.textContent = "Error al subir las fotos: " + (err.message ?? err.error ?? ("HTTP " + fotoRes.status));
        errEl.classList.remove("hidden");
        btn.disabled = false;
        btn.textContent = "Publicar";
        return; // keep form open so user can retry
      }

      hideForm();
      const prodRes = await fetch(API_BASE + "/me/productos", { headers });
      renderProducts(await prodRes.json());
    } catch {
      errEl.textContent = "No se pudo conectar con el backend";
      errEl.classList.remove("hidden");
    } finally {
      btn.disabled = false;
      btn.textContent = "Publicar";
    }
  });

  // ── Google Books API integration ──────────────────────────────────────
  const GBOOKS_API = 'https://www.googleapis.com/books/v1/volumes';
  const GBOOKS_KEY = GOOGLE_BOOKS_KEY ?? '';
  const _gBooksCache = new Map();

  const categoriaSelect  = document.querySelector('select[name="categoria"]');
  const booksLookup      = $('books-lookup');
  const booksQueryInput  = $('books-query');
  const booksResultsEl   = $('books-results');
  const booksSelectedEl  = $('books-selected');
  const booksSelTitleEl  = $('books-selected-title');

  // Mostrar / ocultar panel según categoría
  categoriaSelect?.addEventListener('change', () => {
    if (categoriaSelect.value === 'LIBROS') {
      booksLookup?.classList.remove('hidden');
    } else {
      booksLookup?.classList.add('hidden');
      clearSelectedBook();
    }
  });

  // Si el formulario se resetea, resetear también el panel
  $('btn-cancel-form')?.addEventListener('click', () => {
    booksLookup?.classList.add('hidden');
    clearSelectedBook();
  }, true); // useCapture para que corra antes del hideForm

  async function searchGoogleBooks(query) {
    const isIsbn = /^[\d\-]{9,17}$/.test(query.replace(/\s/g, ''));
    const q = isIsbn ? 'isbn:' + query.replace(/[^\d]/g, '') : query;

    // Devolver desde caché si ya se hizo esta consulta
    if (_gBooksCache.has(q)) return _gBooksCache.get(q);

    const paramObj = { q, maxResults: '6', printType: 'books' };
    if (GBOOKS_KEY) paramObj.key = GBOOKS_KEY;
    const params = new URLSearchParams(paramObj);
    const url = GBOOKS_API + '?' + params.toString();

    const res = await fetch(url);
    if (!res.ok) {
      const body = await res.text().catch(() => '');
      throw new Error('HTTP ' + res.status + (body ? ': ' + body.substring(0, 200) : ''));
    }
    const data = await res.json();
    _gBooksCache.set(q, data); // guardar en caché
    return data;
  }

  function fillFormWithBook(item) {
    const info = item.volumeInfo;

    const tituloInput   = document.querySelector('input[name="titulo"]');
    const descTextarea  = document.querySelector('textarea[name="descripcion"]');

    // Rellenar título si está vacío
    if (tituloInput && !tituloInput.value.trim()) {
      tituloInput.value = info.title
        + (info.subtitle ? ': ' + info.subtitle : '')
        + (info.authors?.length ? ' - ' + info.authors[0] : '');
    }

    // Rellenar descripción si está vacía
    if (descTextarea && !descTextarea.value.trim()) {
      const lines = [];
      if (info.authors?.length)  lines.push('Autor/es: '    + info.authors.join(', '));
      if (info.publisher)        lines.push('Editorial: '   + info.publisher);
      if (info.publishedDate)    lines.push('Año: '         + info.publishedDate.substring(0, 4));
      if (info.pageCount)        lines.push('Páginas: '     + info.pageCount);
      const isbn13 = info.industryIdentifiers?.find(x => x.type === 'ISBN_13')?.identifier;
      if (isbn13)                lines.push('ISBN-13: '     + isbn13);
      if (info.description) {
        lines.push('');
        lines.push(info.description.length > 500
          ? info.description.substring(0, 500) + '…'
          : info.description);
      }
      descTextarea.value = lines.join('\n');
    }

    // Mostrar badge del libro seleccionado
    booksSelTitleEl.textContent =
      info.title + (info.authors?.length ? '  —  ' + info.authors[0] : '');
    booksSelectedEl.classList.remove('hidden');
    booksSelectedEl.classList.add('flex');
    booksResultsEl.classList.add('hidden');
    booksResultsEl.innerHTML = '';
  }

  function clearSelectedBook() {
    booksSelTitleEl.textContent = '';
    booksSelectedEl?.classList.add('hidden');
    booksSelectedEl?.classList.remove('flex');
    if (booksResultsEl) {
      booksResultsEl.classList.add('hidden');
      booksResultsEl.innerHTML = '';
    }
    if (booksQueryInput) booksQueryInput.value = '';
  }

  async function runBooksSearch() {
    const query = booksQueryInput?.value.trim();
    if (!query) return;

    const btn = $('btn-books-search');
    btn.disabled = true;
    btn.innerHTML = '<span class="loading loading-spinner loading-xs"></span> Buscando…';

    booksResultsEl.innerHTML = '';
    booksResultsEl.classList.remove('hidden');
    booksResultsEl.classList.add('flex');

    try {
      const data = await searchGoogleBooks(query);
      const items = data.items ?? [];

      if (!items.length) {
        booksResultsEl.innerHTML =
          '<p class="text-sm text-center text-base-content/50 py-4 px-3">Sin resultados. Prueba con el ISBN completo o el título en otro idioma.</p>';
        return;
      }

      items.forEach(item => {
        const info = item.volumeInfo;
        const thumb = info.imageLinks?.smallThumbnail ?? info.imageLinks?.thumbnail ?? null;
        const authors = info.authors?.slice(0, 2).join(', ') ?? 'Autor desconocido';
        const year = info.publishedDate?.substring(0, 4) ?? '';
        const isbn = info.industryIdentifiers?.find(x => x.type === 'ISBN_13')?.identifier ?? '';

        const btn2 = document.createElement('button');
        btn2.type = 'button';
        btn2.className = 'flex items-center gap-3 w-full text-left px-3 py-2.5 hover:bg-blue-50 transition-colors';
        btn2.innerHTML = `
          ${thumb
            ? `<img src="${thumb}" class="w-9 h-12 object-cover rounded shadow-sm shrink-0" alt="" loading="lazy" />`
            : `<div class="w-9 h-12 bg-blue-100 rounded shrink-0 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-400"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
               </div>`
          }
          <div class="min-w-0 flex-1">
            <p class="font-semibold text-sm text-base-content leading-snug truncate">${info.title}</p>
            <p class="text-xs text-base-content/55 truncate">${authors}${year ? ' · ' + year : ''}</p>
            ${isbn ? `<p class="text-[10px] text-blue-500 mt-0.5">ISBN ${isbn}</p>` : ''}
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-blue-400"><path d="M20 6 9 17l-5-5"/></svg>`;

        btn2.addEventListener('click', () => fillFormWithBook(item));
        booksResultsEl.appendChild(btn2);
      });
    } catch (err) {
      console.error('[Google Books]', err);
      const isNetwork = err instanceof TypeError;
      const msg = isNetwork
        ? 'No se pudo contactar con Google Books. Comprueba tu conexión a internet.'
        : 'Google Books respondió con un error (' + (err.message ?? '') + '). Inténtalo de nuevo.';
      booksResultsEl.innerHTML =
        `<p class="text-sm text-center text-error/70 py-4 px-3">${msg}</p>`;
    } finally {
      btn.disabled = false;
      btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg> Buscar`;
    }
  }

  $('btn-books-search')?.addEventListener('click', runBooksSearch);
  $('btn-books-clear')?.addEventListener('click', clearSelectedBook);
  booksQueryInput?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); runBooksSearch(); }
  });

  loadProfile();
</script>
