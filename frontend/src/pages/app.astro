import Layout from "../layouts/Layout.astro";

<Layout title="UFV Shares · App">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-start justify-between gap-4 flex-wrap">
      <div>
        <h1 class="text-3xl font-extrabold">App</h1>
        <p class="text-sm opacity-70" id="whoami"></p>
      </div>
      <div class="flex gap-2">
        <a class="btn btn-ghost" href="/">Inicio</a>
        <button class="btn" id="logout" type="button">Cerrar sesión</button>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mt-8">
      <section class="lg:col-span-2">
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <div class="flex items-end justify-between gap-4 flex-wrap">
              <div>
                <h2 class="card-title">Productos</h2>
                <p class="text-sm opacity-70">Explora, filtra y encuentra lo que necesitas.</p>
              </div>
              <div class="flex items-end gap-3">
                <label class="form-control">
                  <div class="label"><span class="label-text">Filtrar</span></div>
                  <select id="filter" class="select select-bordered">
                    <option value="">Todos</option>
                    <option value="VENTA">Venta</option>
                    <option value="ALQUILER">Alquiler</option>
                    <option value="PRESTAMO">Préstamo</option>
                  </select>
                </label>
                <button class="btn" id="refresh" type="button">Actualizar</button>
              </div>
            </div>

            <div id="list" class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6"></div>
            <div id="list-error" class="text-error text-sm mt-3" aria-live="polite"></div>
          </div>
        </div>
      </section>

      <section id="publicar" class="lg:col-span-1">
        <div class="card bg-base-100 shadow-xl">
          <div class="card-body">
            <h2 class="card-title">Publicar</h2>
            <p class="text-sm opacity-70">Crea un producto para otros universitarios.</p>

            <form id="publish-form" class="grid gap-3 mt-4">
              <label class="form-control w-full">
                <div class="label"><span class="label-text">Título</span></div>
                <input name="titulo" required class="input input-bordered w-full" />
              </label>

              <label class="form-control w-full">
                <div class="label"><span class="label-text">Descripción</span></div>
                <textarea name="descripcion" required class="textarea textarea-bordered w-full" rows="4"></textarea>
              </label>

              <label class="form-control w-full">
                <div class="label"><span class="label-text">Categoría</span></div>
                <select name="categoria" required class="select select-bordered w-full">
                  <option value="ELECTRONICA">Electrónica</option>
                  <option value="LIBROS">Libros</option>
                  <option value="DEPORTE">Deporte</option>
                  <option value="HOGAR">Hogar</option>
                  <option value="OTROS">Otros</option>
                </select>
              </label>

              <label class="form-control w-full">
                <div class="label"><span class="label-text">Tipo</span></div>
                <select name="tipoTransaccion" required class="select select-bordered w-full">
                  <option value="VENTA">Venta</option>
                  <option value="ALQUILER">Alquiler</option>
                  <option value="PRESTAMO">Préstamo</option>
                </select>
              </label>

              <label class="form-control w-full">
                <div class="label"><span class="label-text">Precio (€)</span></div>
                <input name="precio" type="number" min="0" step="0.01" class="input input-bordered w-full" />
              </label>

              <label class="form-control w-full">
                <div class="label"><span class="label-text">ID propietario</span></div>
                <input name="idPropietario" type="number" min="1" step="1" value="1" required class="input input-bordered w-full" />
              </label>

              <button class="btn btn-primary" type="submit">Publicar</button>
              <div id="publish-msg" class="text-sm" aria-live="polite"></div>
            </form>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script type="module">
    import { API_BASE } from "../lib/env";

    const token = localStorage.getItem("ufvshares_token");
    const email = localStorage.getItem("ufvshares_email");

    if (!token) {
      window.location.href = `/auth?mode=login&next=${encodeURIComponent("/app")}`;
    }

    const whoamiEl = document.getElementById("whoami");
    whoamiEl.textContent = email ? `Sesión: ${email}` : "";

    const listEl = document.getElementById("list");
    const listErrorEl = document.getElementById("list-error");
    const filterEl = document.getElementById("filter");

    function fmtTipo(t) {
      if (t === "ALQUILER") return "Alquiler";
      if (t === "PRESTAMO") return "Préstamo";
      return "Venta";
    }

    function fmtCategoria(c) {
      if (c === "ELECTRONICA") return "Electrónica";
      if (c === "LIBROS") return "Libros";
      if (c === "DEPORTE") return "Deporte";
      if (c === "HOGAR") return "Hogar";
      return "Otros";
    }

    function render(products) {
      listEl.innerHTML = "";
      if (!products.length) {
        listEl.innerHTML = '<div class="opacity-70">No hay productos para este filtro.</div>';
        return;
      }

      for (const p of products) {
        const card = document.createElement("div");
        card.className = "card bg-base-100 border border-base-200";

        const price = p.precio == null ? "—" : `€${Number(p.precio).toFixed(2)}`;
        card.innerHTML = `
          <div class="card-body">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="font-bold leading-tight">${p.titulo}</h3>
                <div class="text-sm opacity-70">Propietario #${p.idPropietario}</div>
              </div>
              <div class="text-right">
                <div class="font-extrabold">${price}</div>
                <div class="badge badge-primary badge-outline mt-2">${fmtTipo(p.tipoTransaccion)}</div>
              </div>
            </div>
            <p class="text-sm opacity-80">${p.descripcion}</p>
            <div class="text-xs opacity-70">${fmtCategoria(p.categoria)}</div>
          </div>
        `;
        listEl.appendChild(card);
      }
    }

    async function load() {
      listErrorEl.textContent = "";

      try {
        const res = await fetch(`${API_BASE}/productos`);
        const body = await res.json().catch(() => ([]));

        if (!res.ok) {
          listErrorEl.textContent = "No se pudieron cargar los productos";
          return;
        }

        const products = Array.isArray(body) ? body : [];
        const selectedType = String(filterEl.value || "").trim();
        const filtered = selectedType ? products.filter((x) => x.tipoTransaccion === selectedType) : products;
        render(filtered);
      } catch {
        listErrorEl.textContent = "No se pudo conectar con el backend";
      }
    }

    document.getElementById("refresh").addEventListener("click", load);
    filterEl.addEventListener("change", load);

    document.getElementById("logout").addEventListener("click", () => {
      localStorage.removeItem("ufvshares_token");
      localStorage.removeItem("ufvshares_email");
      window.location.href = "/";
    });

    const publishForm = document.getElementById("publish-form");
    const publishMsg = document.getElementById("publish-msg");

    publishForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      publishMsg.textContent = "";
      publishMsg.className = "text-sm";

      const formData = new FormData(publishForm);
      const precioRaw = String(formData.get("precio") || "").trim();

      const payload = {
        titulo: String(formData.get("titulo") || "").trim(),
        descripcion: String(formData.get("descripcion") || "").trim(),
        categoria: String(formData.get("categoria") || "OTROS"),
        tipoTransaccion: String(formData.get("tipoTransaccion") || "VENTA"),
        estadoProducto: "DISPONIBLE",
        precio: precioRaw ? Number(precioRaw) : null,
        idPropietario: Number(formData.get("idPropietario") || 1)
      };

      try {
        const res = await fetch(`${API_BASE}/productos`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });

        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          publishMsg.className = "text-error text-sm";
          publishMsg.textContent = body?.error || "No se pudo publicar";
          return;
        }

        publishMsg.className = "text-success text-sm";
        publishMsg.textContent = "Publicado correctamente";
        publishForm.reset();
        await load();
      } catch {
        publishMsg.className = "text-error text-sm";
        publishMsg.textContent = "No se pudo conectar con el backend";
      }
    });

    load();

    if (window.location.hash === "#publicar") {
      document.getElementById("publicar")?.scrollIntoView({ behavior: "smooth" });
    }
  </script>
</Layout>