---
import '../styles/site.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>UFV Shares · Inicio</title>
  </head>
  <body>
    <div class="container">
      <header class="header">
        <div class="brand">
          <img class="logo" src="/Logo.png" onerror="this.onerror=null;this.src='/ufv-badge.svg'" alt="UFV" width="42" height="42" />
          <div>
            <h1>Inicio</h1>
            <div class="subtitle" id="whoami"></div>
          </div>
        </div>
        <div class="row">
          <a class="button" href="/">Landing</a>
          <button class="button" id="logout">Cerrar sesión</button>
        </div>
      </header>

      <div class="grid">
        <section class="panel" aria-label="Listado de productos">
          <div class="row" style="justify-content: space-between; align-items: flex-end;">
            <div>
              <strong>Productos</strong>
              <div class="muted small" style="margin-top: 4px;">Explora, filtra y encuentra lo que necesitas.</div>
            </div>
            <div class="row">
              <label class="field" style="min-width: 180px;">
                Filtrar
                <select id="filter">
                  <option value="">Todos</option>
                  <option value="VENTA">Venta</option>
                  <option value="ALQUILER">Alquiler</option>
                  <option value="PRESTAMO">Préstamo</option>
                </select>
              </label>
              <button class="button" id="refresh">Actualizar</button>
            </div>
          </div>

          <div id="list" class="products"></div>
          <div id="list-error" class="error" aria-live="polite"></div>
        </section>

        <section id="publicar" class="panel" aria-label="Publicar producto">
          <strong>Publicar un producto</strong>
          <p class="muted small">Crea un anuncio para otros universitarios.</p>

          <form id="publish-form">
            <label class="field">
              Título
              <input name="title" required />
            </label>

            <label class="field">
              Descripción
              <textarea name="description" required></textarea>
            </label>

            <label class="field">
              Tipo
              <select name="type" required>
                <option value="SALE">Venta</option>
                <option value="RENT">Alquiler</option>
              </select>
            </label>

            <label class="field">
              Precio (€)
              <input name="price" type="number" min="0" step="0.01" required />
            </label>

            <button class="button button--primary" type="submit">Publicar</button>
            <div id="publish-msg" aria-live="polite"></div>
          </form>
        </section>
      </div>
    </div>

    <script type="module">
      const API_BASE = 'http://localhost:8080/api';
      const token = localStorage.getItem('ufvshares_token');
      const email = localStorage.getItem('ufvshares_email');

      if (!token) {
        window.location.href = `/login?next=${encodeURIComponent('/app')}`;
      }

      document.getElementById('whoami').textContent = email ? `Sesión: ${email}` : '';

      const listEl = document.getElementById('list');
      const listErrorEl = document.getElementById('list-error');
      const filterEl = document.getElementById('filter');

      function fmtType(t) {
        if (t === 'ALQUILER') return 'Alquiler';
        if (t === 'PRESTAMO') return 'Préstamo';
        return 'Venta';
      }

      function render(products) {
        listEl.innerHTML = '';
        if (!products.length) {
          listEl.innerHTML = '<div class="muted">No hay productos para este filtro.</div>';
          return;
        }

        for (const p of products) {
          const card = document.createElement('div');
          card.className = 'card product-card';
          card.innerHTML = `
            <div class="meta">
              <div>
                <div class="product-title"><strong>${p.titulo}</strong></div>
                <div class="small muted">Publicado por usuario #${p.idPropietario}</div>
              </div>
              <div class="row">
                <span class="chip">${fmtType(p.tipoTransaccion)}</span>
                <span class="chip">${p.precio == null ? 'Sin precio' : `€${Number(p.precio).toFixed(2)}`}</span>
              </div>
            </div>
            <div class="muted">${p.descripcion}</div>
          `;
          listEl.appendChild(card);
        }
      }

      async function load() {
        listErrorEl.textContent = '';
        const selectedType = filterEl.value;
        const url = new URL(`${API_BASE}/productos`);

        try {
          const res = await fetch(url);
          const body = await res.json().catch(() => ([]));
          if (!res.ok) {
            listErrorEl.textContent = 'No se pudieron cargar los productos';
            return;
          }
          const products = Array.isArray(body) ? body : [];
          const filtered = selectedType ? products.filter((product) => product.tipoTransaccion === selectedType) : products;
          render(filtered);
        } catch (e) {
          listErrorEl.textContent = 'No se pudo conectar con el backend';
        }
      }

      document.getElementById('refresh').addEventListener('click', load);
      filterEl.addEventListener('change', load);

      document.getElementById('logout').addEventListener('click', () => {
        localStorage.removeItem('ufvshares_token');
        localStorage.removeItem('ufvshares_email');
        window.location.href = '/';
      });

      const publishForm = document.getElementById('publish-form');
      const publishMsg = document.getElementById('publish-msg');

      publishForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        publishMsg.textContent = '';

        const formData = new FormData(publishForm);
        const payload = {
          title: String(formData.get('title') || ''),
          description: String(formData.get('description') || ''),
          type: String(formData.get('type') || 'SALE'),
          price: Number(formData.get('price') || 0)
        };

        try {
          const res = await fetch(`${API_BASE}/products`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(payload)
          });

          const body = await res.json().catch(() => ({}));
          if (!res.ok) {
            if (body?.error === 'INVALID_TOKEN' || body?.error === 'MISSING_TOKEN') {
              localStorage.removeItem('ufvshares_token');
              localStorage.removeItem('ufvshares_email');
              window.location.href = `/login?next=${encodeURIComponent('/app')}`;
              return;
            }
            publishMsg.className = 'error';
            publishMsg.textContent = body?.error || 'No se pudo publicar';
            return;
          }

          publishMsg.className = 'ok';
          publishMsg.textContent = 'Publicado correctamente';
          publishForm.reset();
          await load();
        } catch (e) {
          publishMsg.className = 'error';
          publishMsg.textContent = 'No se pudo conectar con el backend';
        }
      });

      load();

      // Si vienes de la landing con ancla
      if (window.location.hash === '#publicar') {
        document.getElementById('publicar')?.scrollIntoView({ behavior: 'smooth' });
      }
    </script>
  </body>
</html>
