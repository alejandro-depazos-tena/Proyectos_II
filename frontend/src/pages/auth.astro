---
import "../styles/global.css";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
const AUTH_PAGE_API_BASE = API_BASE;
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>UFV Shares &middot; Acceso</title>
    <script define:vars={{ AUTH_PAGE_API_BASE }}>
      (function() {
        const token = localStorage.getItem("ufvshares_token");
        if (!token) return;

        function clearSession() {
          ["ufvshares_token", "ufvshares_email", "ufvshares_nombre", "ufvshares_id"].forEach((key) => {
            localStorage.removeItem(key);
          });
        }

        function tokenState(tokenValue) {
          try {
            const parts = tokenValue.split(".");
            if (parts.length < 2) return "unknown";
            const payload = JSON.parse(atob(parts[1].replace(/-/g, "+").replace(/_/g, "/")));
            if (!payload || typeof payload.exp !== "number") return "unknown";
            return payload.exp * 1000 <= Date.now() ? "expired" : "valid";
          } catch (_) {
            return "unknown";
          }
        }

        if (tokenState(token) === "expired") {
          clearSession();
          return;
        }

        fetch(AUTH_PAGE_API_BASE + "/me", { headers: { Authorization: "Bearer " + token } })
          .then((res) => {
            if (!res.ok) {
              clearSession();
              return;
            }
            const next = new URLSearchParams(location.search).get("next") || "/app";
            location.replace(next);
          })
          .catch(() => {
            const next = new URLSearchParams(location.search).get("next") || "/app";
            location.replace(next);
          });
      })();
    </script>
  </head>
  <body class="bg-base-200 min-h-screen flex items-center justify-center px-4 py-12">

    <div class="w-full max-w-md">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex flex-col items-center gap-2">
          <div class="w-14 h-14 bg-primary rounded-2xl flex items-center justify-center shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-primary-content" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>
            </svg>
          </div>
          <span class="text-2xl font-extrabold tracking-tight text-primary">UFV<span class="text-base-content"> Shares</span></span>
        </a>
        <p class="text-base-content/60 mt-2 text-sm">Marketplace universitario</p>
      </div>

      <!-- Card -->
      <div class="card bg-base-100 shadow-2xl">
        <div class="card-body gap-6">
          <div>
            <h1 id="card-title" class="text-2xl font-extrabold text-center">Bienvenido de vuelta</h1>
            <p id="card-subtitle" class="text-center text-sm text-base-content/60 mt-1">Inicia sesión para acceder a la app.</p>
          </div>

          <!-- Tabs -->
          <div class="tabs tabs-boxed w-full">
            <button id="tab-login" class="tab flex-1 tab-active" type="button">Iniciar sesión</button>
            <button id="tab-register" class="tab flex-1" type="button">Registrarse</button>
          </div>

          <!-- Form -->
          <form id="auth-form" class="grid gap-4" novalidate>

            <!-- Solo registro -->
            <div id="register-fields" class="hidden grid gap-4">
              <div class="grid grid-cols-2 gap-4">
                <label class="form-control w-full">
                  <div class="label"><span class="label-text font-medium">Nombre</span></div>
                  <input id="f-nombre" name="nombre" type="text" autocomplete="given-name" placeholder="Ana" class="input input-bordered w-full" />
                  <p id="err-nombre" class="text-error text-xs mt-1 min-h-[1rem]"></p>
                </label>
                <label class="form-control w-full">
                  <div class="label"><span class="label-text font-medium">Apellidos</span></div>
                  <input id="f-apellidos" name="apellidos" type="text" autocomplete="family-name" placeholder="García López" class="input input-bordered w-full" />
                  <p id="err-apellidos" class="text-error text-xs mt-1 min-h-[1rem]"></p>
                </label>
              </div>
            </div>

            <!-- Correo siempre -->
            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Correo electrónico</span></div>
              <input id="f-email" name="email" type="email" autocomplete="email" required placeholder="tu@ufv.es" class="input input-bordered w-full" />
              <p id="err-email" class="text-error text-xs mt-1 min-h-[1rem]"></p>
            </label>

            <!-- Solo registro -->
            <div id="register-fields-2" class="hidden grid gap-4">
              <div class="grid grid-cols-2 gap-4">
                <label class="form-control w-full">
                  <div class="label"><span class="label-text font-medium">Teléfono</span></div>
                  <input id="f-telefono" name="telefono" type="tel" autocomplete="tel" placeholder="612345678" class="input input-bordered w-full" />
                  <p id="err-telefono" class="text-error text-xs mt-1 min-h-[1rem]"></p>
                </label>
                <label class="form-control w-full">
                  <div class="label"><span class="label-text font-medium">DNI / NIE</span></div>
                  <input id="f-dni" name="dni" type="text" placeholder="12345678A" class="input input-bordered w-full" />
                  <p id="err-dni" class="text-error text-xs mt-1 min-h-[1rem]"></p>
                </label>
              </div>
              <label class="form-control w-full">
                <div class="label"><span class="label-text font-medium">Pregunta de seguridad</span></div>
                <select id="f-pregunta-seguridad" name="preguntaSeguridad" class="select select-bordered w-full">
                  <option value="">Selecciona una pregunta</option>
                  <option value="¿Cuál es el nombre de tu primera mascota?">¿Cuál es el nombre de tu primera mascota?</option>
                  <option value="¿Cuál es tu ciudad de nacimiento?">¿Cuál es tu ciudad de nacimiento?</option>
                  <option value="¿Cuál es tu comida favorita?">¿Cuál es tu comida favorita?</option>
                  <option value="¿Cuál fue tu primer colegio?">¿Cuál fue tu primer colegio?</option>
                </select>
                <p id="err-pregunta-seguridad" class="text-error text-xs mt-1 min-h-[1rem]"></p>
              </label>
              <label class="form-control w-full">
                <div class="label"><span class="label-text font-medium">Respuesta de seguridad</span></div>
                <input id="f-respuesta-seguridad" name="respuestaSeguridad" type="text" placeholder="Tu respuesta" class="input input-bordered w-full" />
                <p id="err-respuesta-seguridad" class="text-error text-xs mt-1 min-h-[1rem]"></p>
              </label>
            </div>

            <!-- Contraseña siempre -->
            <div class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Contraseña</span></div>
              <div class="relative">
                <input id="f-password" name="password" type="password" autocomplete="current-password" required placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" class="input input-bordered w-full pr-12" />
                <button id="toggle-password" type="button" aria-label="Mostrar contraseña" class="absolute right-3 top-1/2 -translate-y-1/2 text-base-content/50 hover:text-base-content transition-colors">
                  <!-- ojo abierto -->
                  <svg id="icon-eye" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.477 0 8.268 2.943 9.542 7-1.274 4.057-5.065 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                  </svg>
                  <!-- ojo cerrado -->
                  <svg id="icon-eye-off" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.477 0-8.268-2.943-9.542-7a9.956 9.956 0 012.223-3.592M6.938 6.938A9.956 9.956 0 0112 5c4.477 0 8.268 2.943 9.542 7a9.962 9.962 0 01-4.48 5.587M3 3l18 18"/>
                  </svg>
                </button>
              </div>
              <p id="err-password" class="text-error text-xs mt-1 min-h-[1rem]"></p>
            </div>

            <button id="submit-btn" class="btn btn-primary w-full mt-2" type="submit">Entrar</button>
            <div id="error" class="text-error text-sm text-center" aria-live="polite"></div>
          </form>

          <div class="text-right -mt-2">
            <a id="forgot-password-link" href="/forgot-password" class="link link-hover text-xs text-primary">¿Has olvidado tu contraseña?</a>
          </div>

          <div class="divider text-xs text-base-content/40">o</div>

          <a class="btn btn-ghost btn-sm w-full" href="/">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Volver al inicio
          </a>
        </div>
      </div>
    </div>

    <script define:vars={{ API_BASE }}>
      const params = new URLSearchParams(window.location.search);
      let mode = params.get("mode") === "register" ? "register" : "login";
      const next = params.get("next") || "/app";

      const tabLogin     = document.getElementById("tab-login");
      const tabRegister  = document.getElementById("tab-register");
      const regFields    = document.getElementById("register-fields");
      const regFields2   = document.getElementById("register-fields-2");
      const cardTitle    = document.getElementById("card-title");
      const cardSubtitle = document.getElementById("card-subtitle");
      const submitBtn    = document.getElementById("submit-btn");
      const errorEl      = document.getElementById("error");
      const fNombre      = document.getElementById("f-nombre");
      const fApellidos   = document.getElementById("f-apellidos");
      const fTelefono    = document.getElementById("f-telefono");
      const fDni         = document.getElementById("f-dni");
      const fPassword    = document.getElementById("f-password");
      const fPreguntaSeguridad = document.getElementById("f-pregunta-seguridad");
      const fRespuestaSeguridad = document.getElementById("f-respuesta-seguridad");
      const forgotPasswordLink = document.getElementById("forgot-password-link");

      // ── Toggle contraseña ─────────────────────────────────────
      document.getElementById("toggle-password").addEventListener("click", function() {
        const visible = fPassword.type === "text";
        fPassword.type = visible ? "password" : "text";
        document.getElementById("icon-eye").classList.toggle("hidden", !visible);
        document.getElementById("icon-eye-off").classList.toggle("hidden", visible);
        this.setAttribute("aria-label", visible ? "Mostrar contraseña" : "Ocultar contraseña");
      });
      // ─────────────────────────────────────────────────────────

      // ── Validación ─────────────────────────────────────────────
      function setFieldError(field, msg) {
        const errEl = document.getElementById("err-" + field);
        const input = document.getElementById("f-" + field);
        if (errEl) errEl.textContent = msg || "";
        if (input) input.classList.toggle("input-error", !!msg);
      }
      function clearErrors() {
        ["nombre","apellidos","email","telefono","dni","password","pregunta-seguridad","respuesta-seguridad"].forEach(f => setFieldError(f, ""));
      }
      function validateRegister(p) {
        const e = {};
        if (!p.nombre    || p.nombre.length    < 2) e.nombre    = "El nombre debe tener al menos 2 caracteres.";
        if (!p.apellidos || p.apellidos.length < 2) e.apellidos = "Los apellidos deben tener al menos 2 caracteres.";
        if (!p.email     || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(p.email)) e.email = "Introduce un correo electrónico válido.";
        if (!p.telefono  || !/^[6789]\d{8}$/.test(p.telefono))           e.telefono = "Teléfono: 9 dígitos empezando por 6, 7, 8 o 9.";
        if (!p.dni       || !/^(\d{8}[A-Z]|[XYZ]\d{7}[A-Z])$/.test(p.dni.toUpperCase())) e.dni = "DNI: 12345678A · NIE: X1234567B.";
        if (!p.preguntaSeguridad) e["pregunta-seguridad"] = "Selecciona una pregunta de seguridad.";
        if (!p.respuestaSeguridad || p.respuestaSeguridad.trim().length < 2) e["respuesta-seguridad"] = "La respuesta debe tener al menos 2 caracteres.";
        if (!p.password  || p.password.length < 8)  e.password = "Mínimo 8 caracteres.";
        else if (!/[A-Z]/.test(p.password))         e.password = "Debe incluir al menos una mayúscula.";
        else if (!/[0-9]/.test(p.password))         e.password = "Debe incluir al menos un número.";
        return e;
      }
      // ───────────────────────────────────────────────────────────

      function setMode(m) {
        mode = m;
        const isReg = m === "register";

        tabLogin.classList.toggle("tab-active", !isReg);
        tabRegister.classList.toggle("tab-active", isReg);

        regFields.style.display  = isReg ? "grid" : "none";
        regFields2.style.display = isReg ? "grid" : "none";

        fNombre.required    = isReg;
        fApellidos.required = isReg;
        fTelefono.required  = isReg;
        fDni.required       = isReg;
        fPreguntaSeguridad.required = isReg;
        fRespuestaSeguridad.required = isReg;
        fPassword.autocomplete = isReg ? "new-password" : "current-password";

        cardTitle.textContent    = isReg ? "Crear cuenta" : "Bienvenido de vuelta";
        cardSubtitle.textContent = isReg ? "Rellena los datos para registrarte." : "Inicia sesión para acceder a la app.";
        submitBtn.textContent    = isReg ? "Crear cuenta" : "Entrar";

        const url = new URL(window.location.href);
        url.searchParams.set("mode", m);
        history.replaceState(null, "", url.toString());
        errorEl.textContent = "";
        clearErrors();
      }

      tabLogin.addEventListener("click", () => setMode("login"));
      tabRegister.addEventListener("click", () => setMode("register"));
      forgotPasswordLink?.addEventListener("click", (e) => {
        e.preventDefault();
        window.location.assign("/forgot-password");
      });
      setMode(mode);

      document.getElementById("auth-form").addEventListener("submit", async function(e) {
        e.preventDefault();
        errorEl.textContent = "";
        clearErrors();

        const formData = new FormData(e.currentTarget);
        let payload;

        if (mode === "register") {
          payload = {
            email:     (formData.get("email")     || "").trim(),
            password:  (formData.get("password")  || ""),
            nombre:    (formData.get("nombre")    || "").trim(),
            apellidos: (formData.get("apellidos") || "").trim(),
            telefono:  (formData.get("telefono")  || "").trim(),
            dni:       (formData.get("dni")       || "").trim().toUpperCase(),
            preguntaSeguridad: (formData.get("preguntaSeguridad") || "").trim(),
            respuestaSeguridad: (formData.get("respuestaSeguridad") || "").trim(),
          };
          const errors = validateRegister(payload);
          if (Object.keys(errors).length > 0) {
            Object.entries(errors).forEach(([field, msg]) => setFieldError(field, msg));
            return;
          }
        } else {
          payload = {
            email:    (formData.get("email")    || "").trim(),
            password: (formData.get("password") || ""),
          };
        }

        submitBtn.disabled = true;
        submitBtn.textContent = "Cargando...";

        try {
          const endpoint = mode === "register" ? "register" : "login";
          const res = await fetch(API_BASE + "/auth/" + endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload),
          });

          const body = await res.json().catch(function() { return {}; });
          if (!res.ok) {
            const msgs = {
              EMAIL_ALREADY_EXISTS:    "Este correo ya está registrado.",
              DNI_ALREADY_EXISTS:      "Este DNI/NIE ya está registrado.",
              TELEFONO_ALREADY_EXISTS: "Este teléfono ya está registrado.",
              INVALID_CREDENTIALS:     "Email o contraseña incorrectos.",
            };
            errorEl.textContent = msgs[body && body.error] || "Error de autenticación";
            return;
          }

          localStorage.setItem("ufvshares_token", body.token);
          localStorage.setItem("ufvshares_email", body.email);
          if (body.nombre) localStorage.setItem("ufvshares_nombre", body.nombre);
          window.location.href = next;
        } catch(err) {
          errorEl.textContent = "No se pudo conectar con el backend";
        } finally {
          submitBtn.disabled = false;
          submitBtn.textContent = mode === "register" ? "Crear cuenta" : "Entrar";
        }
      });
    </script>
  </body>
</html>