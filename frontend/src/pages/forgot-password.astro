---
import "../styles/global.css";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UFV Shares · Recuperar contraseña</title>
    <script is:inline>
      (function () {
        var THEME_KEY = "ufvshares_theme";
        var preferred = "light";
        try {
          var stored = localStorage.getItem(THEME_KEY);
          if (stored === "light" || stored === "dark") {
            preferred = stored;
          } else if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            preferred = "dark";
          }
        } catch (_) {}
        document.documentElement.setAttribute("data-theme", preferred);
      })();
    </script>
  </head>
  <body class="bg-base-200 min-h-screen flex items-center justify-center px-4 py-12">
    <button id="theme-toggle-floating" type="button" class="theme-switch fixed top-3 right-3 z-50" role="switch" aria-checked="false" aria-label="Cambiar tema" title="Cambiar tema">
      <span class="theme-switch-thumb">
        <span id="theme-thumb-icon" class="theme-switch-icon">☀️</span>
      </span>
    </button>
    <div class="w-full max-w-md card bg-base-100 shadow-2xl">
      <div class="card-body gap-5">
        <h1 class="text-2xl font-extrabold text-center">Recuperar contraseña</h1>
        <p class="text-sm text-base-content/70 text-center">
          Primero identifica tu cuenta, responde tu pregunta de seguridad y crea tu nueva contraseña.
        </p>

        <form id="forgot-form" class="grid gap-4" novalidate>
          <label class="form-control w-full">
            <div class="label"><span class="label-text font-medium">Correo electrónico</span></div>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="tu@ufv.es" class="input input-bordered w-full" />
            <p id="error" class="text-error text-xs mt-1 min-h-[1rem]"></p>
          </label>

          <div id="security-block" class="hidden grid gap-4">
            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Pregunta de seguridad</span></div>
              <input id="question" type="text" class="input input-bordered w-full" readonly />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Respuesta</span></div>
              <input id="security-answer" name="securityAnswer" type="text" class="input input-bordered w-full" placeholder="Tu respuesta" />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Nueva contraseña</span></div>
              <input id="password" name="password" type="password" minlength="8" class="input input-bordered w-full" placeholder="Mínimo 8 caracteres" />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Confirmar contraseña</span></div>
              <input id="password-confirm" name="passwordConfirm" type="password" minlength="8" class="input input-bordered w-full" placeholder="Repite la contraseña" />
            </label>
          </div>

          <button id="submit-btn" type="submit" class="btn btn-primary w-full">Continuar</button>
        </form>

        <div id="success" class="alert alert-success hidden text-sm">
          Contraseña actualizada correctamente. Ya puedes iniciar sesión.
        </div>

        <a href="/auth?mode=login" class="btn btn-ghost btn-sm w-full">Volver a iniciar sesión</a>
      </div>
    </div>

    <script define:vars={{ API_BASE }}>
      const form = document.getElementById("forgot-form");
      const submitBtn = document.getElementById("submit-btn");
      const errorEl = document.getElementById("error");
      const successEl = document.getElementById("success");
      const securityBlock = document.getElementById("security-block");
      const questionInput = document.getElementById("question");
      const answerInput = document.getElementById("security-answer");
      const passwordInput = document.getElementById("password");
      const passwordConfirmInput = document.getElementById("password-confirm");

      let loadedQuestion = false;

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl.textContent = "";
        successEl.classList.add("hidden");

        const fd = new FormData(form);
        const email = String(fd.get("email") || "").trim();
        if (!email) {
          errorEl.textContent = "Introduce un correo válido.";
          return;
        }

        try {
          if (!loadedQuestion) {
            submitBtn.disabled = true;
            submitBtn.textContent = "Cargando pregunta...";
            const res = await fetch(API_BASE + "/auth/security-question", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email }),
            });

            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              if (body?.error === "USER_NOT_FOUND") {
                errorEl.textContent = "No existe ninguna cuenta con ese correo electrónico.";
              } else if (body?.error === "SECURITY_QUESTION_NOT_CONFIGURED") {
                errorEl.textContent = "Esta cuenta no tiene pregunta de seguridad configurada. Usa una cuenta registrada con el nuevo formulario.";
              } else {
                errorEl.textContent = "No se pudo cargar la pregunta de seguridad.";
              }
              return;
            }

            questionInput.value = body.question || "";
            securityBlock.classList.remove("hidden");
            loadedQuestion = true;
            submitBtn.textContent = "Actualizar contraseña";
            answerInput?.focus();
            return;
          }

          const securityAnswer = String(answerInput?.value || "").trim();
          const password = String(passwordInput?.value || "");
          const passwordConfirm = String(passwordConfirmInput?.value || "");

          if (!securityAnswer) {
            errorEl.textContent = "Debes responder la pregunta de seguridad.";
            return;
          }
          if (password.length < 8) {
            errorEl.textContent = "La contraseña debe tener al menos 8 caracteres.";
            return;
          }
          if (password !== passwordConfirm) {
            errorEl.textContent = "Las contraseñas no coinciden.";
            return;
          }

          submitBtn.disabled = true;
          submitBtn.textContent = "Actualizando...";

          const res = await fetch(API_BASE + "/auth/reset-password-security", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, securityAnswer, password }),
          });

          const body = await res.json().catch(() => ({}));
          if (!res.ok) {
            if (body?.error === "INVALID_SECURITY_ANSWER") {
              errorEl.textContent = "La respuesta de seguridad no es correcta.";
            } else {
              errorEl.textContent = "No se pudo actualizar la contraseña.";
            }
            return;
          }

          successEl.classList.remove("hidden");
          form.reset();
          securityBlock.classList.add("hidden");
          loadedQuestion = false;
          submitBtn.textContent = "Continuar";
        } catch (_) {
          errorEl.textContent = "No se pudo conectar con el backend.";
        } finally {
          submitBtn.disabled = false;
          if (!loadedQuestion) {
            submitBtn.textContent = "Continuar";
          }
        }
      });

      const THEME_KEY = "ufvshares_theme";
      const themeToggleFloating = document.getElementById("theme-toggle-floating");
      const themeThumbIcon = document.getElementById("theme-thumb-icon");

      function updateThemeButton(theme) {
        const isDark = theme === "dark";
        themeToggleFloating?.classList.toggle("is-dark", isDark);
        themeToggleFloating?.setAttribute("aria-checked", isDark ? "true" : "false");
        if (themeThumbIcon) {
          themeThumbIcon.textContent = isDark ? "🌙" : "☀️";
        }
      }

      function setTheme(theme) {
        document.documentElement.setAttribute("data-theme", theme);
        try {
          localStorage.setItem(THEME_KEY, theme);
        } catch (_) {}
        updateThemeButton(theme);
      }

      if (themeToggleFloating) {
        const initialTheme = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
        updateThemeButton(initialTheme);
        themeToggleFloating.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
          setTheme(current === "dark" ? "light" : "dark");
        });
      }
    </script>
  </body>
</html>
