---
import "../styles/global.css";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
---

<!doctype html>
<html lang="es" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UFV Shares · Recuperar contraseña</title>
    <script is:inline>
      (function () {
        var THEME_KEY = "ufvshares_theme";
        var preferred = "light";
        try {
          var stored = localStorage.getItem(THEME_KEY);
          if (stored === "light" || stored === "dark") {
            preferred = stored;
          } else if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            preferred = "dark";
          }
        } catch (_) {}
        document.documentElement.setAttribute("data-theme", preferred);
      })();
    </script>
  </head>
  <body class="bg-base-200 min-h-screen flex items-center justify-center px-4 py-12">
    <button id="theme-toggle-floating" type="button" class="theme-switch fixed top-3 right-3 z-50" role="switch" aria-checked="false" aria-label="Cambiar tema" title="Cambiar tema">
      <span class="theme-switch-thumb">
        <span id="theme-thumb-icon" class="theme-switch-icon">☀️</span>
      </span>
    </button>
    <div class="w-full max-w-2xl card bg-base-100 shadow-2xl">
      <div class="card-body gap-6">
        <div class="text-center space-y-2">
          <h1 class="text-2xl font-extrabold">Recuperar contraseña</h1>
          <p class="text-sm text-base-content/70">
            Puedes pedir un enlace por correo, usar ese enlace para fijar una nueva contraseña o recurrir al método antiguo por pregunta de seguridad.
          </p>
        </div>

        <div id="request-card" class="grid gap-5">
          <form id="forgot-form" class="grid gap-4" novalidate>
            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Correo electrónico</span></div>
              <input id="email" name="email" type="email" required autocomplete="email" placeholder="tu@ufv.es" class="input input-bordered w-full" />
            </label>

            <p id="request-error" class="text-error text-xs min-h-4"></p>

            <button id="request-submit" type="submit" class="btn btn-primary w-full">Enviar enlace de recuperación</button>
          </form>

          <div id="request-success" class="alert alert-success hidden text-sm">
            <div class="space-y-2">
              <p id="request-success-text">Hemos enviado un enlace de recuperación si la cuenta existe.</p>
              <a id="request-success-link" href="#" class="btn btn-xs btn-outline hidden">Abrir enlace de recuperación</a>
            </div>
          </div>
        </div>

        <div id="token-card" class="fixed inset-0 z-50 bg-black/55 p-4 flex items-center justify-center" style="display:none;">
          <div class="w-full max-w-md card bg-base-100 shadow-2xl">
            <div class="card-body gap-5">
              <div class="text-center space-y-2">
                <h2 class="text-xl font-extrabold">Crear nueva contraseña</h2>
                <p class="text-sm text-base-content/70">
                  Introduce y confirma tu nueva contraseña para completar la recuperación.
                </p>
              </div>

              <form id="token-form" class="grid gap-4" novalidate>
                <input id="reset-token" name="token" type="hidden" />
                <label class="form-control w-full">
                  <div class="label"><span class="label-text font-medium">Nueva contraseña</span></div>
                  <input id="token-password" name="password" type="password" minlength="8" autocomplete="new-password" class="input input-bordered w-full" placeholder="Mínimo 8 caracteres" />
                </label>

                <label class="form-control w-full">
                  <div class="label"><span class="label-text font-medium">Confirmar contraseña</span></div>
                  <input id="token-password-confirm" name="passwordConfirm" type="password" minlength="8" autocomplete="new-password" class="input input-bordered w-full" placeholder="Repite la contraseña" />
                </label>

                <p id="token-error" class="text-error text-xs min-h-4"></p>

                <button id="token-submit" type="submit" class="btn btn-primary w-full">Cambiar contraseña</button>
              </form>

              <div id="token-success" class="alert alert-success hidden text-sm">
                Contraseña actualizada correctamente. Ya puedes iniciar sesión.
              </div>

              <a href="/auth?mode=login" class="btn btn-ghost btn-sm w-full">Volver a iniciar sesión</a>
            </div>
          </div>
        </div>

        <div class="divider">o</div>

        <button id="legacy-toggle" type="button" class="btn btn-ghost btn-sm w-full">Usar método antiguo por pregunta de seguridad</button>

        <div id="legacy-card" class="hidden gap-4 rounded-2xl border border-base-300 bg-base-200/40 p-4">
          <form id="legacy-form" class="grid gap-4" novalidate>
            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Correo electrónico</span></div>
              <input id="legacy-email" name="email" type="email" required autocomplete="email" placeholder="tu@ufv.es" class="input input-bordered w-full" />
            </label>

            <button id="legacy-load" type="submit" class="btn btn-outline btn-primary w-full">Cargar pregunta de seguridad</button>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Pregunta de seguridad</span></div>
              <input id="question" type="text" class="input input-bordered w-full" readonly />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Respuesta</span></div>
              <input id="security-answer" name="securityAnswer" type="text" class="input input-bordered w-full" placeholder="Tu respuesta" />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Nueva contraseña</span></div>
              <input id="password" name="password" type="password" minlength="8" autocomplete="new-password" class="input input-bordered w-full" placeholder="Mínimo 8 caracteres" />
            </label>

            <label class="form-control w-full">
              <div class="label"><span class="label-text font-medium">Confirmar contraseña</span></div>
              <input id="password-confirm" name="passwordConfirm" type="password" minlength="8" autocomplete="new-password" class="input input-bordered w-full" placeholder="Repite la contraseña" />
            </label>

            <p id="legacy-error" class="text-error text-xs min-h-4"></p>

            <button id="legacy-submit" type="submit" class="btn btn-primary w-full hidden">Actualizar contraseña</button>
          </form>

          <div id="legacy-success" class="alert alert-success hidden text-sm">
            Contraseña actualizada correctamente con el método antiguo.
          </div>
        </div>

        <a href="/auth?mode=login" class="btn btn-ghost btn-sm w-full">Volver a iniciar sesión</a>
      </div>
    </div>

    <script define:vars={{ API_BASE }}>
      const requestCard = document.getElementById("request-card");
      const tokenCard = document.getElementById("token-card");
      const legacyCard = document.getElementById("legacy-card");

      const requestForm = document.getElementById("forgot-form");
      const requestSubmit = document.getElementById("request-submit");
      const requestError = document.getElementById("request-error");
      const requestSuccess = document.getElementById("request-success");
      const requestSuccessText = document.getElementById("request-success-text");
      const requestSuccessLink = document.getElementById("request-success-link");

      const tokenForm = document.getElementById("token-form");
      const tokenSubmit = document.getElementById("token-submit");
      const tokenError = document.getElementById("token-error");
      const tokenSuccess = document.getElementById("token-success");
      const tokenInput = document.getElementById("reset-token");
      const tokenPasswordInput = document.getElementById("token-password");
      const tokenPasswordConfirmInput = document.getElementById("token-password-confirm");

      const legacyToggle = document.getElementById("legacy-toggle");
      const legacyForm = document.getElementById("legacy-form");
      const legacySubmit = document.getElementById("legacy-submit");
      const legacyError = document.getElementById("legacy-error");
      const legacySuccess = document.getElementById("legacy-success");

      const questionInput = document.getElementById("question");
      const answerInput = document.getElementById("security-answer");
      const passwordInput = document.getElementById("password");
      const passwordConfirmInput = document.getElementById("password-confirm");
      const legacyEmailInput = document.getElementById("legacy-email");
      const legacyLoadButton = document.getElementById("legacy-load");

      let loadedQuestion = false;
      const token = new URLSearchParams(window.location.search).get("token") || "";

      function setVisible(el, visible) {
        if (!el) return;
        el.classList.toggle("hidden", !visible);
      }

      function setMessage(el, message, visible = true) {
        if (!el) return;
        el.textContent = message;
        setVisible(el, visible);
      }

      if (tokenInput instanceof HTMLInputElement) {
        tokenInput.value = token;
      }

      if (token) {
        setVisible(requestCard, false);
        setVisible(legacyCard, false);
        setVisible(legacyToggle, false);
        if (tokenCard instanceof HTMLElement) {
          tokenCard.style.display = "flex";
        }
        const tokenPasswordField = document.getElementById("token-password");
        if (tokenPasswordField instanceof HTMLInputElement) {
          tokenPasswordField.focus();
        }
      }

      legacyToggle?.addEventListener("click", () => {
        const isHidden = legacyCard?.classList.contains("hidden");
        setVisible(legacyCard, isHidden);
      });

      requestForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        setMessage(requestError, "", false);
        setVisible(requestSuccess, false);

        const fd = new FormData(requestForm);
        const email = String(fd.get("email") || "").trim();
        if (!email) {
          setMessage(requestError, "Introduce un correo válido.");
          return;
        }

        try {
          if (requestSubmit instanceof HTMLButtonElement) {
            requestSubmit.disabled = true;
            requestSubmit.textContent = "Enviando...";
          }

          const res = await fetch(API_BASE + "/auth/forgot-password", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email }),
          });

          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            setMessage(requestError, body?.error === "USER_NOT_FOUND" ? "No existe ninguna cuenta con ese correo electrónico." : "No se pudo enviar el enlace de recuperación.");
            return;
          }

          setVisible(requestSuccess, true);
          if (requestSuccessText) {
            requestSuccessText.textContent = "Hemos enviado un enlace de recuperación si la cuenta existe.";
          }
          if (requestSuccessLink instanceof HTMLAnchorElement) {
            const body = await res.json().catch(() => ({}));
            const resetUrl = String(body?.resetUrl || "");
            if (resetUrl) {
              requestSuccessText && (requestSuccessText.textContent = "No había SMTP configurado, así que te dejo el enlace directo para probar el cambio:");
              requestSuccessLink.href = resetUrl;
              requestSuccessLink.textContent = "Abrir enlace de recuperación";
              requestSuccessLink.classList.remove("hidden");
            } else {
              requestSuccessLink.classList.add("hidden");
            }
          }
          requestForm.reset();
        } catch (_) {
          setMessage(requestError, "No se pudo conectar con el backend.");
        } finally {
          if (requestSubmit instanceof HTMLButtonElement) {
            requestSubmit.disabled = false;
            requestSubmit.textContent = "Enviar enlace de recuperación";
          }
        }
      });

      tokenForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        setMessage(tokenError, "", false);
        setVisible(tokenSuccess, false);

        const password = String(tokenPasswordInput instanceof HTMLInputElement ? tokenPasswordInput.value : "");
        const passwordConfirm = String(tokenPasswordConfirmInput instanceof HTMLInputElement ? tokenPasswordConfirmInput.value : "");

        if (!token) {
          setMessage(tokenError, "Falta el token de recuperación.");
          return;
        }
        if (password.length < 8) {
          setMessage(tokenError, "La contraseña debe tener al menos 8 caracteres.");
          return;
        }
        if (password !== passwordConfirm) {
          setMessage(tokenError, "Las contraseñas no coinciden.");
          return;
        }

        try {
          if (tokenSubmit instanceof HTMLButtonElement) {
            tokenSubmit.disabled = true;
            tokenSubmit.textContent = "Actualizando...";
          }

          const res = await fetch(API_BASE + "/auth/reset-password-token", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ token, password }),
          });

          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            setMessage(tokenError, body?.error === "INVALID_RESET_TOKEN" ? "El enlace ya no es válido o ha caducado." : "No se pudo actualizar la contraseña.");
            return;
          }

          setVisible(tokenSuccess, true);
          tokenForm.reset();
        } catch (_) {
          setMessage(tokenError, "No se pudo conectar con el backend.");
        } finally {
          if (tokenSubmit instanceof HTMLButtonElement) {
            tokenSubmit.disabled = false;
            tokenSubmit.textContent = "Cambiar contraseña";
          }
        }
      });

      legacyForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        setMessage(legacyError, "", false);
        setVisible(legacySuccess, false);

        const fd = new FormData(legacyForm);
        const email = String(fd.get("email") || "").trim();
        if (!loadedQuestion) {
          if (!email) {
            setMessage(legacyError, "Introduce un correo válido.");
            return;
          }

          try {
            if (legacyLoadButton instanceof HTMLButtonElement) {
              legacyLoadButton.disabled = true;
              legacyLoadButton.textContent = "Cargando pregunta...";
            }

            const res = await fetch(API_BASE + "/auth/security-question", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email }),
            });

            const body = await res.json().catch(() => ({}));
            if (!res.ok) {
              if (body?.error === "USER_NOT_FOUND") {
                setMessage(legacyError, "No existe ninguna cuenta con ese correo electrónico.");
              } else if (body?.error === "SECURITY_QUESTION_NOT_CONFIGURED") {
                setMessage(legacyError, "Esta cuenta no tiene pregunta de seguridad configurada.");
              } else {
                setMessage(legacyError, "No se pudo cargar la pregunta de seguridad.");
              }
              return;
            }

            if (questionInput instanceof HTMLInputElement) {
              questionInput.value = body.question || "";
            }
            if (legacyEmailInput instanceof HTMLInputElement) {
              legacyEmailInput.value = email;
            }
            loadedQuestion = true;
            setVisible(legacySubmit, true);
            if (legacyLoadButton instanceof HTMLButtonElement) {
              legacyLoadButton.textContent = "Pregunta cargada";
            }
            answerInput?.focus();
            return;
          } catch (_) {
            setMessage(legacyError, "No se pudo conectar con el backend.");
            return;
          } finally {
            if (legacyLoadButton instanceof HTMLButtonElement) {
              legacyLoadButton.disabled = false;
              if (!loadedQuestion) {
                legacyLoadButton.textContent = "Cargar pregunta de seguridad";
              }
            }
          }
        }

        const securityAnswer = String(answerInput?.value || "").trim();
        const password = String(passwordInput?.value || "");
        const passwordConfirm = String(passwordConfirmInput?.value || "");

        if (!securityAnswer) {
          setMessage(legacyError, "Debes responder la pregunta de seguridad.");
          return;
        }
        if (password.length < 8) {
          setMessage(legacyError, "La contraseña debe tener al menos 8 caracteres.");
          return;
        }
        if (password !== passwordConfirm) {
          setMessage(legacyError, "Las contraseñas no coinciden.");
          return;
        }

        try {
          if (legacySubmit instanceof HTMLButtonElement) {
            legacySubmit.disabled = true;
            legacySubmit.textContent = "Actualizando...";
          }

          const res = await fetch(API_BASE + "/auth/reset-password-security", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ email, securityAnswer, password }),
          });

          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            setMessage(legacyError, body?.error === "INVALID_SECURITY_ANSWER" ? "La respuesta de seguridad no es correcta." : "No se pudo actualizar la contraseña.");
            return;
          }

          setVisible(legacySuccess, true);
          legacyForm.reset();
          loadedQuestion = false;
          setVisible(legacySubmit, false);
          if (legacyLoadButton instanceof HTMLButtonElement) {
            legacyLoadButton.textContent = "Cargar pregunta de seguridad";
          }
        } catch (_) {
          setMessage(legacyError, "No se pudo conectar con el backend.");
        } finally {
          if (legacySubmit instanceof HTMLButtonElement) {
            legacySubmit.disabled = false;
            legacySubmit.textContent = "Actualizar contraseña";
          }
        }
      });

      const THEME_KEY = "ufvshares_theme";
      const themeToggleFloating = document.getElementById("theme-toggle-floating");
      const themeThumbIcon = document.getElementById("theme-thumb-icon");

      function updateThemeButton(theme) {
        const isDark = theme === "dark";
        themeToggleFloating?.classList.toggle("is-dark", isDark);
        themeToggleFloating?.setAttribute("aria-checked", isDark ? "true" : "false");
        if (themeThumbIcon) {
          themeThumbIcon.textContent = isDark ? "🌙" : "☀️";
        }
      }

      function setTheme(theme) {
        document.documentElement.setAttribute("data-theme", theme);
        try {
          localStorage.setItem(THEME_KEY, theme);
        } catch (_) {}
        updateThemeButton(theme);
      }

      if (themeToggleFloating) {
        const initialTheme = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
        updateThemeButton(initialTheme);
        themeToggleFloating.addEventListener("click", () => {
          const current = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
          setTheme(current === "dark" ? "light" : "dark");
        });
      }
    </script>
  </body>
</html>
