---
---

<section class="bg-base-200 py-16 sm:py-20" id="app-reviews">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 sm:mb-10">
      <p class="text-xs font-semibold uppercase tracking-[0.22em] text-primary/80">Comunidad</p>
      <h2 class="text-3xl sm:text-4xl font-black text-base-content mt-2">Reseñas de la app</h2>
      <p class="text-base text-base-content/70 mt-3 max-w-2xl">
        Queremos mejorar UFV Shares en cada iteracion. Deja una reseña sobre tu experiencia general.
      </p>
    </div>

    <div class="grid gap-5 lg:grid-cols-5">
      <article class="lg:col-span-2 rounded-2xl border border-base-300 bg-base-100 shadow-sm p-5 sm:p-6">
        <p class="text-sm text-base-content/60">Valoracion media</p>
        <p id="reviews-avg" class="text-4xl font-black text-base-content mt-2">0.0</p>
        <p id="reviews-stars" class="text-yellow-500 text-xl mt-1 tracking-[0.15em]">-----</p>
        <p id="reviews-count" class="text-sm text-base-content/60 mt-2">Sin reseñas todavia</p>

        <div class="mt-5 rounded-xl border border-base-300 bg-base-200/50 p-4">
          <h3 class="text-sm font-semibold text-base-content">Como evaluamos</h3>
          <p class="text-xs text-base-content/65 mt-1 leading-relaxed">
            Las reseñas se guardan en tu cuenta y se sincronizan entre dispositivos.
            Cada usuario mantiene una reseña activa que puede actualizar cuando quiera.
          </p>
        </div>
      </article>

      <article class="lg:col-span-3 rounded-2xl border border-base-300 bg-base-100 shadow-sm p-5 sm:p-6">
        <h3 class="text-xl font-bold text-base-content">Deja tu reseña</h3>
        <form id="app-review-form" class="mt-4 space-y-4">
          <div class="form-control w-full">
            <span class="label-text text-sm font-medium">Puntuacion</span>
            <div id="rating-picker" class="flex items-center gap-1.5 mt-2" role="radiogroup" aria-label="Puntuacion de 1 a 5">
              <button type="button" data-rating="1" class="rating-star" aria-label="1 estrella">★</button>
              <button type="button" data-rating="2" class="rating-star" aria-label="2 estrellas">★</button>
              <button type="button" data-rating="3" class="rating-star" aria-label="3 estrellas">★</button>
              <button type="button" data-rating="4" class="rating-star" aria-label="4 estrellas">★</button>
              <button type="button" data-rating="5" class="rating-star" aria-label="5 estrellas">★</button>
              <span id="rating-label" class="ml-2 text-xs text-base-content/60">Selecciona una puntuacion</span>
            </div>
          </div>

          <label class="form-control w-full">
            <span class="label-text text-sm font-medium">Comentario</span>
            <textarea
              id="review-comment"
              class="textarea textarea-bordered min-h-[120px]"
              maxlength="280"
              placeholder="Que te esta gustando y que mejorarias..."
              required
            ></textarea>
            <span id="review-help" class="text-xs text-base-content/55 mt-1">Minimo 10 caracteres, maximo 280.</span>
          </label>

          <div class="flex items-center justify-between gap-3">
            <p id="review-feedback" class="text-sm text-base-content/70"></p>
            <button type="submit" class="btn btn-primary rounded-full px-6">Publicar reseña</button>
          </div>
        </form>
      </article>
    </div>

    <article class="mt-6 rounded-2xl border border-base-300 bg-base-100 shadow-sm p-5 sm:p-6">
      <div class="flex items-center justify-between gap-3 mb-4">
        <h3 class="text-xl font-bold text-base-content">Ultimas reseñas</h3>
        <button id="reviews-clear" type="button" class="btn btn-ghost btn-sm">Eliminar mi reseña</button>
      </div>
      <div id="reviews-list" class="space-y-3"></div>
    </article>
  </div>
</section>

<style>
  .rating-star {
    border: none;
    background: transparent;
    font-size: 1.5rem;
    line-height: 1;
    color: #c7cbd3;
    cursor: pointer;
    transition: transform 0.15s ease, color 0.15s ease;
    padding: 0;
  }

  .rating-star:hover {
    transform: translateY(-1px);
  }

  .rating-star.is-active {
    color: #f59e0b;
  }
</style>

<script>
  const API_BASE = (import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api").replace(/\/$/, "");
  const token = localStorage.getItem("ufvshares_token");
  const currentUserId = Number(localStorage.getItem("ufvshares_id") || "0");

  const form = document.getElementById("app-review-form");
  const listEl = document.getElementById("reviews-list");
  const avgEl = document.getElementById("reviews-avg");
  const starsEl = document.getElementById("reviews-stars");
  const countEl = document.getElementById("reviews-count");
  const clearBtn = document.getElementById("reviews-clear");
  const feedbackEl = document.getElementById("review-feedback");
  const commentInput = document.getElementById("review-comment");
  const ratingLabel = document.getElementById("rating-label");
  const starButtons = Array.from(document.querySelectorAll("#rating-picker [data-rating]"));

  let selectedRating = 0;
  let reviews = [];

  function normalizeReview(item) {
    const idUsuario = Number(item?.idUsuario || 0);
    return {
      idReview: Number(item?.idReview || 0),
      idUsuario,
      name: String(item?.nombreUsuario || "Usuario"),
      rating: Number(item?.puntuacion || 0),
      comment: String(item?.comentario || ""),
      createdAt: item?.fechaActualizacion || new Date().toISOString(),
      mine: idUsuario > 0 && idUsuario === currentUserId,
    };
  }

  async function loadReviewsFromApi() {
    const response = await fetch(API_BASE + "/app-reviews");
    if (!response.ok) {
      throw new Error("No se pudieron cargar las reseñas.");
    }
    const data = await response.json();
    if (!Array.isArray(data)) return [];
    return data.map(normalizeReview);
  }

  function renderSummary() {
    const count = reviews.length;
    if (!avgEl || !starsEl || !countEl) return;
    if (count === 0) {
      avgEl.textContent = "0.0";
      starsEl.textContent = "-----";
      countEl.textContent = "Sin reseñas todavia";
      return;
    }

    const total = reviews.reduce((sum, item) => sum + item.rating, 0);
    const avg = total / count;
    const rounded = Math.round(avg);
    avgEl.textContent = avg.toFixed(1);
    starsEl.textContent = "★★★★★".slice(0, rounded).padEnd(5, "☆");
    countEl.textContent = count + " reseña" + (count === 1 ? "" : "s");
  }

  function renderList() {
    if (!listEl) return;
    listEl.innerHTML = "";

    if (reviews.length === 0) {
      const empty = document.createElement("p");
      empty.className = "text-sm text-base-content/60";
      empty.textContent = "Todavia no hay reseñas. Se la primera persona en opinar.";
      listEl.appendChild(empty);
      return;
    }

    reviews.forEach((item) => {
      const card = document.createElement("article");
      card.className = "rounded-xl border border-base-300 bg-base-200/45 p-4";

      const top = document.createElement("div");
      top.className = "flex items-center justify-between gap-3";

      const name = document.createElement("p");
      name.className = "font-semibold text-base-content";
      name.textContent = item.name;

      if (item.mine) {
        const mineBadge = document.createElement("span");
        mineBadge.className = "badge badge-primary badge-sm ml-2";
        mineBadge.textContent = "Tu reseña";
        name.appendChild(mineBadge);
      }

      const rating = document.createElement("p");
      rating.className = "text-sm text-yellow-500 tracking-[0.12em]";
      rating.textContent = "★★★★★".slice(0, item.rating).padEnd(5, "☆");

      top.appendChild(name);
      top.appendChild(rating);

      const comment = document.createElement("p");
      comment.className = "text-sm text-base-content/75 mt-2 leading-relaxed";
      comment.textContent = item.comment;

      const date = document.createElement("p");
      date.className = "text-xs text-base-content/50 mt-2";
      date.textContent = new Date(item.createdAt).toLocaleString("es-ES");

      card.appendChild(top);
      card.appendChild(comment);
      card.appendChild(date);
      listEl.appendChild(card);
    });
  }

  function renderStars() {
    starButtons.forEach((btn) => {
      const value = Number(btn.getAttribute("data-rating") || "0");
      btn.classList.toggle("is-active", value <= selectedRating);
      btn.setAttribute("aria-checked", value === selectedRating ? "true" : "false");
    });
    if (ratingLabel) {
      ratingLabel.textContent = selectedRating > 0
        ? selectedRating + "/5"
        : "Selecciona una puntuacion";
    }
  }

  starButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      selectedRating = Number(btn.getAttribute("data-rating") || "0");
      renderStars();
    });
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const comment = (commentInput?.value || "").trim();

    if (!token) {
      if (feedbackEl) feedbackEl.textContent = "Debes iniciar sesion para publicar una reseña.";
      return;
    }

    if (selectedRating < 1 || selectedRating > 5) {
      if (feedbackEl) feedbackEl.textContent = "Selecciona una puntuacion de 1 a 5.";
      return;
    }

    if (comment.length < 10) {
      if (feedbackEl) feedbackEl.textContent = "El comentario debe tener al menos 10 caracteres.";
      return;
    }

    try {
      const response = await fetch(API_BASE + "/me/app-reviews", {
        method: "POST",
        headers: {
          "Authorization": "Bearer " + token,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          puntuacion: selectedRating,
          comentario: comment.slice(0, 280),
        }),
      });

      if (!response.ok) {
        throw new Error("No se pudo guardar la reseña.");
      }

      reviews = await loadReviewsFromApi();
      renderSummary();
      renderList();

      if (commentInput) commentInput.value = "";
      selectedRating = 0;
      renderStars();
      if (feedbackEl) feedbackEl.textContent = "Reseña guardada. Gracias por tu feedback.";
    } catch (_) {
      if (feedbackEl) feedbackEl.textContent = "No se pudo guardar ahora mismo. Intentalo de nuevo.";
    }
  });

  clearBtn?.addEventListener("click", async () => {
    if (!token) {
      if (feedbackEl) feedbackEl.textContent = "Debes iniciar sesion para gestionar tu reseña.";
      return;
    }

    try {
      const response = await fetch(API_BASE + "/me/app-reviews", {
        method: "DELETE",
        headers: {
          "Authorization": "Bearer " + token,
        },
      });

      if (!response.ok && response.status !== 204) {
        throw new Error("No se pudo eliminar la reseña.");
      }

      reviews = await loadReviewsFromApi();
      renderSummary();
      renderList();
      selectedRating = 0;
      renderStars();
      if (feedbackEl) feedbackEl.textContent = "Tu reseña ha sido eliminada.";
    } catch (_) {
      if (feedbackEl) feedbackEl.textContent = "No se pudo eliminar la reseña ahora mismo.";
    }
  });

  renderStars();

  (async () => {
    try {
      reviews = await loadReviewsFromApi();
      renderSummary();
      renderList();
    } catch (_) {
      reviews = [];
      renderSummary();
      renderList();
      if (feedbackEl) feedbackEl.textContent = "No se pudieron cargar las reseñas por ahora.";
    }
  })();
</script>
