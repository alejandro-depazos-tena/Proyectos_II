---
const team = [
    {
        name: "Jesús de Andrés de Las Heras",
        role: "Desarrollo Full-Stack",
        description:
            "Coordinación del proyecto y desarrollo de las funcionalidades principales de la plataforma.",
        avatar: "JA",
        color: "bg-blue-100 text-blue-700",
    },
    {
        name: "Alejandro de Pazos Tena",
        role: "Frontend & UX",
        description:
            "Diseño y maquetación de la interfaz de usuario, asegurando una experiencia visual moderna y fluida.",
        avatar: "AP",
        color: "bg-violet-100 text-violet-700",
    },
    {
        name: "Mario Hernández Santos",
        role: "Backend & API REST",
        description:
            "Diseño y desarrollo de la API REST con Spring Boot, gestión de la base de datos y lógica de negocio.",
        avatar: "MH",
        color: "bg-emerald-100 text-emerald-700",
    },
    {
        name: "Gonzalo de Lorenzo Vaquero",
        role: "Base de datos & Testing",
        description:
            "Modelado del esquema de datos, migraciones SQL y pruebas de integración del sistema.",
        avatar: "GL",
        color: "bg-amber-100 text-amber-700",
    },
    {
        name: "Nicolás Sanchidrian Infante",
        role: "Infraestructura & DevOps",
        description:
            "Configuración del entorno de desarrollo, gestión de repositorios Git y seguimiento del backlog en Azure DevOps.",
        avatar: "NS",
        color: "bg-rose-100 text-rose-700",
    },
];
---

<section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <span
                class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block"
                >El equipo</span
            >
            <h2
                class="text-3xl md:text-5xl font-black text-slate-900 uppercase"
            >
                Conoce a los desarrolladores
            </h2>
            <p class="text-slate-500 font-medium mt-4">
                Ingeniería Informática · Universidad Francisco de Vitoria
                (UFV) · Promoción 2025
            </p>
        </div>

        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 justify-items-center"
        >
            {
                team.map((member) => (
                    <div class="group relative bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-xl transition-shadow duration-300 w-full max-w-sm overflow-hidden">
                        <!-- Contenido principal -->
                        <div class="p-8 flex flex-col items-center text-center">
                            <div class={`w-20 h-20 rounded-full flex items-center justify-center text-2xl font-black mb-5 ${member.color}`}>
                                {member.avatar}
                            </div>
                            <h3 class="text-lg font-black text-slate-900 mb-1 leading-snug">
                                {member.name}
                            </h3>
                            <span class="text-xs font-bold uppercase tracking-widest text-primary">
                                {member.role}
                            </span>
                        </div>

                        <!-- Panel deslizante desde abajo -->
                        <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-400 ease-out bg-slate-900 px-7 py-6 rounded-b-2xl">
                            <p class="text-slate-300 text-sm leading-relaxed text-center">
                                {member.description}
                            </p>
                        </div>

                        <!-- Línea de color en la parte superior -->
                        <div class={`absolute top-0 left-0 right-0 h-1 ${member.color.replace('bg-', 'bg-').split(' ')[0]}`}></div>
                    </div>
                ))
            }
        </div>

        <!-- Badge universidad -->
        <div class="mt-16 flex justify-center">
            <div
                class="inline-flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-full px-6 py-3"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-5 h-5 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 14l9-5-9-5-9 5 9 5z"
                    ></path>
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
                    ></path>
                </svg>
                <span class="text-sm font-bold text-slate-700"
                    >Proyecto académico · Proyectos II · UFV</span
                >
            </div>
        </div>
    </div>
</section>

<style>
    .duration-400 {
        transition-duration: 400ms;
    }
</style>
