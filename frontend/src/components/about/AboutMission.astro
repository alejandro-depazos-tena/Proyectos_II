---

---

<section class="py-20 px-4">
    <div class="max-w-7xl mx-auto">
        <!-- Quiénes somos -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-24">
            <div class="order-2 md:order-1">
                <span
                    class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block"
                    >Quiénes somos</span
                >
                <h2
                    class="text-3xl md:text-5xl font-black text-slate-900 uppercase mb-6 leading-tight"
                >
                    Un proyecto nacido <br /> en la universidad
                </h2>
                <div
                    class="space-y-4 text-slate-600 leading-relaxed font-medium"
                >
                    <p>
                        Somos un grupo de cinco estudiantes de
                        <strong class="text-slate-800">Ingeniería Informática</strong>
                        de la
                        <strong class="text-slate-800"
                            >Universidad Francisco de Vitoria (UFV)</strong
                        >, unidos por la pasión por la tecnología y el desarrollo
                        de software.
                    </p>
                    <p>
                        UFVShares nació como proyecto académico de la asignatura
                        de <em>Proyectos II</em>, con el objetivo de construir
                        una plataforma de comercio electrónico completa, desde
                        el diseño hasta el despliegue, aplicando todo lo
                        aprendido durante la carrera.
                    </p>
                    <p>
                        La idea fue crear una tienda de tecnología que no solo
                        funcionara bien, sino que también tuviera un diseño
                        moderno y una experiencia de usuario cuidada al detalle.
                    </p>
                </div>
            </div>
            <div class="order-1 md:order-2 relative">
                <div
                    class="aspect-square rounded-2xl overflow-hidden shadow-2xl"
                >
                    <img
                        src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=1200&auto=format&fit=crop"
                        alt="Equipo trabajando"
                        class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                    />
                </div>
                <div
                    class="absolute -bottom-6 -right-6 w-32 h-32 bg-primary/10 rounded-full -z-10 blur-2xl"
                >
                </div>
            </div>
        </div>

        <!-- Cómo está hecha la aplicación -->
        <div class="bg-slate-50 rounded-3xl p-10 md:p-16">
            <div class="text-center max-w-2xl mx-auto mb-12">
                <span
                    class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block"
                    >Stack tecnológico</span
                >
                <h2
                    class="text-3xl md:text-4xl font-black text-slate-900 uppercase"
                >
                    Cómo está construida la aplicación
                </h2>
                <p class="text-slate-500 mt-4 font-medium">
                    Arquitectura moderna de tipo cliente-servidor con tecnologías
                    de nivel profesional.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Frontend -->
                <div
                    class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100"
                >
                    <div
                        class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-6 h-6 text-primary"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        class="text-lg font-black text-slate-900 uppercase tracking-tight mb-3"
                    >
                        Frontend
                    </h3>
                    <ul class="space-y-2 text-slate-500 font-medium text-sm">
                        <li>
                            <span class="font-bold text-slate-700">Astro</span> — Framework principal para SSR y páginas estáticas
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">React</span> — Componentes interactivos (favoritos y paneles dinámicos)
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Tailwind CSS</span> — Sistema de estilos utilitario
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">DaisyUI</span> — Componentes UI sobre Tailwind
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Nanostores</span> — Estado global reactivo
                        </li>
                    </ul>
                </div>

                <!-- Backend -->
                <div
                    class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100"
                >
                    <div
                        class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-6 h-6 text-primary"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        class="text-lg font-black text-slate-900 uppercase tracking-tight mb-3"
                    >
                        Backend
                    </h3>
                    <ul class="space-y-2 text-slate-500 font-medium text-sm">
                        <li>
                            <span class="font-bold text-slate-700">Java 21</span> — Lenguaje principal del servidor
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Spring Boot 3</span> — Framework REST API
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Spring Security</span> — Autenticación y autorización con JWT
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">JPA / Hibernate</span> — ORM para persistencia de datos
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Maven</span> — Gestión de dependencias y builds
                        </li>
                    </ul>
                </div>

                <!-- Base de datos e infraestructura -->
                <div
                    class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100"
                >
                    <div
                        class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center mb-5"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            class="w-6 h-6 text-primary"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"
                            ></path>
                        </svg>
                    </div>
                    <h3
                        class="text-lg font-black text-slate-900 uppercase tracking-tight mb-3"
                    >
                        Datos e infra
                    </h3>
                    <ul class="space-y-2 text-slate-500 font-medium text-sm">
                        <li>
                            <span class="font-bold text-slate-700">H2</span> — Base de datos en memoria para desarrollo
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">MySQL</span> — Base de datos relacional en producción
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">REST API</span> — Comunicación frontend ↔ backend
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Azure DevOps</span> — Gestión de proyecto y sprints
                        </li>
                        <li>
                            <span class="font-bold text-slate-700">Git / GitHub</span> — Control de versiones y colaboración
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Metodología Scrum -->
        <div class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div class="relative">
                <div class="bg-primary/5 rounded-3xl p-10 border border-primary/10">
                    <!-- Sprint cycle visual -->
                    <div class="flex items-center justify-center gap-3 flex-wrap">
                        {["Product Backlog", "Sprint Planning", "Sprint (2 sem.)", "Sprint Review", "Retrospectiva"].map((item, i) => (
                            <div class="flex items-center gap-2">
                                <div class="bg-primary text-white text-xs font-bold rounded-full w-7 h-7 flex items-center justify-center shrink-0">
                                    {i + 1}
                                </div>
                                <span class="text-slate-700 font-semibold text-sm">{item}</span>
                                {i < 4 && <span class="text-primary font-bold text-lg">→</span>}
                            </div>
                        ))}
                    </div>
                    <div class="mt-8 grid grid-cols-3 gap-4 text-center">
                        <div class="bg-white rounded-xl p-4 shadow-sm">
                            <p class="text-2xl font-black text-primary">4</p>
                            <p class="text-xs font-semibold text-slate-500 mt-1">Sprints</p>
                        </div>
                        <div class="bg-white rounded-xl p-4 shadow-sm">
                            <p class="text-2xl font-black text-primary">2</p>
                            <p class="text-xs font-semibold text-slate-500 mt-1">Semanas/sprint</p>
                        </div>
                        <div class="bg-white rounded-xl p-4 shadow-sm">
                            <p class="text-2xl font-black text-primary">5</p>
                            <p class="text-xs font-semibold text-slate-500 mt-1">Miembros</p>
                        </div>
                    </div>
                </div>
            </div>
            <div>
                <span class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block">
                    Metodología de trabajo
                </span>
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 uppercase mb-6 leading-tight">
                    Desarrollado con Scrum
                </h2>
                <div class="space-y-4 text-slate-600 leading-relaxed font-medium">
                    <p>
                        Todo el proyecto ha sido gestionado siguiendo la metodología ágil
                        <strong class="text-slate-800">Scrum</strong>, organizando el trabajo
                        en sprints de dos semanas con entregas incrementales y revisiones
                        continuas.
                    </p>
                    <p>
                        El equipo adoptó los roles clásicos de Scrum: un
                        <strong class="text-slate-800">Product Owner</strong> responsable del
                        backlog y las prioridades, un
                        <strong class="text-slate-800">Scrum Master</strong> que facilitó los
                        procesos y eliminó impedimentos, y el
                        <strong class="text-slate-800">Development Team</strong> encargado de
                        la implementación.
                    </p>
                    <ul class="space-y-2 mt-4">
                        <li class="flex items-start gap-3">
                            <span class="w-2 h-2 rounded-full bg-primary mt-2 shrink-0"></span>
                            <span><strong class="text-slate-800">Daily Standups</strong> para sincronizar el trabajo diario y detectar bloqueos.</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-2 h-2 rounded-full bg-primary mt-2 shrink-0"></span>
                            <span><strong class="text-slate-800">Sprint Planning</strong> con estimación de tareas en story points.</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-2 h-2 rounded-full bg-primary mt-2 shrink-0"></span>
                            <span><strong class="text-slate-800">Azure DevOps</strong> como tablero Kanban, gestión de backlog y seguimiento de sprints.</span>
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-2 h-2 rounded-full bg-primary mt-2 shrink-0"></span>
                            <span><strong class="text-slate-800">Retrospectivas</strong> al final de cada sprint para mejorar el proceso continuamente.</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Asignaturas implicadas -->
        <div class="mt-16 relative overflow-hidden rounded-3xl">
            <!-- Fondo de gradiente con blobs animados -->
            <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 via-white to-violet-50 rounded-3xl"></div>
            <div class="blob blob-1 absolute -top-20 -left-20 w-80 h-80 bg-blue-400/20 rounded-full blur-3xl pointer-events-none"></div>
            <div class="blob blob-2 absolute -bottom-20 -right-20 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl pointer-events-none"></div>
            <div class="blob blob-3 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-72 h-72 bg-cyan-400/15 rounded-full blur-3xl pointer-events-none"></div>

            <div class="relative p-10 md:p-14">
                <div class="text-center max-w-2xl mx-auto mb-12">
                    <span class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block">
                        Contexto académico
                    </span>
                    <h2 class="text-3xl md:text-4xl font-black text-slate-900 uppercase">
                        Asignaturas implicadas
                    </h2>
                    <p class="text-slate-500 mt-4 font-medium">
                        UFVShares integra conocimientos de cuatro asignaturas clave del
                        Grado en Ingeniería Informática de la UFV.
                    </p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="subject-grid">

                    <!-- IPO -->
                    <div class="subject-card group relative bg-white/80 backdrop-blur-sm rounded-2xl p-7 border border-white/70 shadow-sm hover:shadow-2xl hover:shadow-blue-500/20 transition-all duration-500 hover:-translate-y-3 overflow-hidden cursor-default opacity-0 translate-y-8">
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-blue-500/8 to-cyan-500/8 rounded-2xl pointer-events-none"></div>
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-blue-500 to-cyan-400 rounded-t-2xl"></div>
                        <div class="absolute -bottom-3 -right-1 text-7xl font-black text-blue-500/5 group-hover:text-blue-500/12 transition-colors duration-500 select-none leading-none tracking-tighter">IPO</div>
                        <div class="relative">
                            <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-xl flex items-center justify-center mb-5 shadow-md group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-blue-500/40 transition-all duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122" />
                                </svg>
                            </div>
                            <h3 class="text-slate-900 font-black text-sm uppercase tracking-tight mb-3">
                                Interacción Persona-Ordenador
                            </h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Diseño de interfaces centrado en el usuario, usabilidad, accesibilidad y experiencia de usuario (UX/UI) aplicados al frontend.
                            </p>
                        </div>
                    </div>

                    <!-- DIS -->
                    <div class="subject-card group relative bg-white/80 backdrop-blur-sm rounded-2xl p-7 border border-white/70 shadow-sm hover:shadow-2xl hover:shadow-violet-500/20 transition-all duration-500 hover:-translate-y-3 overflow-hidden cursor-default opacity-0 translate-y-8" style="transition-delay: 100ms;">
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-violet-500/8 to-purple-500/8 rounded-2xl pointer-events-none"></div>
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-violet-500 to-purple-400 rounded-t-2xl"></div>
                        <div class="absolute -bottom-3 -right-1 text-7xl font-black text-violet-500/5 group-hover:text-violet-500/12 transition-colors duration-500 select-none leading-none tracking-tighter">DIS</div>
                        <div class="relative">
                            <div class="w-12 h-12 bg-gradient-to-br from-violet-500 to-purple-400 rounded-xl flex items-center justify-center mb-5 shadow-md group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-violet-500/40 transition-all duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                                </svg>
                            </div>
                            <h3 class="text-slate-900 font-black text-sm uppercase tracking-tight mb-3">
                                Desarrollo e Integración de Software
                            </h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Integración de sistemas heterogéneos, APIs REST, arquitecturas cliente-servidor y prácticas de CI/CD.
                            </p>
                        </div>
                    </div>

                    <!-- IS2 -->
                    <div class="subject-card group relative bg-white/80 backdrop-blur-sm rounded-2xl p-7 border border-white/70 shadow-sm hover:shadow-2xl hover:shadow-emerald-500/20 transition-all duration-500 hover:-translate-y-3 overflow-hidden cursor-default opacity-0 translate-y-8" style="transition-delay: 200ms;">
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-emerald-500/8 to-teal-500/8 rounded-2xl pointer-events-none"></div>
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-emerald-500 to-teal-400 rounded-t-2xl"></div>
                        <div class="absolute -bottom-3 -right-1 text-7xl font-black text-emerald-500/5 group-hover:text-emerald-500/12 transition-colors duration-500 select-none leading-none tracking-tighter">IS2</div>
                        <div class="relative">
                            <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-400 rounded-xl flex items-center justify-center mb-5 shadow-md group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-emerald-500/40 transition-all duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                                </svg>
                            </div>
                            <h3 class="text-slate-900 font-black text-sm uppercase tracking-tight mb-3">
                                Ingeniería de Software II
                            </h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Metodologías ágiles (Scrum), gestión de proyectos software, análisis de requisitos, casos de uso y documentación técnica.
                            </p>
                        </div>
                    </div>

                    <!-- POO -->
                    <div class="subject-card group relative bg-white/80 backdrop-blur-sm rounded-2xl p-7 border border-white/70 shadow-sm hover:shadow-2xl hover:shadow-amber-500/20 transition-all duration-500 hover:-translate-y-3 overflow-hidden cursor-default opacity-0 translate-y-8" style="transition-delay: 300ms;">
                        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 bg-gradient-to-br from-amber-500/8 to-orange-500/8 rounded-2xl pointer-events-none"></div>
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-amber-500 to-orange-400 rounded-t-2xl"></div>
                        <div class="absolute -bottom-3 -right-1 text-7xl font-black text-amber-500/5 group-hover:text-amber-500/12 transition-colors duration-500 select-none leading-none tracking-tighter">POO</div>
                        <div class="relative">
                            <div class="w-12 h-12 bg-gradient-to-br from-amber-500 to-orange-400 rounded-xl flex items-center justify-center mb-5 shadow-md group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-amber-500/40 transition-all duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
                                </svg>
                            </div>
                            <h3 class="text-slate-900 font-black text-sm uppercase tracking-tight mb-3">
                                Programación Orientada a Objetos
                            </h3>
                            <p class="text-slate-500 text-sm leading-relaxed">
                                Diseño de clases, herencia, polimorfismo y patrones de diseño aplicados al backend en Java con Spring Boot.
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</section>

<style>
    /* Blobs flotantes */
    .blob {
        animation: float-blob 8s ease-in-out infinite;
    }
    .blob-2 { animation-delay: 2s; animation-direction: alternate-reverse; }
    .blob-3 { animation-delay: 4s; }

    @keyframes float-blob {
        0%, 100% { transform: translate(0, 0) scale(1); }
        33%  { transform: translate(20px, -20px) scale(1.05); }
        66%  { transform: translate(-15px, 15px) scale(0.97); }
    }

    /* Entrada de tarjetas */
    .subject-card.visible {
        opacity: 1 !important;
        transform: translateY(0) !important;
        transition: opacity 0.6s ease-out, transform 0.6s ease-out,
                    box-shadow 0.5s ease, transform 0.5s ease;
    }
</style>

<script>
    // Scroll-reveal para las tarjetas de asignaturas
    const subjectCards = document.querySelectorAll<HTMLElement>(".subject-card");

    const revealObserver = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    const el = entry.target as HTMLElement;
                    // Respeta el transition-delay ya definido en el elemento
                    el.classList.add("visible");
                    revealObserver.unobserve(el);
                }
            });
        },
        { threshold: 0.15 }
    );

    subjectCards.forEach((card) => revealObserver.observe(card));
</script>
