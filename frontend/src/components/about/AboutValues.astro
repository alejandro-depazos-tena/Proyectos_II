---
import AboutCard from "./AboutCard.astro";

const values = [
    {
        title: "Aprendizaje continuo",
        description:
            "Cada decisión técnica del proyecto fue una oportunidad de aprender y aplicar conocimientos reales de ingeniería del software.",
        icon: "lucide:graduation-cap",
    },
    {
        title: "Trabajo en equipo",
        description:
            "Coordinamos sprints ágiles, revisiones de código y reuniones semanales para avanzar juntos hacia el mismo objetivo.",
        icon: "lucide:users",
    },
    {
        title: "Calidad técnica",
        description:
            "Aplicamos buenas prácticas: arquitectura limpia, separación de responsabilidades y pruebas desde el primer día.",
        icon: "lucide:award",
    },
];
---

<section class="py-20 bg-slate-50 px-4">
    <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-2xl mx-auto mb-16">
            <span
                class="text-primary font-bold uppercase tracking-widest text-sm mb-4 block"
                >Nuestra filosofía</span
            >
            <h2
                class="text-3xl md:text-5xl font-black text-slate-900 uppercase"
            >
                Valores que guiaron el proyecto
            </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {values.map((value) => <AboutCard {...value} />)}
        </div>
    </div>
</section>
