---
import { Icon } from "astro-icon/components";

const contactDetails = [
    {
        icon: "lucide:map-pin",
        title: "Campus UFV",
        lines: [
            "Ctra. Pozuelo a Majadahonda, km 1.800",
            "28223 Pozuelo de Alarcón, Madrid",
        ],
    },
    {
        icon: "lucide:mail",
        title: "Soporte técnico",
        lines: ["soporte@ufvshares.es"],
    },
    {
        icon: "lucide:clock",
        title: "Horario de atención",
        lines: ["Lunes a Viernes: 9:00 – 20:00 h", "Fines de semana: 10:00 – 14:00 h"],
    },
    {
        icon: "lucide:graduation-cap",
        title: "Solo para estudiantes UFV",
        lines: ["Necesitas cuenta universitaria (@ufv.es) para registrarte"],
    },
];
---

<div class="space-y-6 mb-10">
    {
        contactDetails.map((item) => (
            <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary shrink-0">
                    <Icon name={item.icon} class="w-5 h-5" />
                </div>
                <div>
                    <h3 class="font-bold text-lg">{item.title}</h3>
                    <p class="text-base-content/70">
                        {item.lines.map((line, index) => (
                            <>
                                {line}
                                {index < item.lines.length - 1 && <br />}
                            </>
                        ))}
                    </p>
                </div>
            </div>
        ))
    }
</div>
