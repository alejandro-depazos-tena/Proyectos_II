---
import { Icon } from "astro-icon/components";

interface Seller {
    name: string;
    avatar?: string;
    degree?: string;
    rating?: number;
    totalSales?: number;
    whatsapp?: string;
    email?: string;
}

interface Product {
    name: string;
    price: number;
    description: string;
    category: string;
    stock: number;
    badge?: string;
    discount?: number;
    image?: string;
    images?: string[];
    specs?: { label: string; value: string }[];
    slug?: string;
    seller?: Seller;
}

interface Props {
    product: Product;
}

const { product } = Astro.props;

const discountedPrice = product.price * (1 - (product.discount || 0) / 100);
const productSlug = product.slug || product.name.toLowerCase().replace(/\s+/g, "-");
const productImage = product.image || (product as any).images?.[0] || "";
---

<div
    class="product-info space-y-10"
    data-product={JSON.stringify({
        id: productSlug,
        name: product.name,
        price: product.price,
        image: productImage,
        category: product.category,
        discount: product.discount,
        stock: product.stock,
    })}
    data-favorite={JSON.stringify({
        id: productSlug,
        name: product.name,
        price: product.price,
        image: productImage,
        stock: product.stock,
        slug: productSlug,
    })}
>
    <!-- Header Info -->
    <div class="space-y-4">
        <span
            class="text-primary font-black uppercase text-xs tracking-[0.3em] italic"
        >
            {product.category}
            {product.badge ? `/ ${product.badge}` : ""}
        </span>
        <h1
            class="text-4xl md:text-5xl font-black text-slate-950 uppercase tracking-tighter leading-tight"
        >
            {product.name}
        </h1>
        <div class="flex items-center gap-4">
            <div class="flex flex-col">
                {
                    product.discount && product.discount > 0 && (
                        <span class="text-sm font-bold text-slate-400 line-through decoration-red-500/50">
                            ${product.price.toLocaleString()}
                        </span>
                    )
                }
                <span class="text-4xl font-black text-slate-900">
                    ${
                        discountedPrice.toLocaleString(undefined, {
                            minimumFractionDigits: 0,
                            maximumFractionDigits: 0,
                        })
                    }
                </span>
            </div>
            <div class="flex flex-col gap-2">
                {
                    product.discount && product.discount > 0 && (
                        <span class="badge bg-red-50 text-red-600 border-none font-black px-3 py-1 text-[10px] uppercase tracking-widest">
                            Ahorra {product.discount}%
                        </span>
                    )
                }
                {
                    product.stock > 0 ? (
                        <span class="badge bg-emerald-50 text-emerald-600 border-none font-bold p-3">
                            En stock ({product.stock})
                        </span>
                    ) : (
                        <span class="badge bg-red-50 text-red-600 border-none font-bold p-3">
                            Sin stock
                        </span>
                    )
                }
            </div>
        </div>
    </div>

    <!-- Description -->
    <div class="space-y-4">
        <h3
            class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400"
        >
            Descripci\u00f3n
        </h3>
        <p class="text-slate-600 font-medium leading-relaxed text-lg">
            {
                product.description ||
                    "No hay una descripci\u00f3n disponible para este producto en este momento."
            }
        </p>
    </div>

    <!-- Specs Grid -->
    {
        product.specs && (
            <div class="grid grid-cols-2 gap-6 p-8 bg-slate-50 rounded-3xl border border-slate-100">
                {product.specs.map((spec) => (
                    <div class="space-y-1">
                        <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">
                            {spec.label}
                        </p>
                        <p class="text-sm font-bold text-slate-900 uppercase italic">
                            {spec.value}
                        </p>
                    </div>
                ))}
            </div>
        )
    }

    <!-- Seller Info Card -->
    {product.seller && (
        <div class="rounded-3xl border border-slate-100 bg-slate-50 p-6 space-y-4">
            <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400">
                {product.badge === "Alquiler" ? "Arrendador" : "Vendedor"}
            </h3>
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0">
                    {product.seller.avatar ? (
                        <img
                            src={product.seller.avatar}
                            alt={product.seller.name}
                            class="w-12 h-12 rounded-full object-cover"
                        />
                    ) : (
                        <Icon name="lucide:user" class="w-6 h-6 text-primary" />
                    )}
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-black text-slate-900 truncate">{product.seller.name}</p>
                    {product.seller.degree && (
                        <p class="text-xs text-slate-500 font-medium truncate">{product.seller.degree}</p>
                    )}
                </div>
                <div class="flex flex-col items-end gap-1">
                    {product.seller.rating && (
                        <div class="flex items-center gap-1">
                            <Icon name="lucide:star" class="w-3.5 h-3.5 text-amber-400 fill-amber-400" />
                            <span class="text-xs font-black text-slate-700">{product.seller.rating.toFixed(1)}</span>
                        </div>
                    )}
                    {product.seller.totalSales !== undefined && (
                        <span class="text-[10px] text-slate-400 font-medium">{product.seller.totalSales} ventas</span>
                    )}
                </div>
            </div>
        </div>
    )}

    <!-- Actions -->
    <div class="space-y-4 pt-4">
        <!-- Contact Button -->
        {product.seller?.email ? (
            <a
                href={`mailto:${product.seller.email}?subject=Interesse en: ${encodeURIComponent(product.name)}`}
                class="w-full bg-primary text-white rounded-2xl py-5 px-8 font-black uppercase tracking-widest text-sm flex items-center justify-center gap-4 hover:bg-primary/80 transition-all active:scale-[0.98]"
            >
                <Icon name="lucide:mail" class="w-5 h-5" />
                Contactar al {product.badge === "Alquiler" ? "arrendador" : "vendedor"}
            </a>
        ) : (
            <a
                href="/chats"
                class="w-full bg-primary text-white rounded-2xl py-5 px-8 font-black uppercase tracking-widest text-sm flex items-center justify-center gap-4 hover:bg-primary/80 transition-all active:scale-[0.98]"
            >
                <Icon name="lucide:message-circle" class="w-5 h-5" />
                Contactar al {product.badge === "Alquiler" ? "arrendador" : "vendedor"}
            </a>
        )}

        <!-- Add to Favorites -->
        <button
            id="add-to-favorite-btn"
            class="w-full border-2 border-primary text-primary rounded-2xl py-5 font-black uppercase tracking-widest text-sm flex items-center justify-center gap-4 hover:bg-primary hover:text-white transition-all active:scale-[0.98] cursor-pointer"
        >
            <Icon name="lucide:heart" class="w-5 h-5 transition-colors duration-300" id="fav-heart-icon" />
            <span id="fav-btn-label">Guardar en favoritos</span>
        </button>
    </div>

    <!-- Trust Badges -->
    <div
        class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-slate-100"
    >
        <div class="flex items-center gap-3 text-slate-500">
            <Icon name="lucide:shield-check" class="w-5 h-5 text-emerald-500" />
            <span class="text-[10px] uppercase font-bold tracking-widest"
                >Garant\u00eda certificada</span
            >
        </div>
        <div class="flex items-center gap-3 text-slate-500">
            <Icon name="lucide:truck" class="w-5 h-5 text-amber-500" />
            <span class="text-[10px] uppercase font-bold tracking-widest"
                >Env\u00edo asegurado 24/48h</span
            >
        </div>
    </div>
</div>

<script>
    import { toggleFavorite, isFavorite, favoriteItems } from "../../store/favoriteStore";
    import { toast } from "sonner";

    function setupPurchaseActions() {
        const productInfo = document.querySelector(".product-info");
        if (!productInfo) return;

        const favoriteData = JSON.parse(
            productInfo.getAttribute("data-favorite") || "{}",
        );
        const favBtn = document.getElementById("add-to-favorite-btn");
        const favIcon = document.getElementById("fav-heart-icon");
        const favLabel = document.getElementById("fav-btn-label");

        const updateFavUI = (isFav: boolean) => {
            if (!favBtn || !favIcon || !favLabel) return;
            if (isFav) {
                favIcon.classList.add("fill-primary");
                favLabel.textContent = "Eliminar de favoritos";
                favBtn.classList.add("bg-primary/10");
            } else {
                favIcon.classList.remove("fill-primary");
                favLabel.textContent = "Guardar en favoritos";
                favBtn.classList.remove("bg-primary/10");
            }
        };

        // Init favorite button state
        updateFavUI(isFavorite(favoriteData.id));

        // Subscribe to store changes
        favoriteItems.subscribe(() => {
            updateFavUI(isFavorite(favoriteData.id));
        });

        favBtn?.addEventListener("click", () => {
            const result = toggleFavorite(favoriteData);
            if (result.success) {
                toast.success(result.message);
            }
        });
    }

    setupPurchaseActions();
    document.addEventListener("astro:page-load", setupPurchaseActions);
</script>
