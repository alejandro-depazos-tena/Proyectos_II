---
import { Icon } from "astro-icon/components";

const categories = [
    { name: "Inicio", href: "/app" },
    { name: "Libros", href: "/category/libros" },
    { name: "Material", href: "/category/material" },
    { name: "Tecnología", href: "/category/tecnologia" },
    { name: "Idiomas", href: "/category/idiomas" },
    { name: "Deporte", href: "/category/deporte" },
];
---

<div class="bg-primary text-primary-content shadow-sm relative z-40">
    <div
        class="max-w-7xl mx-auto flex justify-between items-center text-xs sm:text-sm font-medium h-10"
    >
        <!-- Mobile: Heart + Contact -->
        <div
            class="flex sm:hidden w-full items-center justify-between h-full px-4"
        >
            <a
                href="/favorites"
                class="flex items-center gap-2 h-full px-2 hover:bg-white/10 transition-colors"
                aria-label="Favoritos"
            >
                <Icon name="lucide:heart" class="w-5 h-5" />
                <span>Favoritos</span>
            </a>

            <div class="flex h-full items-center">
                <a
                    href="/contact"
                    class="flex items-center h-full px-2 hover:bg-white/10 transition-colors"
                    >Contacto</a
                >
            </div>
        </div>

        <!-- Desktop: Left Side (Mapped Categories) -->
        <div class="hidden sm:flex h-full items-center">
            {
                categories.map((cat) => (
                    <a
                        href={cat.href}
                        class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer"
                    >
                        {cat.name}
                    </a>
                ))
            }
        </div>

        <!-- Desktop: Right Side -->
        <div class="hidden sm:flex h-full items-center">
            <a
                href="/about"
                class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer"
                >Sobre UFV Shares</a
            >
            <a
                href="/blog"
                class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer"
                >Blog</a
            >
            <a
                href="/contact"
                class="flex items-center h-full px-4 hover:bg-white/10 text-white/90 hover:text-white transition-all cursor-pointer"
                >Contacto</a
            >
        </div>
    </div>

</div>
