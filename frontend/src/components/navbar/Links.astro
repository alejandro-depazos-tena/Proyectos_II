---
import { Icon } from "astro-icon/components";
---

<div class="bg-primary text-primary-content shadow-sm relative z-40">
    <div class="max-w-7xl mx-auto flex justify-between items-center text-xs sm:text-sm font-medium h-10 px-4 sm:px-6 lg:px-8">

        <!-- Mobile: scroll horizontally -->
        <div class="flex sm:hidden w-full items-center gap-0 h-full overflow-x-auto scrollbar-none">
            <a href="/app"       class="flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:home" class="w-3.5 h-3.5" />Inicio
            </a>
            <a href="/favorites" class="flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:heart" class="w-3.5 h-3.5" />Favoritos
            </a>
            <a href="/chats" class="chat-link-mobile relative flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:message-circle" class="w-3.5 h-3.5" />Chats
                <span id="nav-chat-badge-mobile" class="chat-unread-badge hidden" aria-label="Mensajes sin leer">0</span>
            </a>
            <a href="/blog"      class="flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:rss" class="w-3.5 h-3.5" />Blog
            </a>
            <a href="/reviews"   class="flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:star" class="w-3.5 h-3.5" />Reseñas
            </a>
            <a href="/contact"   class="flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:mail" class="w-3.5 h-3.5" />Contacto
            </a>
            <a href="/admin" data-admin-link class="hidden flex items-center gap-1.5 h-full px-3 whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
                <Icon name="lucide:shield" class="w-3.5 h-3.5" />Admin
            </a>
        </div>

        <!-- Desktop left: primary section links -->
        <div class="hidden sm:flex h-full items-center gap-0">
            <a href="/app"
                class="links-item flex items-center gap-1.5 h-full px-4 hover:bg-white/10 text-white/80 hover:text-white transition-all text-xs font-medium">
                <Icon name="lucide:home" class="w-3.5 h-3.5" />Inicio
            </a>
            <a href="/reviews"
                class="links-item flex items-center gap-1.5 h-full px-4 hover:bg-white/10 text-white/80 hover:text-white transition-all text-xs font-medium">
                <Icon name="lucide:star" class="w-3.5 h-3.5" />Reseñas
            </a>
            <a href="/favorites"
                class="links-item flex items-center gap-1.5 h-full px-4 hover:bg-white/10 text-white/80 hover:text-white transition-all text-xs font-medium">
                <Icon name="lucide:heart" class="w-3.5 h-3.5" />Favoritos
            </a>
            <a href="/chats"
                class="links-item chat-link-desktop relative flex items-center gap-1.5 h-full px-4 hover:bg-white/10 text-white/80 hover:text-white transition-all text-xs font-medium">
                <Icon name="lucide:message-circle" class="w-3.5 h-3.5" />Chats
                <span id="nav-chat-badge-desktop" class="chat-unread-badge hidden" aria-label="Mensajes sin leer">0</span>
            </a>
        </div>

        <!-- Desktop right: info + publish -->
        <div class="hidden sm:flex h-full items-center gap-0">
            <a href="/blog"    class="flex items-center h-full px-3 hover:bg-white/10 text-white/70 hover:text-white transition-all text-xs">Blog</a>
            <a href="/about"   class="flex items-center h-full px-3 hover:bg-white/10 text-white/70 hover:text-white transition-all text-xs">Sobre nosotros</a>
            <a href="/contact" class="flex items-center h-full px-3 hover:bg-white/10 text-white/70 hover:text-white transition-all text-xs">Contacto</a>
            <a href="/admin" data-admin-link class="hidden flex items-center h-full px-3 hover:bg-white/10 text-white/70 hover:text-white transition-all text-xs">Admin</a>
            <div class="w-px h-5 bg-white/20 mx-1"></div>
            <a href="/profile#publicar"
                class="flex items-center gap-1.5 h-full px-4 bg-white/15 hover:bg-white/25 text-white font-bold transition-all text-xs">
                <Icon name="lucide:plus-circle" class="w-3.5 h-3.5" />Publicar
            </a>
        </div>
    </div>
</div>

<style>
    .scrollbar-none::-webkit-scrollbar { display: none; }
    .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }

    .chat-link-mobile,
    .chat-link-desktop {
        overflow: visible;
    }

    .chat-unread-badge {
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        border-radius: 999px;
        background: #ef4444;
        color: #ffffff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 700;
        line-height: 1;
        box-shadow: 0 1px 4px rgba(0,0,0,.25);
    }

    .chat-unread-badge.hidden {
        display: none;
    }

    .chat-link-mobile .chat-unread-badge {
        margin-left: 2px;
    }

    .chat-link-desktop .chat-unread-badge {
        margin-left: 4px;
    }
</style>

<script>
    // Highlight current page
    const path = location.pathname;
    document.querySelectorAll<HTMLAnchorElement>('.links-item').forEach(link => {
        const href = new URL(link.href).pathname;
        if (href === path) {
            link.classList.add('bg-white/20', 'text-white', '!font-bold');
        }
    });

    const chatBadgeDesktop = document.getElementById('nav-chat-badge-desktop');
    const chatBadgeMobile = document.getElementById('nav-chat-badge-mobile');
    const isAdmin = localStorage.getItem('ufvshares_admin') === '1';
    document.querySelectorAll<HTMLElement>('[data-admin-link]').forEach((node) => {
        node.classList.toggle('hidden', !isAdmin);
    });

    function setChatUnreadBadge(total: number) {
        const value = total > 99 ? '99+' : String(total);
        [chatBadgeDesktop, chatBadgeMobile].forEach((badge) => {
            if (!badge) return;
            if (total > 0) {
                badge.textContent = value;
                badge.classList.remove('hidden');
            } else {
                badge.classList.add('hidden');
            }
        });
    }

    window.addEventListener('ufvshares:chat-unread', (event: Event) => {
        const customEvent = event as CustomEvent<{ total: number }>;
        setChatUnreadBadge(customEvent.detail?.total ?? 0);
    });
</script>
