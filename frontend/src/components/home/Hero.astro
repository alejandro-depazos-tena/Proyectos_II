---
// Hero personalizado — sin imágenes, con saludo dinámico y barra de búsqueda
---

<!-- Greeting banner -->
<section class="bg-gradient-to-br from-[#0f172a] via-[#1e1b4b] to-[#312e81] pt-6 pb-10 px-4 relative overflow-hidden">
  <!-- decorative blobs -->
  <div class="absolute -top-24 -left-24 w-72 h-72 rounded-full bg-primary/20 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-64 h-64 rounded-full bg-yellow-400/10 blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <!-- top row: greeting + publish btn -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <p class="text-white/50 text-sm font-medium mb-1 uppercase tracking-widest">Bienvenido de vuelta</p>
        <h1 class="text-3xl sm:text-4xl font-black text-white" id="hero-greeting">UFV Shares</h1>
      </div>
      <a href="/profile#publicar"
        class="btn btn-warning btn-md rounded-full px-7 gap-2 shadow-lg hover:scale-105 transition-transform self-start sm:self-auto font-bold">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
        Publicar anuncio
      </a>
    </div>

    <!-- Search bar -->
    <div class="relative max-w-2xl">
      <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
      <input
        id="hero-search"
        type="text"
        placeholder="Busca libros, calculadoras, portátiles…"
        class="w-full pl-12 pr-16 py-4 rounded-2xl bg-white/10 backdrop-blur-sm border border-white/20 text-white placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-white/30 focus:bg-white/15 transition-all text-base"
        autocomplete="off"
      />
      <button id="hero-search-btn"
        class="absolute right-2 top-1/2 -translate-y-1/2 btn btn-primary btn-sm rounded-xl px-4">
        Buscar
      </button>
    </div>

    <!-- quick stats pills -->
    <div class="flex flex-wrap gap-3 mt-6" id="hero-stats">
      <span class="badge badge-lg bg-white/10 border-white/20 text-white/70 gap-1.5 font-medium">
        <span class="w-2 h-2 rounded-full bg-success inline-block animate-pulse"></span>
        Marketplace activo
      </span>
      <span class="badge badge-lg bg-white/10 border-white/20 text-white/70 font-medium" id="stat-products">Cargando anuncios…</span>
    </div>
  </div>
</section>


<script>
  // Greeting with username
  const token = localStorage.getItem('ufvshares_token');
  if (token) {
    try {
      const payload = JSON.parse(atob(token.split('.')[1]));
      const name = payload.nombre || payload.name || payload.sub || '';
      const first = name.split(' ')[0];
      if (first) {
        const el = document.getElementById('hero-greeting');
        if (el) el.textContent = '¡Hola, ' + first + '!';
      }
    } catch {}
  }

  // Search
  function triggerSearch() {
    const q = (document.getElementById('hero-search') as HTMLInputElement)?.value?.trim();
    if (q) {
      document.getElementById('featured-products-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      window.dispatchEvent(new CustomEvent('ufv:search', { detail: q }));
    }
  }
  document.getElementById('hero-search-btn')?.addEventListener('click', triggerSearch);
  document.getElementById('hero-search')?.addEventListener('keydown', (e: Event) => {
    if ((e as KeyboardEvent).key === 'Enter') triggerSearch();
  });

</script>

<style>
  .scrollbar-none::-webkit-scrollbar { display: none; }
  .scrollbar-none { -ms-overflow-style: none; scrollbar-width: none; }
</style>


