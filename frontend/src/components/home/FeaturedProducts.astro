---
import Pagination from "../ui/Pagination.astro";
const API_BASE = import.meta.env.PUBLIC_API_BASE ?? "http://localhost:8080/api";
---

<section class="pb-10 bg-base-100" id="featured-products-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-12">
            <h2
                class="text-3xl font-black text-slate-900 uppercase tracking-tighter"
            >
                Anuncios destacados
            </h2>
        </div>

        <!-- Loading skeletons -->
        <div id="products-loading" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 min-h-[400px]">
            {Array.from({ length: 8 }).map(() => (
                <div class="rounded-xl overflow-hidden border border-base-200 animate-pulse">
                    <div class="bg-slate-200" style="aspect-ratio: 4/5;"></div>
                    <div class="p-4 space-y-3">
                        <div class="h-3 bg-slate-200 rounded w-1/3"></div>
                        <div class="h-4 bg-slate-200 rounded w-3/4"></div>
                        <div class="h-4 bg-slate-200 rounded w-1/2"></div>
                    </div>
                </div>
            ))}
        </div>

        <!-- Real product grid (hidden until loaded) -->
        <div
            id="product-grid"
            class="hidden grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 min-h-[800px]"
        ></div>

        <p id="no-products-msg" class="hidden text-center py-24 text-slate-400 font-bold uppercase tracking-widest bg-slate-50 rounded-3xl border-2 border-dashed border-slate-200">
            No hay productos disponibles ahora mismo
        </p>

        <!-- Pagination Controls -->
        <div class="flex justify-center mt-12" id="pagination-controls"></div>
    </div>
</section>

<script define:vars={{ API_BASE }}>
    const ITEMS_PER_PAGE = 8;

    const BACKEND_BASE = (() => { try { return new URL(API_BASE).origin; } catch { return 'http://localhost:8080'; } })();

    function getImageUrl(product) {
        if (product.fotoUrl) return BACKEND_BASE + product.fotoUrl;
        if (product.fotos && product.fotos.length > 0) return BACKEND_BASE + product.fotos[0].url;
        if (product.imagenUrl) return product.imagenUrl;
        return '/foto.webp';
    }

    function escAttr(str) {
        return String(str ?? '').replace(/'/g, '&#39;').replace(/"/g, '&quot;');
    }

    function createProductCard(p) {
        const img = getImageUrl(p);
        const id = p.idProducto;
        const title = p.titulo || '';
        const category = (p.categoria || '').replace(/_/g, ' ');
        const price = p.precio != null ? new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR' }).format(Number(p.precio)) : 'Gratis';
        const tipo = p.tipoTransaccion === 'ALQUILER' ? 'Alquiler' : 'Venta';

        const productData = escAttr(JSON.stringify({ id: String(id), name: title, price: p.precio ?? 0, image: img, stock: 1 }));
        const favData = escAttr(JSON.stringify({ id: String(id), name: title, price: p.precio ?? 0, image: img, stock: 1, slug: String(id) }));

        return `<div class="product-card-wrapper hidden">
  <div class="card bg-base-100 shadow-sm hover:shadow-xl transition-shadow duration-300 group relative rounded-xl overflow-hidden border border-base-200">
    <div class="absolute top-3 right-3 z-20 flex flex-col gap-2 translate-x-12 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-300 ease-in-out">
      <button class="add-to-favorite-btn btn btn-circle btn-sm bg-white hover:bg-primary hover:text-white border-none shadow-md" aria-label="AÃ±adir a favoritos" data-favorite='${favData}'>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      </button>
      <button class="add-to-cart-btn btn btn-circle btn-sm bg-white hover:bg-primary hover:text-white border-none shadow-md" aria-label="AÃ±adir al carrito" data-product='${productData}'>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      </button>
    </div>
    <div class="relative w-full overflow-hidden bg-gray-100" style="aspect-ratio:4/5">
      <img src="${img}" alt="${escAttr(title)}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" onerror="this.src='/foto.webp'" />
      <a href="/product/view?id=${id}" class="absolute inset-0 z-10" aria-label="Ver ${escAttr(title)}"></a>
      <span class="absolute top-3 left-3 badge badge-primary font-bold text-xs z-20">${tipo}</span>
    </div>
    <div class="p-4">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-widest">${category}</span>
      <h3 class="font-bold text-base mt-1 truncate" title="${escAttr(title)}">${title}</h3>
      <div class="flex items-center justify-between mt-2">
        <span class="text-xl font-bold text-primary">${price}</span>
        <span class="text-success text-xs flex items-center gap-1">
          <span class="w-2 h-2 rounded-full bg-success inline-block"></span>Disponible
        </span>
      </div>
    </div>
  </div>
</div>`;
    }

    function renderPagination(currentPage, totalPages) {
        const container = document.getElementById('pagination-controls');
        if (!container || totalPages <= 1) { if(container) container.innerHTML = ''; return; }
        let html = '<div class="join">';
        for (let i = 1; i <= totalPages; i++) {
            html += `<button class="join-item btn pagination-btn${i === currentPage ? ' btn-active' : ''}" data-page="${i}">${i}</button>`;
        }
        html += '</div>';
        container.innerHTML = html;
        container.querySelectorAll('.pagination-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const page = parseInt(btn.dataset.page);
                showPage(page);
            });
        });
    }

    function showPage(page) {
        const wrappers = document.querySelectorAll('#product-grid .product-card-wrapper');
        const total = wrappers.length;
        const totalPages = Math.ceil(total / ITEMS_PER_PAGE);
        const start = (page - 1) * ITEMS_PER_PAGE;
        const end = start + ITEMS_PER_PAGE;
        wrappers.forEach((w, i) => {
            w.classList.toggle('hidden', i < start || i >= end);
        });
        renderPagination(page, totalPages);
        document.getElementById('featured-products-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    async function loadProducts() {
        const loading = document.getElementById('products-loading');
        const grid = document.getElementById('product-grid');
        const noMsg = document.getElementById('no-products-msg');
        if (!grid) return;

        const token = localStorage.getItem('ufvshares_token');
        const headers = token ? { 'Authorization': 'Bearer ' + token } : {};

        try {
            const res = await fetch(`${API_BASE}/productos`, { headers });
            if (!res.ok) throw new Error('Error ' + res.status);
            const products = await res.json();

            loading?.classList.add('hidden');

            if (!products.length) {
                noMsg?.classList.remove('hidden');
                return;
            }

            grid.innerHTML = products.map(createProductCard).join('');
            grid.classList.remove('hidden');
            grid.classList.add('grid');

            showPage(1);

            // Reinit cart & favorites listeners for dynamically added buttons
            document.dispatchEvent(new Event('astro:page-load'));
        } catch (e) {
            loading?.classList.add('hidden');
            noMsg?.classList.remove('hidden');
            console.error('Error cargando productos:', e);
        }
    }

    loadProducts();
</script>

